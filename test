#!/usr/bin/env python3
# csv_to_html_virtual.py

import csv
import os
import sys
import html
import json
from datetime import datetime

def read_csv(path):
    with open(path, "r", newline="", encoding="utf-8") as f:
        sample = f.read(4096)
        f.seek(0)
        try:
            dialect = csv.Sniffer().sniff(sample, delimiters=",;\t|")
        except Exception:
            dialect = csv.excel
        reader = csv.reader(f, dialect)
        rows = list(reader)
    if not rows:
        return [], []
    return rows[0], rows[1:]

def esc(s):
    return html.escape("" if s is None else str(s))

def build_html(title, header, rows):
    now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    header_js = json.dumps(header, ensure_ascii=False)
    data_js = json.dumps(rows, ensure_ascii=False)

    # keep real <table> header for sticky th, but body is virtual
    ths = "\n".join(f"<th data-idx='{i}'>{esc(h)}</th>" for i, h in enumerate(header))

    return f"""<!doctype html>
<html lang="bg">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{esc(title)}</title>
  <style>
    body {{ font-family: Arial, sans-serif; margin: 16px; }}
    .topbar {{ display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin-bottom:12px; }}
    input[type="search"] {{ padding:8px 10px; min-width:280px; }}
    .meta {{ color:#666; font-size: 12px; }}
    .wrap {{
      height: 78vh;
      overflow: auto;
      border: 1px solid #eee;
      position: relative;
    }}
    table {{ border-collapse: collapse; width: 100%; table-layout: fixed; }}
    th, td {{ border: 1px solid #ddd; padding: 8px; font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }}
    th {{ position: sticky; top: 0; background: #f5f5f5; cursor: pointer; user-select:none; z-index: 5; }}
    tr:nth-child(even) td {{ background: #fafafa; }}
    .hint {{ font-size:12px; color:#777; margin-bottom:8px; }}

    /* virtual spacer layers */
    .spacer {{
      height: 0px;
    }}
  </style>
</head>
<body>
  <div class="topbar">
    <h2 style="margin:0">{esc(title)}</h2>
    <input id="q" type="search" placeholder="Филтър (търси във всички колони)..." />
    <span class="meta">Генерирано: {esc(now)} | Видими: <span id="vc"></span> | Общо: <span id="tc"></span></span>
  </div>
  <div class="hint">Клик върху заглавие на колона = сортиране. (Виртуално рендериране за 15k+ реда)</div>

  <div id="wrap" class="wrap">
    <table id="t">
      <thead><tr>{ths}</tr></thead>
      <tbody id="tb">
        <tr class="spacer"><td colspan="{len(header)}" style="padding:0;border:0;"><div id="topSpacer" style="height:0px;"></div></td></tr>
        <!-- rows injected here -->
        <tr class="spacer"><td colspan="{len(header)}" style="padding:0;border:0;"><div id="botSpacer" style="height:0px;"></div></td></tr>
      </tbody>
    </table>
  </div>

<script>
const HEADERS = {header_js};
const DATA = {data_js};

(function() {{
  const wrap = document.getElementById('wrap');
  const tb = document.getElementById('tb');
  const q = document.getElementById('q');
  const vc = document.getElementById('vc');
  const tc = document.getElementById('tc');
  const topSpacer = document.getElementById('topSpacer');
  const botSpacer = document.getElementById('botSpacer');

  // -------- Performance knobs --------
  const ROW_HEIGHT = 34;      // approximate px (will self-correct a bit)
  const OVERSCAN = 10;        // render extra rows above/below viewport
  const MAX_RENDER = 400;     // hard cap rendered rows

  // Derived state
  let idx = Array.from({{length: DATA.length}}, (_, i) => i); // indices into DATA
  let filteredIdx = idx.slice();
  let sortState = {{ col: -1, dir: 1 }};

  function normalize(s) {{
    return (s || "").toString().toLowerCase();
  }}

  // Precompute "search strings" lazily to speed repeated filtering
  const searchCache = new Array(DATA.length).fill(null);
  function rowSearchString(i) {{
    let s = searchCache[i];
    if (s !== null) return s;
    s = normalize(DATA[i].join(" "));
    searchCache[i] = s;
    return s;
  }}

  // Debounce for input
  let tmr = null;
  q.addEventListener('input', () => {{
    if (tmr) clearTimeout(tmr);
    tmr = setTimeout(() => {{
      applyFilter(q.value);
    }}, 120);
  }});

  function applyFilter(text) {{
    const needle = normalize(text).trim();
    if (!needle) {{
      filteredIdx = idx.slice();
    }} else {{
      // filter on cached joined string
      const out = [];
      for (let k = 0; k < idx.length; k++) {{
        const i = idx[k];
        if (rowSearchString(i).includes(needle)) out.push(i);
      }}
      filteredIdx = out;
    }}
    // reset scroll to top for UX
    wrap.scrollTop = 0;
    render();
  }}

  function isNumberLike(v) {{
    v = (v || "").trim();
    if (!v) return false;
    if (/^\\d+:\\d{{2}}:\\d{{2}}$/.test(v)) return true;
    if (/^\\d+(\\.\\d+)?$/.test(v)) return true;
    return false;
  }}

  function parseValue(v) {{
    v = (v || "").trim();
    if (/^\\d+:\\d{{2}}:\\d{{2}}$/.test(v)) {{
      const p = v.split(':').map(x => parseInt(x,10));
      return p[0]*3600 + p[1]*60 + p[2];
    }}
    if (/^\\d+(\\.\\d+)?$/.test(v)) return parseFloat(v);
    return v.toLowerCase();
  }}

  function sortBy(col) {{
    const dir = (sortState.col === col) ? -sortState.dir : 1;
    sortState = {{ col, dir }};

    filteredIdx.sort((ia, ib) => {{
      const a = DATA[ia][col] ?? "";
      const b = DATA[ib][col] ?? "";
      const an = isNumberLike(a);
      const bn = isNumberLike(b);
      const pa = parseValue(a);
      const pb = parseValue(b);
      if (an && bn) return (pa - pb) * dir;
      return (pa > pb ? 1 : pa < pb ? -1 : 0) * dir;
    }});

    wrap.scrollTop = 0;
    render();
  }}

  // Click handlers for headers
  document.querySelectorAll('th[data-idx]').forEach(th => {{
    th.addEventListener('click', () => {{
      sortBy(parseInt(th.getAttribute('data-idx'), 10));
    }});
  }});

  // Virtual render
  let raf = null;
  wrap.addEventListener('scroll', () => {{
    if (raf) return;
    raf = requestAnimationFrame(() => {{
      raf = null;
      render();
    }});
  }});

  function clearRenderedRows() {{
    // Remove rows between spacers (keep first and last spacer rows)
    while (tb.rows.length > 2) tb.deleteRow(1);
  }}

  function render() {{
    const total = filteredIdx.length;
    tc.textContent = total.toString();

    const viewH = wrap.clientHeight;
    const scrollTop = wrap.scrollTop;

    const approxStart = Math.floor(scrollTop / ROW_HEIGHT);
    let start = Math.max(0, approxStart - OVERSCAN);
    let end = Math.min(total, approxStart + Math.ceil(viewH / ROW_HEIGHT) + OVERSCAN);

    // hard cap render count
    if (end - start > MAX_RENDER) end = start + MAX_RENDER;

    const topH = start * ROW_HEIGHT;
    const botH = Math.max(0, (total - end) * ROW_HEIGHT);

    topSpacer.style.height = topH + "px";
    botSpacer.style.height = botH + "px";

    clearRenderedRows();

    // Insert rows after top spacer (which is row 0)
    for (let p = start; p < end; p++) {{
      const i = filteredIdx[p];
      const r = DATA[i];

      const tr = document.createElement('tr');
      for (let c = 0; c < HEADERS.length; c++) {{
        const td = document.createElement('td');
        td.textContent = (r[c] ?? "");
        tr.appendChild(td);
      }}
      tb.insertBefore(tr, tb.rows[tb.rows.length - 1]); // before bottom spacer row
    }}

    vc.textContent = (end - start).toString();
  }}

  // initial render
  render();
}})();
</script>
</body>
</html>
"""

def main():
    if len(sys.argv) < 2:
        print("Usage: python3 csv_to_html_virtual.py /path/to/file.csv [output.html]", file=sys.stderr)
        sys.exit(2)

    csv_path = sys.argv[1]
    out_path = sys.argv[2] if len(sys.argv) >= 3 else os.path.splitext(csv_path)[0] + ".html"

    header, rows = read_csv(csv_path)
    title = os.path.basename(csv_path)

    doc = build_html(title, header, rows)
    with open(out_path, "w", encoding="utf-8") as f:
        f.write(doc)

    print(out_path)

if __name__ == "__main__":
    main()
