}
function drawDonut(host,cfg){
  const W=host.clientWidth,H=host.clientHeight;if(W<20||H<20)return;
  const ls=LS(),t=cfg.type||'donut',hid=hiddenOf(cfg);
  const data=cfg.data.filter(d=>!hid.has(d.name));
  const legendH=26;const pad=10;
  const R=Math.max(12,Math.min(W/2-pad,(H-legendH)/2-pad));
  const cx=W/2,cy=(H-legendH)/2;
  const total=data.reduce((a,b)=>a+b.value,0)||1;const maxV=Math.max(...data.map(d=>d.value),1);
  let s=`<svg viewBox="0 0 ${W} ${H}" width="${W}" height="${H}">`;let a0=-Math.PI/2;
  data.forEach((d,i)=>{const frac=d.value/total;const a1=a0+frac*Math.PI*2;const r=t==='rose'?(R*(0.45+0.55*(d.value/maxV))):R;const x0=cx+r*Math.cos(a0),y0=cy+r*Math.sin(a0),x1=cx+r*Math.cos(a1),y1=cy+r*Math.sin(a1);const large=(a1-a0)>Math.PI?1:0;s+=`<path class="wedge" data-i="${i}" d="M${cx} ${cy} L${x0.toFixed(1)} ${y0.toFixed(1)} A${r.toFixed(1)} ${r.toFixed(1)} 0 ${large} 1 ${x1.toFixed(1)} ${y1.toFixed(1)} Z" fill="${d.color}" stroke="${cvar('--surface')}" stroke-width="2" opacity="0" style="transform-origin:${cx}px ${cy}px"/>`;a0=a1;});
  if(t==='donut'){s+=`<circle cx="${cx}" cy="${cy}" r="${(R*0.56).toFixed(1)}" fill="${cvar('--surface')}"/><text x="${cx}" y="${cy-2}" text-anchor="middle" fill="${cvar('--text')}" font-size="${(20*ls).toFixed(1)}" font-weight="700" font-family="JetBrains Mono">${fmtShort(total)}</text><text x="${cx}" y="${cy+16}" text-anchor="middle" fill="${cvar('--muted')}" font-size="${(10.5*ls).toFixed(1)}" font-family="JetBrains Mono">${cfg.centerLabel||'общо'}</text>`;}
  let lf=10*ls;const widths=data.map(d=>22+d.name.length*lf*0.62);let totw=widths.reduce((a,b)=>a+b,0);if(totw>W-16)lf=lf*(W-16)/totw;
