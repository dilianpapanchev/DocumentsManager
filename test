const scrim=document.getElementById('scrim');
function wirePanel(el){
  el.querySelectorAll('[data-act]').forEach(b=>b.addEventListener('click',e=>{e.stopPropagation();const a=b.dataset.act;const id=panelId(el);if(a==='type')cycleType(el,id,b);if(a==='max')toggleMax(el,id);}));
  const rs=el.querySelector('[data-resize]');if(rs)wireResize(rs,el);
