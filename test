<!DOCTYPE html>

<html lang="bg">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SQL Report</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface2: #1c2128;
    --border: #30363d;
    --accent: #00d4aa;
    --accent2: #ff6b35;
    --text: #e6edf3;
    --text-muted: #8b949e;
    --text-dim: #484f58;
    --row-even: #161b22;
    --row-odd: #13181f;
    --row-hover: #1f2937;
    --match: rgba(0, 212, 170, 0.12);
    --match-border: #00d4aa;
  }

- { box-sizing: border-box; margin: 0; padding: 0; }

body {
background: var(–bg);
color: var(–text);
font-family: ‘IBM Plex Sans’, sans-serif;
font-size: 14px;
min-height: 100vh;
}

/* ── HEADER ── */
header {
background: var(–surface);
border-bottom: 1px solid var(–border);
padding: 18px 28px;
display: flex;
align-items: center;
gap: 16px;
position: sticky;
top: 0;
z-index: 100;
}

header .logo {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 18px;
font-weight: 600;
color: var(–accent);
letter-spacing: -0.5px;
}

header .logo span { color: var(–text-muted); }
header .subtitle { color: var(–text-muted); font-size: 12px; }

.header-right {
margin-left: auto;
display: flex;
align-items: center;
gap: 12px;
}

.badge {
background: rgba(0,212,170,0.15);
color: var(–accent);
font-family: ‘IBM Plex Mono’, monospace;
font-size: 11px;
padding: 3px 10px;
border-radius: 20px;
border: 1px solid rgba(0,212,170,0.3);
}

/* ── FILTER PANEL ── */
.filter-panel {
background: var(–surface2);
border-bottom: 1px solid var(–border);
padding: 16px 28px;
display: flex;
flex-wrap: wrap;
gap: 16px;
align-items: flex-end;
}

.filter-group {
display: flex;
flex-direction: column;
gap: 5px;
}

.filter-group label {
font-size: 11px;
font-weight: 500;
color: var(–text-muted);
text-transform: uppercase;
letter-spacing: 0.8px;
font-family: ‘IBM Plex Mono’, monospace;
}

.filter-group input, .filter-group select {
background: var(–surface);
border: 1px solid var(–border);
color: var(–text);
padding: 7px 12px;
border-radius: 6px;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 13px;
outline: none;
transition: border-color 0.15s, box-shadow 0.15s;
min-width: 170px;
}

.filter-group input:focus, .filter-group select:focus {
border-color: var(–accent);
box-shadow: 0 0 0 3px rgba(0,212,170,0.12);
}

.filter-group input[type=“datetime-local”] { min-width: 200px; }

.mode-tabs {
display: flex;
background: var(–surface);
border: 1px solid var(–border);
border-radius: 7px;
overflow: hidden;
}

.mode-tab {
padding: 7px 18px;
cursor: pointer;
font-size: 12px;
font-weight: 500;
color: var(–text-muted);
transition: all 0.15s;
border: none;
background: none;
font-family: ‘IBM Plex Sans’, sans-serif;
}

.mode-tab.active {
background: var(–accent);
color: #000;
font-weight: 600;
}

.btn {
padding: 8px 20px;
border-radius: 6px;
border: none;
cursor: pointer;
font-size: 13px;
font-weight: 500;
font-family: ‘IBM Plex Sans’, sans-serif;
transition: all 0.15s;
}

.btn-primary {
background: var(–accent);
color: #000;
}
.btn-primary:hover { background: #00f0c0; }

.btn-ghost {
background: transparent;
color: var(–text-muted);
border: 1px solid var(–border);
}
.btn-ghost:hover { border-color: var(–text-muted); color: var(–text); }

.filter-inputs { display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap; }
.filter-inputs.hidden { display: none; }

/* ── STATS BAR ── */
.stats-bar {
padding: 10px 28px;
display: flex;
gap: 24px;
align-items: center;
border-bottom: 1px solid var(–border);
background: var(–bg);
}

.stat {
display: flex;
align-items: baseline;
gap: 6px;
}

.stat-val {
font-family: ‘IBM Plex Mono’, monospace;
font-size: 20px;
font-weight: 600;
color: var(–accent);
}

.stat-label {
font-size: 11px;
color: var(–text-muted);
text-transform: uppercase;
letter-spacing: 0.5px;
}

.stat-sep { color: var(–border); font-size: 18px; }

/* ── TABLE CONTAINER ── */
.table-wrap {
overflow: auto;
max-height: calc(100vh - 220px);
padding: 0 28px 28px;
}

table {
width: 100%;
border-collapse: collapse;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 13px;
margin-top: 16px;
}

thead {
position: sticky;
top: 0;
z-index: 10;
}

th {
background: var(–surface2);
color: var(–text-muted);
font-size: 11px;
font-weight: 500;
text-transform: uppercase;
letter-spacing: 0.8px;
padding: 10px 14px;
text-align: left;
border-bottom: 1px solid var(–border);
white-space: nowrap;
cursor: pointer;
user-select: none;
transition: color 0.15s;
}

th:hover { color: var(–text); }
th.sorted { color: var(–accent); }
th .sort-icon { margin-left: 4px; opacity: 0.5; }
th.sorted .sort-icon { opacity: 1; }

tbody tr {
border-bottom: 1px solid rgba(48,54,61,0.4);
transition: background 0.1s;
}

tbody tr:nth-child(even) { background: var(–row-even); }
tbody tr:nth-child(odd) { background: var(–row-odd); }
tbody tr:hover { background: var(–row-hover); }

tbody tr.highlight {
background: var(–match) !important;
border-left: 3px solid var(–match-border);
}

td {
padding: 9px 14px;
color: var(–text);
white-space: nowrap;
border: none;
}

td.name-col {
color: var(–text);
font-weight: 500;
max-width: 200px;
overflow: hidden;
text-overflow: ellipsis;
}

td.date-col { color: #79c0ff; }
td.time-col { color: #d2a8ff; }
td.duration-col { color: var(–accent2); font-weight: 500; }
td.number-col { color: var(–text-muted); text-align: right; }

td.empty { color: var(–text-dim); font-style: italic; }

/* no results */
.no-results {
text-align: center;
padding: 60px 20px;
color: var(–text-muted);
}
.no-results .icon { font-size: 36px; margin-bottom: 12px; }
.no-results h3 { font-size: 16px; margin-bottom: 6px; color: var(–text); }

/* ── PASTE AREA ── */
.data-section {
padding: 20px 28px;
border-bottom: 1px solid var(–border);
background: var(–surface2);
}

.data-section label {
display: block;
font-size: 11px;
font-weight: 500;
color: var(–text-muted);
text-transform: uppercase;
letter-spacing: 0.8px;
font-family: ‘IBM Plex Mono’, monospace;
margin-bottom: 8px;
}

.data-row {
display: flex;
gap: 10px;
align-items: flex-start;
}

textarea {
flex: 1;
background: var(–surface);
border: 1px solid var(–border);
color: var(–text);
padding: 10px 14px;
border-radius: 6px;
font-family: ‘IBM Plex Mono’, monospace;
font-size: 12px;
height: 80px;
resize: vertical;
outline: none;
transition: border-color 0.15s;
}

textarea:focus { border-color: var(–accent); }

.hint {
font-size: 11px;
color: var(–text-dim);
margin-top: 6px;
font-family: ‘IBM Plex Mono’, monospace;
}

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: var(–bg); }
::-webkit-scrollbar-thumb { background: var(–border); border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(–text-dim); }

/* ── DURATION BADGE ── */
.dur-badge {
display: inline-block;
padding: 2px 8px;
border-radius: 4px;
background: rgba(255,107,53,0.15);
color: var(–accent2);
border: 1px solid rgba(255,107,53,0.3);
font-size: 12px;
}

@media (max-width: 700px) {
header, .filter-panel, .stats-bar, .table-wrap, .data-section { padding-left: 14px; padding-right: 14px; }
.filter-panel { gap: 10px; }
}
</style>

</head>
<body>

<header>
  <div>
    <div class="logo">SQL<span>/</span>Report</div>
    <div class="subtitle">Интерактивен филтър по дата и час</div>
  </div>
  <div class="header-right">
    <span class="badge" id="totalBadge">0 реда</span>
  </div>
</header>

<!-- DATA INPUT -->

<div class="data-section">
  <label>📋 Поставете данните (pipe-separated: Name|Date|StartDateTime|EndDate|EndTime|Duration|Number)</label>
  <div class="data-row">
    <textarea id="rawData" placeholder="Name|2026-01-27|2026-01-27 22:30:20.0|2026-01-28| 01:30:21.0|03:02:01|8140
Name2|2026-01-27|2026-01-27 08:00:00.0|2026-01-27| 10:30:00.0|02:30:00|5200
..."></textarea>
    <div>
      <button class="btn btn-primary" onclick="loadData()">▶ Зареди</button>
      <br><br>
      <button class="btn btn-ghost" onclick="loadSample()">Примерни</button>
    </div>
  </div>
  <div class="hint">Формат: Name | Дата | Start DateTime | End Date | End Time | Duration | Number — всеки ред на нов ред</div>
</div>

<!-- FILTERS -->

<div class="filter-panel">
  <div class="filter-group">
    <label>Режим на филтриране</label>
    <div class="mode-tabs">
      <button class="mode-tab active" onclick="setMode('datetime')" id="tab-datetime">Дата + Час</button>
      <button class="mode-tab" onclick="setMode('range')" id="tab-range">Диапазон</button>
      <button class="mode-tab" onclick="setMode('date')" id="tab-date">Само дата</button>
    </div>
  </div>

  <!-- DateTime mode -->

  <div class="filter-inputs" id="inputs-datetime">
    <div class="filter-group">
      <label>Начало (от)</label>
      <input type="datetime-local" id="dt-from" step="1">
    </div>
  </div>

  <!-- Range mode -->

  <div class="filter-inputs hidden" id="inputs-range">
    <div class="filter-group">
      <label>От</label>
      <input type="datetime-local" id="range-from" step="1">
    </div>
    <div class="filter-group">
      <label>До</label>
      <input type="datetime-local" id="range-to" step="1">
    </div>
  </div>

  <!-- Date-only mode -->

  <div class="filter-inputs hidden" id="inputs-date">
    <div class="filter-group">
      <label>Дата</label>
      <input type="date" id="date-only">
    </div>
  </div>

  <div class="filter-group">
    <label>&nbsp;</label>
    <div style="display:flex;gap:8px">
      <button class="btn btn-primary" onclick="applyFilter()">🔍 Филтрирай</button>
      <button class="btn btn-ghost" onclick="clearFilter()">✕ Изчисти</button>
    </div>
  </div>

  <div class="filter-group" style="margin-left:auto">
    <label>Търсене по име</label>
    <input type="text" id="searchName" placeholder="Въведи текст..." oninput="applyFilter()" style="min-width:180px;font-family:'IBM Plex Sans',sans-serif">
  </div>
</div>

<!-- STATS -->

<div class="stats-bar">
  <div class="stat">
    <span class="stat-val" id="statAll">0</span>
    <span class="stat-label">Общо реда</span>
  </div>
  <span class="stat-sep">|</span>
  <div class="stat">
    <span class="stat-val" id="statFiltered">0</span>
    <span class="stat-label">Показани</span>
  </div>
  <span class="stat-sep">|</span>
  <div class="stat">
    <span class="stat-val" id="statEmpty">0</span>
    <span class="stat-label">Без час</span>
  </div>
  <span class="stat-sep">|</span>
  <div class="stat" id="statDurGroup" style="display:none">
    <span class="stat-val" id="statDur">—</span>
    <span class="stat-label">Общо времетраене</span>
  </div>
</div>

<!-- TABLE -->

<div class="table-wrap">
  <div id="tableContainer">
    <div class="no-results">
      <div class="icon">📂</div>
      <h3>Няма заредени данни</h3>
      <p>Поставете данни по-горе и натиснете "Зареди"</p>
    </div>
  </div>
</div>

<script>
// ─────────────────────────────────────────────
//  State
// ─────────────────────────────────────────────
let allRows = [];
let currentMode = 'datetime';
let sortCol = null, sortDir = 1;

// ─────────────────────────────────────────────
//  Mode switching
// ─────────────────────────────────────────────
function setMode(mode) {
  currentMode = mode;
  ['datetime','range','date'].forEach(m => {
    document.getElementById('inputs-' + m).classList.toggle('hidden', m !== mode);
    document.getElementById('tab-' + m).classList.toggle('active', m === mode);
  });
}

// ─────────────────────────────────────────────
//  Parse helpers
// ─────────────────────────────────────────────
function parseDateTime(datePart, timePart) {
  // datePart: "2026-01-27", timePart: " 22:30:20.0" or "22:30:20.0"
  if (!datePart || !datePart.trim()) return null;
  const d = datePart.trim();
  const t = timePart ? timePart.trim().split('.')[0] : '';
  if (!t) return new Date(d + 'T00:00:00');
  return new Date(d + 'T' + t);
}

function parseDuration(str) {
  if (!str || !str.trim()) return null;
  const parts = str.trim().split(':');
  if (parts.length < 2) return null;
  return parseInt(parts[0]) * 3600 + parseInt(parts[1]) * 60 + parseInt(parts[2] || '0');
}

function formatDurSecs(s) {
  if (s === null || isNaN(s)) return '—';
  const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
  return [h, m, sec].map(x => String(x).padStart(2,'0')).join(':');
}

function parseLine(line) {
  if (!line.trim()) return null;
  const parts = line.split('|');
  // Expected: Name | Date | StartDateTime | EndDate | EndTime | Duration | Number
  const name     = parts[0] || '';
  const date     = parts[1] || '';
  const startDT  = parts[2] || '';  // "2026-01-27 22:30:20.0"
  const endDate  = parts[3] || '';
  const endTime  = parts[4] || '';
  const duration = parts[5] || '';
  const number   = parts[6] || '';

  // Parse start: split date and time from startDT
  let startObj = null;
  if (startDT.trim()) {
    const sp = startDT.trim().split(' ');
    const sd = sp[0];
    const st = sp[1] ? sp[1].split('.')[0] : '00:00:00';
    startObj = new Date(sd + 'T' + st);
  } else if (date.trim()) {
    startObj = new Date(date.trim() + 'T00:00:00');
  }

  // Parse end
  let endObj = null;
  if (endDate.trim() && endTime.trim()) {
    const et = endTime.trim().split('.')[0];
    endObj = new Date(endDate.trim() + 'T' + et);
  }

  return {
    name,
    date: date.trim(),
    startDT: startDT.trim(),
    endDate: endDate.trim(),
    endTime: endTime.trim(),
    duration: duration.trim(),
    number: number.trim(),
    startObj,
    endObj,
    durationSecs: parseDuration(duration)
  };
}

// ─────────────────────────────────────────────
//  Load data
// ─────────────────────────────────────────────
function loadData() {
  const raw = document.getElementById('rawData').value.trim();
  if (!raw) return;
  const lines = raw.split('\n');
  allRows = lines.map(parseLine).filter(Boolean);
  document.getElementById('totalBadge').textContent = allRows.length + ' реда';
  applyFilter();
}

function loadSample() {
  const sample = `Иван Иванов|2026-01-27|2026-01-27 08:00:00.0|2026-01-27| 10:30:00.0|02:30:00|5200
Мария Петрова|2026-01-27|2026-01-27 22:30:20.0|2026-01-28| 01:30:21.0|03:00:01|8140
Георги Стоянов|2026-01-27|2026-01-27 09:15:00.0|2026-01-27| 11:00:00.0|01:45:00|3200
Анна Димитрова|2026-01-27||2026-01-27| |00:00:00|0
Петър Николов|2026-01-28|2026-01-28 06:00:00.0|2026-01-28| 14:00:00.0|08:00:00|12000
Елена Попова|2026-01-28|2026-01-28 22:00:00.0|2026-01-29| 02:30:00.0|04:30:00|9800
Христо Василев|2026-01-29|2026-01-29 07:30:00.0|2026-01-29| 09:00:00.0|01:30:00|2900
Ния Тодорова|2026-01-27|2026-01-27 14:00:00.0|2026-01-27| 18:45:00.0|04:45:00|6700
Борис Лазаров|2026-01-28|2026-01-28 10:00:00.0|2026-01-28| 12:00:00.0|02:00:00|4100
Светла Колева|2026-01-29|2026-01-29 23:00:00.0|2026-01-30| 01:00:00.0|02:00:00|3900`;
  document.getElementById('rawData').value = sample;
  loadData();
}

// ─────────────────────────────────────────────
//  Filter logic
// ─────────────────────────────────────────────
function applyFilter() {
  const nameQ = document.getElementById('searchName').value.toLowerCase();

  let fromDT = null, toDT = null;
  if (currentMode === 'datetime') {
    const v = document.getElementById('dt-from').value;
    if (v) fromDT = new Date(v);
  } else if (currentMode === 'range') {
    const vf = document.getElementById('range-from').value;
    const vt = document.getElementById('range-to').value;
    if (vf) fromDT = new Date(vf);
    if (vt) toDT = new Date(vt);
  } else if (currentMode === 'date') {
    const v = document.getElementById('date-only').value;
    if (v) {
      fromDT = new Date(v + 'T00:00:00');
      toDT   = new Date(v + 'T23:59:59');
    }
  }

  const filtered = allRows.filter(row => {
    // Name search
    if (nameQ && !row.name.toLowerCase().includes(nameQ)) return false;

    // No date filter → show all
    if (!fromDT && !toDT) return true;

    // Row must have start (and optionally end) to filter
    const s = row.startObj;
    const e = row.endObj;

    if (!s && !e) return false; // no timestamps → exclude when filtering

    if (currentMode === 'datetime') {
      // Show rows whose interval overlaps or starts at/after fromDT
      // We show rows where start >= fromDT OR (start < fromDT AND end >= fromDT)
      if (!fromDT) return true;
      if (s && s >= fromDT) return true;
      if (s && e && s < fromDT && e >= fromDT) return true;
      return false;
    } else {
      // Range / date-only: row's start-end interval must overlap [fromDT, toDT]
      const f = fromDT || new Date(0);
      const t = toDT || new Date(8640000000000000);
      // Overlap: row_start <= range_end AND row_end >= range_start
      const rowStart = s || f;
      const rowEnd   = e || (s ? new Date(s.getTime() + 86400000) : t);
      return rowStart <= t && rowEnd >= f;
    }
  });

  // Sort
  let sorted = [...filtered];
  if (sortCol !== null) {
    sorted.sort((a, b) => {
      const va = getSortVal(a, sortCol);
      const vb = getSortVal(b, sortCol);
      if (va === vb) return 0;
      if (va === null || va === '') return 1;
      if (vb === null || vb === '') return -1;
      return va < vb ? -sortDir : sortDir;
    });
  }

  renderTable(sorted);
  updateStats(filtered);
}

function getSortVal(row, col) {
  switch(col) {
    case 0: return row.name;
    case 1: return row.startObj ? row.startObj.getTime() : null;
    case 2: return row.endObj ? row.endObj.getTime() : null;
    case 3: return row.durationSecs;
    case 4: return parseInt(row.number) || 0;
    default: return null;
  }
}

function clearFilter() {
  document.getElementById('dt-from').value = '';
  document.getElementById('range-from').value = '';
  document.getElementById('range-to').value = '';
  document.getElementById('date-only').value = '';
  document.getElementById('searchName').value = '';
  applyFilter();
}

// ─────────────────────────────────────────────
//  Render
// ─────────────────────────────────────────────
function renderTable(rows) {
  const container = document.getElementById('tableContainer');

  if (rows.length === 0) {
    container.innerHTML = `<div class="no-results">
      <div class="icon">🔍</div>
      <h3>Няма намерени редове</h3>
      <p>Опитайте с различен диапазон или изчистете филтъра</p>
    </div>`;
    return;
  }

  const cols = [
    { label: 'Име', idx: 0 },
    { label: 'Начало', idx: 1 },
    { label: 'Край', idx: 2 },
    { label: 'Времетраене', idx: 3 },
    { label: 'Номер', idx: 4 },
  ];

  let html = `<table><thead><tr>`;
  cols.forEach(c => {
    const sorted = sortCol === c.idx;
    const icon = sorted ? (sortDir === 1 ? '↑' : '↓') : '⇅';
    html += `<th class="${sorted ? 'sorted' : ''}" onclick="toggleSort(${c.idx})">${c.label} <span class="sort-icon">${icon}</span></th>`;
  });
  html += `</tr></thead><tbody>`;

  for (const row of rows) {
    const startStr = row.startDT || '';
    const endStr   = (row.endDate && row.endTime)
                       ? row.endDate + ' ' + row.endTime.trim()
                       : (row.endDate || '');

    const nameCell = `<td class="name-col" title="${esc(row.name)}">${esc(row.name) || '<span class="empty">—</span>'}</td>`;
    const startCell = startStr
      ? `<td class="date-col">${esc(startStr)}</td>`
      : `<td class="empty">—</td>`;
    const endCell = endStr
      ? `<td class="time-col">${esc(endStr)}</td>`
      : `<td class="empty">—</td>`;
    const durCell = row.duration
      ? `<td class="duration-col"><span class="dur-badge">${esc(row.duration)}</span></td>`
      : `<td class="empty">—</td>`;
    const numCell = row.number
      ? `<td class="number-col">${esc(row.number)}</td>`
      : `<td class="empty">—</td>`;

    html += `<tr>${nameCell}${startCell}${endCell}${durCell}${numCell}</tr>`;
  }

  html += `</tbody></table>`;
  container.innerHTML = html;
}

function esc(s) {
  if (!s) return '';
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ─────────────────────────────────────────────
//  Sort
// ─────────────────────────────────────────────
function toggleSort(colIdx) {
  if (sortCol === colIdx) {
    sortDir *= -1;
  } else {
    sortCol = colIdx;
    sortDir = 1;
  }
  applyFilter();
}

// ─────────────────────────────────────────────
//  Stats
// ─────────────────────────────────────────────
function updateStats(filtered) {
  const withoutTime = filtered.filter(r => !r.startObj).length;
  document.getElementById('statAll').textContent = allRows.length;
  document.getElementById('statFiltered').textContent = filtered.length;
  document.getElementById('statEmpty').textContent = withoutTime;

  const totalSecs = filtered.reduce((sum, r) => sum + (r.durationSecs || 0), 0);
  if (totalSecs > 0) {
    document.getElementById('statDur').textContent = formatDurSecs(totalSecs);
    document.getElementById('statDurGroup').style.display = '';
  } else {
    document.getElementById('statDurGroup').style.display = 'none';
  }
}
</script>

