#!/usr/bin/env python3
# csv_to_html_anomalies_virtual_chart.py
#
# Single self-contained HTML (email-friendly).
# - Virtualized table (fast for 15k+ rows)
# - Default view: ONLY anomaly rows
# - If you filter/search by a JOB (or click a row), it shows that job’s rows (including non-anomalies)
# - Trend chart for selected job: ELAPSED + THROUGHPUT over last 31 BATCH.DATE
#
# Usage:
#   python3 csv_to_html_anomalies_virtual_chart.py /path/to/file.csv [output.html]

import csv
import os
import sys
import html
import json
from datetime import datetime


def read_csv(path: str):
    with open(path, "r", newline="", encoding="utf-8") as f:
        sample = f.read(4096)
        f.seek(0)
        try:
            dialect = csv.Sniffer().sniff(sample, delimiters=",;\t|")
        except Exception:
            dialect = csv.excel
        reader = csv.reader(f, dialect)
        rows = list(reader)
    if not rows:
        return [], []
    return rows[0], rows[1:]


def esc(s):
    return html.escape("" if s is None else str(s))


def build_html(title: str, header, rows):
    now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    header_js = json.dumps(header, ensure_ascii=False)
    data_js = json.dumps(rows, ensure_ascii=False)

    ths = "\n".join(f"<th data-idx='{i}' title='{esc(h)}'>{esc(h)}</th>" for i, h in enumerate(header))
    col_count = len(header)

    return f"""<!doctype html>
<html lang="bg">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{esc(title)}</title>
  <style>
    body {{ font-family: Arial, sans-serif; margin: 16px; color:#111; }}
    .topbar {{
      display:flex; gap:12px; align-items:center; flex-wrap:wrap;
      margin-bottom:10px;
    }}
    h2 {{ margin:0; font-size:18px; }}
    input[type="search"] {{ padding:8px 10px; min-width:320px; }}
    .meta {{ color:#666; font-size: 12px; }}
    .hint {{ font-size:12px; color:#777; margin-bottom:10px; line-height:1.35; }}

    .controls {{
      display:flex; gap:12px; flex-wrap:wrap; align-items:center;
      margin: 6px 0 10px 0;
      padding: 10px 12px;
      border: 1px solid #eee;
      border-radius: 10px;
      background: #fafafa;
    }}
    .controls label {{ font-size: 13px; color:#222; display:flex; gap:8px; align-items:center; }}
    .pill {{
      font-size: 12px; padding: 4px 8px; border-radius: 999px; border:1px solid #e5e5e5;
      background:#fff; color:#333;
    }}
    .pill strong {{ font-weight:700; }}
    .btn {{
      border:1px solid #ddd; background:#fff; padding:6px 10px; border-radius:8px;
      cursor:pointer; font-size: 13px;
    }}
