    }}

    /* Row severity highlight */
    tr[data-sev="critical"] td {{ background: #ffecec; }}
    tr[data-sev="warning"]  td {{ background: #fff3e0; }}
    tr[data-sev="info"]     td {{ background: #eef6ff; }}

    .badge {{
      display:inline-flex; align-items:center; gap:6px;
      border-radius: 999px; padding: 2px 8px;
      font-size: 12px; border: 1px solid #ddd; background:#fff;
    }}
    .b-critical {{ border-color:#f2b8b8; }}
    .b-warning  {{ border-color:#f0d3a1; }}
    .b-info     {{ border-color:#b7d7ff; }}
    .dot {{ width:8px; height:8px; border-radius:999px; display:inline-block; }}
    .d-critical {{ background:#d21b1b; }}
