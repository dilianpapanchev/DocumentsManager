            <div class="tl-node" style="background:${i===rc.timeline.length-1?PALETTE.crit:PALETTE.warn};left:6px;top:2px;width:14px;height:14px"></div>
            <div style="padding-left:6px"><span class="num" style="color:var(--text-2);font-size:12px">${t.time}</span>
