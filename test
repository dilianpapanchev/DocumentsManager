    .kpi {{
      display:flex; gap:10px; flex-wrap:wrap; align-items:center;
    }}
    .kpi .box {{
      border:1px solid #eee; background:#fff; border-radius:10px; padding:8px 10px;
      font-size: 13px;
    }}
    .k {{ color:#666; font-size:12px; }}
    .v {{ font-weight:700; }}

    .panel {{
      border: 1px solid #eee;
      border-radius: 12px;
      background: #fff;
      padding: 12px;
      margin: 0 0 10px 0;
    }}
    .panel-title {{ font-size: 13px; font-weight:700; margin: 0 0 8px 0; color:#222; }}
    .panel-sub {{ font-size: 12px; color:#666; margin:0 0 8px 0; }}

    .chart-wrap {{
      display:flex; gap:12px; flex-wrap:wrap; align-items:flex-start;
    }}
    #chart {{
      width: 980px;
      max-width: 100%;
      height: 280px;
      border:1px solid #eee;
      border-radius: 12px;
      background: #fafafa;
    }}
    .chart-side {{
      min-width: 260px;
      max-width: 100%;
      flex: 1;
    }}
    .chart-side .line {{
      font-size: 12px; color:#444; margin: 4px 0;
      word-break: break-word;
    }}
    .chart-side .line b {{ color:#111; }}

    .tooltip {{
      position: fixed;
      pointer-events: none;
      background: rgba(17,17,17,0.92);
      color: #fff;
      font-size: 12px;
