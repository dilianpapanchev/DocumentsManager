  svgw.appendChild(svg("path",{d:arcStroke(cx,cy,R,start,end),fill:"none",stroke:PALETTE.bg3,"stroke-width":13,"stroke-linecap":"round"}));
  const col=frac>=0.9?PALETTE.ok:frac>=0.75?PALETTE.warn:frac>=0.6?PALETTE.high:PALETTE.crit;
  const fg=svg("path",{d:arcStroke(cx,cy,R,start,start+(end-start)*frac),fill:"none",stroke:col,"stroke-width":13,"stroke-linecap":"round"});
  svgw.appendChild(fg);
  // ticks
  for(let i=0;i<=10;i++){const a=start+(end-start)*i/10;const r1=R-10,r2=R-4;
    svgw.appendChild(svg("line",{x1:cx+r1*Math.cos(a),y1:cy+r1*Math.sin(a),x2:cx+r2*Math.cos(a),y2:cy+r2*Math.sin(a),
      stroke:PALETTE.border,"stroke-width":1.5}));}
  wrap.insertBefore(svgw,wrap.firstChild);
  if(STATE.animate){const len=fg.getTotalLength();fg.style.strokeDasharray=len;fg.style.strokeDashoffset=len;
    fg.style.transition="stroke-dashoffset 1.3s cubic-bezier(.2,.8,.2,1)";requestAnimationFrame(()=>fg.style.strokeDashoffset=0);}
}

