function drawCartesian(host,cfg){
  const W=host.clientWidth,H=host.clientHeight;if(W<20||H<20)return;
  const ls=LS();const hid=hiddenOf(cfg);
  const series=cfg.series.filter(s=>!hid.has(s.name));
  const ML=(cfg.dual?54:46),MR=(cfg.dual?48:14),MT=cfg.series.length>1?26:14,MB=28;
  const pw=W-ML-MR,ph=H-MT-MB,n=cfg.x.length,t=cfg.type,colors=pal();
