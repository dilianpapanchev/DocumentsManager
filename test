color: var(–text-bright);
}

.filter-row {
display: flex;
gap: 16px;
flex-wrap: wrap;
align-items: flex-end;
}

.field {
display: flex;
flex-direction: column;
gap: 6px;
}

.field label {
font-size: 0.72rem;
color: var(–text-dim);
text-transform: uppercase;
letter-spacing: 0.08em;
}

.field input {
background: var(–surface2);
border: 1px solid var(–border);
border-radius: 6px;
color: var(–text-bright);
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.85rem;
padding: 9px 12px;
outline: none;
transition: border-color 0.15s;
min-width: 180px;
}

.field input:focus {
border-color: var(–accent);
}

/* Hide default calendar icon and style consistently */
input[type=“date”]::-webkit-calendar-picker-indicator {
filter: invert(0.5) sepia(1) saturate(3) hue-rotate(190deg);
cursor: pointer;
}

.field input.invalid-input {
border-color: var(–invalid) !important;
}

.field .hint {
font-size: 0.68rem;
color: var(–text-dim);
margin-top: 3px;
}

.field .hint.error {
color: var(–invalid);
}

.btn {
padding: 9px 22px;
border-radius: 6px;
border: none;
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.82rem;
font-weight: 600;
cursor: pointer;
transition: all 0.15s;
letter-spacing: 0.04em;
}

.btn-primary {
background: var(–accent);
color: #fff;
}

.btn-primary:hover {
background: #5590ff;
transform: translateY(-1px);
}

.btn-reset {
background: transparent;
border: 1px solid var(–border);
color: var(–text-dim);
}

.btn-reset:hover {
border-color: var(–warn);
color: var(–warn);
}

.results-header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 12px;
padding: 0 2px;
}

.results-count {
font-size: 0.78rem;
color: var(–text-dim);
}

.results-count span {
color: var(–accent2);
font-weight: 700;
}

.table-wrap {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 12px;
overflow: hidden;
overflow-x: auto;
}

table {
width: 100%;
border-collapse: collapse;
font-size: 0.78rem;
}

thead tr {
background: var(–surface2);
border-bottom: 1px solid var(–border);
}

th {
padding: 12px 16px;
text-align: left;
color: var(–text-dim);
font-weight: 600;
text-transform: uppercase;
letter-spacing: 0.08em;
font-size: 0.68rem;
white-space: nowrap;
}

tbody tr {
border-bottom: 1px solid var(–border);
transition: background 0.1s;
}

tbody tr:last-child { border-bottom: none; }

tbody tr:hover { background: rgba(61, 126, 255, 0.05); }

td {
padding: 11px 16px;
color: var(–text);
white-space: nowrap;
}

.td-recid {
color: var(–accent);
font-weight: 600;
}

.td-date { color: var(–text-bright); }

.td-elapsed {
color: var(–accent2);
font-weight: 600;
}

.td-transactions { color: var(–warn); font-weight: 600; }

.badge {
display: inline-flex;
align-items: center;
gap: 4px;
padding: 2px 8px;
border-radius: 4px;
font-size: 0.68rem;
font-weight: 700;
}

.badge-valid { background: rgba(0,212,170,0.12); color: var(–valid); }
.badge-invalid { background: rgba(255,68,102,0.12); color: var(–invalid); }

.empty-state {
text-align: center;
padding: 60px 20px;
color: var(–text-dim);
font-size: 0.85rem;
}

.empty-state .icon { font-size: 2.5rem; margin-bottom: 12px; opacity: 0.4; }

@media (max-width: 600px) {
.filter-row { flex-direction: column; }
.field input { min-width: 100%; }
}
</style>

</head>
