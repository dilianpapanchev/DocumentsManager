function drawHeatmap(host,cfg){
  const W=host.clientWidth,H=host.clientHeight; if(W<20||H<20)return;
  const rows=cfg.rows,cols=cfg.cols,data=cfg.data;const ML=92,MT=8,MB=22;
  const cw=(W-ML-8)/cols.length, ch=(H-MT-MB)/rows.length;
  const max=Math.max(...data.flat());const acc=cvar('--accent');
  let s=`<svg viewBox="0 0 ${W} ${H}" width="${W}" height="${H}">`;
  rows.forEach((r,ri2)=>{s+=`<text x="${ML-8}" y="${(MT+ri2*ch+ch/2+3).toFixed(1)}" text-anchor="end" fill="${cvar('--muted')}" font-size="10.5" font-family="JetBrains Mono">${r}</text>`;});
  const stepC=Math.ceil(cols.length/12);
  cols.forEach((c,ci)=>{if(ci%stepC===0)s+=`<text x="${(ML+ci*cw+cw/2).toFixed(1)}" y="${H-7}" text-anchor="middle" fill="${cvar('--axis')}" font-size="9" font-family="JetBrains Mono">${c}</text>`;});
  rows.forEach((r,ri2)=>cols.forEach((c,ci)=>{const v=data[ri2][ci];const inten=max?v/max:0;const x=ML+ci*cw,y=MT+ri2*ch;s+=`<rect class="hm" data-r="${ri2}" data-c="${ci}" x="${(x+1).toFixed(1)}" y="${(y+1).toFixed(1)}" width="${(cw-2).toFixed(1)}" height="${(ch-2).toFixed(1)}" rx="2.5" fill="${acc}" opacity="0" data-op="${(0.08+inten*0.92).toFixed(2)}"/>`;}));
  s+=`</svg>`;host.innerHTML=s;
  host.querySelectorAll('.hm').forEach((rect,i)=>{const op=rect.dataset.op;setTimeout(()=>{rect.style.transition='opacity .4s';rect.style.opacity=op;},i*4);
    const ri2=+rect.dataset.r,ci=+rect.dataset.c;
    rect.addEventListener('mousemove',e=>showTip(e,`<div class="tt-h">${rows[ri2]} · ${cols[ci]}</div><div class="tt-r"><b>${fmt(data[ri2][ci])}</b> ${cfg.unit||''}</div>`));
    rect.addEventListener('mouseleave',hideTip);
    rect.addEventListener('click',()=>toast(`${rows[ri2]} · ${cols[ci]}: <b>${fmt(data[ri2][ci])}</b>`));
  });
}

