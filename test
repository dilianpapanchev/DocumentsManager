            started: parseDateTime(cols[2]),
            stopped: parseDateTime(cols[3]),
            isValid: true
        };

        if (
            !record.started ||
            !record.stopped ||
            isNaN(record.started.getTime()) ||
            isNaN(record.stopped.getTime())
        ) {
            record.isValid = false;
        }

        records.push(record);
