AA.ARCHIVE.SERVICE|2026-04-21|2026-04-21 01:00:56.0|2026-04-21 20:00:18.0|18:59:22|
AA.ARCHIVE.SERVICE|2026-04-22|2026-04-22 01:00:12.0|||
AA.ARR.PRODUCT.TRACKER|2026-03-02|2026-03-01 06:57:52.0|2026-03-01 08:58:54.0|02:01:02|1810933
AA.ARR.PRODUCT.TRACKER|2026-03-02|2026-03-01 06:05:57.0|2026-03-01 06:40:38.0|00:34:41|2008308
AA.ARR.PRODUCT.TRACKER|2026-03-19|2026-03-19 19:17:07.0|2026-03-19 19:32:41.0|00:15:34|1980725
AA.ARR.PRODUCT.TRACKER|2026-03-19|2026-03-19 18:37:00.0|2026-03-19 19:08:07.0|00:31:07|1237649
AA.ARR.PRODUCT.TRACKER|2026-03-27|2026-03-27 03:57:41.0|2026-03-27 06:31:31.0|02:33:50|1953389
AA.ARR.PRODUCT.TRACKER|2026-03-27|2026-03-27 03:14:34.0|2026-03-27 03:27:49.0|00:13:15|1519850`;
  loadData();
}

// ── Filter ─────────────────────────────────────────────
function applyFilter() {
  const nameQ = document.getElementById('searchName').value.toLowerCase();

  let fromDT = null, toDT = null, pointDT = null;

  if (mode === 'datetime') {
    const v = document.getElementById('dt-point').value;
    if (v) pointDT = new Date(v);
  } else if (mode === 'range') {
    const vf = document.getElementById('r-from').value;
    const vt = document.getElementById('r-to').value;
    if (vf) fromDT = new Date(vf);
    if (vt) toDT   = new Date(vt);
  } else if (mode === 'date') {
    const v = document.getElementById('d-only').value;
    if (v) {
      fromDT = new Date(v + 'T00:00:00');
      toDT   = new Date(v + 'T23:59:59');
    }
  }

  const noFilter = !pointDT && !fromDT && !toDT;

  const filtered = allRows.filter(row => {
    // RECID text search
    if (nameQ && !row.recid.toLowerCase().includes(nameQ)) return false;
    // No time filter → show all
    if (noFilter) return true;

    const s = row.startObj;
    const e = row.stopObj;

    if (mode === 'datetime') {
      // Row is "active" at pointDT if: started <= point AND (stopped >= point OR no stopped)
      if (!s) return false;
      if (e) return s <= pointDT && pointDT <= e;
      return s <= pointDT; // still running / no stop recorded
    } else {
      // Range overlap: row_start <= range_end  AND  row_end >= range_start
      const f  = fromDT || new Date(0);
      const t  = toDT   || new Date(8640000000000000);
      const rs = s || f;
      const re = e || (s ? new Date(s.getTime() + 86400000) : t);
      return rs <= t && re >= f;
    }
  });

  // Sort
  let sorted = [...filtered];
  if (sortCol !== null) {
    sorted.sort((a, b) => {
      const va = sv(a, sortCol), vb = sv(b, sortCol);
      if (va === vb) return 0;
      if (va === null || va === '') return 1;
      if (vb === null || vb === '') return -1;
      return va < vb ? -sortDir : sortDir;
    });
  }

  renderTable(sorted);
  updateStats(filtered);
}

function sv(row, col) {
  switch(col) {
    case 0: return row.recid;
    case 1: return row.date;
    case 2: return row.startObj ? row.startObj.getTime() : null;
    case 3: return row.stopObj  ? row.stopObj.getTime()  : null;
    case 4: return row.elapsedSecs;
    case 5: return parseInt(row.transactions) || 0;
    default: return null;
  }
}

function clearFilter() {
  document.getElementById('dt-point').value = '';
  document.getElementById('r-from').value   = '';
  document.getElementById('r-to').value     = '';
  document.getElementById('d-only').value   = '';
  document.getElementById('searchName').value = '';
  applyFilter();
}

// ── Render table ───────────────────────────────────────
const COLS = [
  { label: 'RECID',        cls: 'c-recid'   },
  { label: 'DATE',         cls: 'c-date'    },
  { label: 'STARTED',      cls: 'c-start'   },
  { label: 'STOPPED',      cls: 'c-stop'    },
  { label: 'ELAPSED',      cls: 'c-elapsed' },
  { label: 'TRANSACTIONS', cls: 'c-trx'     },
];

function renderTable(rows) {
  const cont = document.getElementById('tCont');
  if (!rows.length) {
    cont.innerHTML = `<div class="no-results">
      <div class="icon">🔍</div>
      <h3>Няма намерени редове</h3>
      <p>Опитайте с различни параметри или изчистете филтъра</p>
    </div>`;
    return;
  }

  let h = '<table><thead><tr>';
  COLS.forEach((c, i) => {
    const s = sortCol === i;
    const icon = s ? (sortDir === 1 ? '↑' : '↓') : '⇅';
    h += `<th class="${s ? 'sorted' : ''}" onclick="toggleSort(${i})">${c.label}<span class="si">${icon}</span></th>`;
  });
  h += '</tr></thead><tbody>';

  for (const r of rows) {
    h += '<tr>';
    // RECID
    h += `<td class="c-recid" title="${esc(r.recid)}">${esc(r.recid) || '<span style="color:var(--text-dim)">—</span>'}</td>`;
    // DATE
    h += r.date ? `<td class="c-date">${esc(r.date)}</td>` : `<td class="empty">—</td>`;
    // STARTED
    h += r.startedRaw ? `<td class="c-start">${esc(r.startedRaw)}</td>` : `<td class="empty">—</td>`;
    // STOPPED
    h += r.stoppedRaw ? `<td class="c-stop">${esc(r.stoppedRaw)}</td>` : `<td class="empty">—</td>`;
    // ELAPSED
    h += r.elapsed
      ? `<td class="c-elapsed"><span class="dur-badge">${esc(r.elapsed)}</span></td>`
      : `<td class="empty">—</td>`;
    // TRANSACTIONS
    h += r.transactions ? `<td class="c-trx">${esc(r.transactions)}</td>` : `<td class="empty">—</td>`;
    h += '</tr>';
  }
  h += '</tbody></table>';
  cont.innerHTML = h;
}

function esc(s) {
  return String(s)
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;');
}

// ── Sort ───────────────────────────────────────────────
function toggleSort(i) {
  if (sortCol === i) sortDir *= -1;
  else { sortCol = i; sortDir = 1; }
  applyFilter();
}

// ── Stats ──────────────────────────────────────────────
function updateStats(filtered) {
  const noTS = filtered.filter(r => !r.startObj && !r.stopObj).length;
  document.getElementById('sAll').textContent      = allRows.length;
  document.getElementById('sFiltered').textContent = filtered.length;
  document.getElementById('sEmpty').textContent    = noTS;

  const total = filtered.reduce((s, r) => s + (r.elapsedSecs || 0), 0);
  if (total > 0) {
    document.getElementById('sDur').textContent = fmtSecs(total);
    document.getElementById('sDurGroup').style.display = '';
    document.getElementById('durSep').style.display = '';
  } else {
    document.getElementById('sDurGroup').style.display = 'none';
    document.getElementById('durSep').style.display = 'none';
  }
}
</script>

</body>
</html>









