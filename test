    ${field('Размер на шрифта',Math.round(SETTINGS.fontScale*100),80,140,5,'fontScale',v=>v+'%')}
    ${field('Размер на графиките',Math.round(SETTINGS.chartScale*100),70,150,5,'chartScale',v=>v+'%')}
    ${field('Размер на етикетите (metrics)',Math.round(SETTINGS.labelScale*100),80,150,5,'labelScale',v=>v+'%')}
    ${field('Заобляне',Math.round(SETTINGS.radius*100),0,180,10,'radius',v=>v+'%')}
    ${field('Плътност на мрежата',Math.round(SETTINGS.gridOpacity*100),10,100,5,'gridOpacity',v=>v+'%')}
  </div>
  <div class="dr-grp"><h4>Анимации</h4>
    ${toggle('Включени анимации',SETTINGS.anim,'anim')}
    ${field('Скорост на анимациите',Math.round(SETTINGS.animSpeed*100),50,250,10,'animSpeed',v=>(v/100).toFixed(1)+'×')}
  </div>
  <div class="dr-grp"><h4>Изглед</h4>
    ${toggle('Компактен режим',SETTINGS.compact,'compact')}
    ${toggle('Сияние (glow)',SETTINGS.glow,'glow')}
    <div class="field"><div class="fl"><span>Формат на числата</span></div><div class="seg" id="segNum"><button data-num="short" class="${SETTINGS.numFmt==='short'?'on':''}">Кратък (1.2k)</button><button data-num="full" class="${SETTINGS.numFmt==='full'?'on':''}">Пълен (1,234)</button></div></div>
  </div>
  <div class="dr-grp"><button class="btn" id="resetBtn" style="width:100%;justify-content:center">Възстанови по подразбиране</button></div>`;
  b.querySelectorAll('.tsq').forEach(t=>t.onclick=()=>setTheme(t.dataset.t));
  b.querySelectorAll('input[data-set]').forEach(inp=>inp.oninput=()=>{const k=inp.dataset.set;const raw=+inp.value;const val=(k==='fontScale'||k==='chartScale'||k==='labelScale'||k==='radius'||k==='gridOpacity'||k==='animSpeed')?raw/100:raw;SETTINGS[k]=val;const lbl=b.querySelector(`[data-v="${k}"]`);if(lbl){const map={fontScale:v=>Math.round(v*100)+'%',chartScale:v=>Math.round(v*100)+'%',labelScale:v=>Math.round(v*100)+'%',radius:v=>Math.round(v*100)+'%',gridOpacity:v=>Math.round(v*100)+'%',animSpeed:v=>v.toFixed(1)+'×'};lbl.textContent=(map[k]||(x=>x))(val);}applySettings(k);});
  b.querySelectorAll('[data-toggle]').forEach(sw=>sw.onclick=()=>{const k=sw.dataset.toggle;SETTINGS[k]=!SETTINGS[k];sw.classList.toggle('on',SETTINGS[k]);applySettings(k);});
  b.querySelector('#segNum').querySelectorAll('button').forEach(btn=>btn.onclick=()=>{SETTINGS.numFmt=btn.dataset.num;b.querySelectorAll('#segNum button').forEach(x=>x.classList.remove('on'));btn.classList.add('on');});
  b.querySelector('#resetBtn').onclick=()=>{Object.assign(SETTINGS,{fontScale:1,chartScale:1,labelScale:1,anim:true,animSpeed:1,radius:1,gridOpacity:1,compact:false,glow:true,numFmt:'short'});applySettings('all');buildDrawer();toast('Настройките са възстановени');};
}
function applySettings(key){
  const r=document.documentElement;
  r.style.setProperty('--fs',SETTINGS.fontScale);
  r.style.setProperty('--cs',SETTINGS.chartScale);
  r.style.setProperty('--rad',SETTINGS.radius);
  r.style.setProperty('--gridop',SETTINGS.gridOpacity);
  r.style.setProperty('--anim',SETTINGS.anim?1:0);
  document.body.classList.toggle('compact',SETTINGS.compact);
  document.body.classList.toggle('glow',SETTINGS.glow);
  if(['fontScale','chartScale','labelScale','gridOpacity','animSpeed','anim','all'].includes(key)){clearTimeout(window._rs);window._rs=setTimeout(renderActive,180);}
}
document.getElementById('setBtn').onclick=()=>{drawer.classList.add('open');scrim.classList.add('show');scrim.onclick=closeDrawer;};
function closeDrawer(){drawer.classList.remove('open');scrim.classList.remove('show');scrim.onclick=null;}
document.getElementById('drClose').onclick=closeDrawer;

/* ===== CONTROLS ===== */
document.getElementById('langBtn').onclick=()=>{lang=lang==='bg'?'en':'bg';applyLang();};
document.getElementById('burger').onclick=()=>{document.getElementById('sidebar').classList.toggle('open');document.getElementById('sbScrim').classList.toggle('show');};
document.getElementById('sbScrim').onclick=()=>{document.getElementById('sidebar').classList.remove('open');document.getElementById('sbScrim').classList.remove('show');};
document.getElementById('printBtn').onclick=()=>{const prev=active;SECTIONS.forEach(id=>{const s=document.querySelector(`section[data-sec="${id}"]`);s.classList.add('on');Object.keys(charts).forEach(cid=>{if(s.contains(charts[cid].body))renderChart(cid);});});renderOverviewExtras();setTimeout(()=>window.print(),450);setTimeout(()=>document.querySelectorAll('section[data-sec]').forEach(s=>s.classList.toggle('on',s.dataset.sec===prev)),1400);};
document.getElementById('exportBtn').onclick=()=>{const rows=['hour,'+LV.join(',')];HOURS.forEach((h,i)=>rows.push(h+','+LV.map(l=>lvHourly[l][i]).join(',')));const blob=new Blob([rows.join('\n')],{type:'text/csv'});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='log_levels_by_hour.csv';a.click();URL.revokeObjectURL(url);toast(L().exported+' • <b>24</b> '+(lang==='bg'?'реда':'rows'));};
function applyLang(){document.documentElement.lang=lang;document.getElementById('brandsub').textContent=L().brand;document.getElementById('langTxt').textContent=L().lang;buildNav();buildAllSections();activate(active);}
window.addEventListener('resize',()=>{clearTimeout(window._rz);window._rz=setTimeout(renderActive,180);});

/* ===== INIT ===== */
applySettings('all');
buildNav();
buildDrawer();
buildAllSections();
document.getElementById('secPeriod').textContent=L().period;
activate('exec');
</script>
</body>
</html>
