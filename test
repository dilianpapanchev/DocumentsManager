    w.addEventListener('mouseenter',e=>{w.style.transform='scale(1.04)';tipHtml(e);});w.addEventListener('mousemove',tipHtml);w.addEventListener('mouseleave',()=>{w.style.transform='scale(1)';hideTip();});w.addEventListener('click',()=>toast(`${data[i].name}: <b>${fmt(data[i].value)}</b> (${(data[i].value/total*100).toFixed(1)}%)`));});
}
function drawGauge(host,cfg){
