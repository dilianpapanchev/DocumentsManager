const TIP=$("#chartTip");
function showTip(x,y,html){TIP.innerHTML=html;TIP.style.display="block";
  const r=TIP.getBoundingClientRect();let nx=x+14,ny=y-r.height-10;
  if(nx+r.width>innerWidth-8)nx=x-r.width-14; if(ny<8)ny=y+16;
  TIP.style.left=nx+"px";TIP.style.top=ny+"px";}
function hideTip(){TIP.style.display="none";}

/* =========================================================================
   CHART ENGINE — renders into a mount div. Supported types:
   line, area, bar, stackedBar, hbar, donut, gauge
   ========================================================================= */
function catmull(points){/* smooth path through points */
  if(points.length<2)return "";
  let d="M"+points[0][0]+","+points[0][1];
  for(let i=0;i<points.length-1;i++){
    const p0=points[i-1]||points[i],p1=points[i],p2=points[i+1],p3=points[i+2]||p2;
    const c1x=p1[0]+(p2[0]-p0[0])/6,c1y=p1[1]+(p2[1]-p0[1])/6;
    const c2x=p2[0]-(p3[0]-p1[0])/6,c2y=p2[1]-(p3[1]-p1[1])/6;
    d+=`C${c1x},${c1y} ${c2x},${c2y} ${p2[0]},${p2[1]}`;
  }return d;}

function renderChart(mount,cfg){
  mount.innerHTML="";
  const W=Math.max(220,mount.clientWidth||600);
  const Htot=Math.max(140,mount.clientHeight||240);
  const animate=STATE.animate&&!mount.closest(".no-anim");
  const type=cfg.type;
  const series=(cfg.series||[]).filter(s=>!s._off);
  if(!series.length&&type!=="gauge"){mount.appendChild(el("div",{class:"chart-empty"},
    '<svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3v18h18"/><path d="M7 14l3-3 3 3 4-5"/></svg><div>No data to display</div>'));return;}

  const legendH = cfg.showLegend&&type!=="gauge" ? 26 : 0;
  const H=Htot-legendH;
  const root=svg("svg",{viewBox:`0 0 ${W} ${H}`,width:W,height:H,style:"display:block;overflow:visible"});
  mount.appendChild(root);

  if(type==="donut"){drawDonut(root,W,H,series,cfg,animate);}
  else if(type==="gauge"){drawGauge(root,W,H,cfg,animate);}
  else if(type==="hbar"){drawHBar(root,W,H,series,cfg,animate);}
  else {drawXY(root,W,H,series,cfg,animate,mount);}

  if(cfg.showLegend&&type!=="gauge"){
    const lg=el("div",{class:"chart-legend"});
    series.forEach(s=>{const it=el("div",{class:"cl"+(s._off?" off":"")});
      it.appendChild(el("span",{class:"cl-sw",style:"background:"+s.color}));
      it.appendChild(document.createTextNode(s.name));lg.appendChild(it);});
    mount.appendChild(lg);
  }
}

/* ---- shared axis + grid for XY charts ---- */
function drawXY(root,W,H,series,cfg,animate,mount){
  const padL=48,padR=16,padT=14,padB=28;
  const pw=W-padL-padR, ph=H-padT-padB;
  const labels=cfg.labels||series[0].data.map((_,i)=>i);
  const n=labels.length;
  const stacked=cfg.type==="stackedBar";
  let yMax=cfg.yMax;
  if(!yMax){
    if(stacked){yMax=Math.max(...labels.map((_,i)=>series.reduce((s,se)=>s+(se.data[i]||0),0)));}
    else yMax=Math.max(...series.flatMap(s=>s.data));
  }
  yMax=yMax*1.12||1;
  const yMin=0;
  const X=i=> padL + (n<=1?pw/2 : (pw*i/(n-1)));
  const Xb=i=> padL + pw*(i+0.5)/n;                    // band center for bars
  const Y=v=> padT + ph*(1-(v-yMin)/(yMax-yMin));
  const grid=cfg.showGrid!==false;

  /* grid + y labels */
  const gy=svg("g",{}); root.appendChild(gy);
  const steps=4;
  for(let i=0;i<=steps;i++){
    const v=yMin+(yMax-yMin)*i/steps, y=Y(v);
    if(grid)gy.appendChild(svg("line",{x1:padL,y1:y,x2:W-padR,y2:y,stroke:PALETTE.grid,"stroke-width":1}));
    const t=svg("text",{x:padL-8,y:y+4,fill:PALETTE.text3,"font-size":10.5,"text-anchor":"end",
      "font-family":"var(--mono)"});t.textContent=fmtShort(v,cfg.yUnit);gy.appendChild(t);
  }
  /* x labels (thinned) */
  const every=Math.ceil(n/ (W<520?6:12));
  labels.forEach((lb,i)=>{ if(i%every!==0 && i!==n-1)return;
    const x=(cfg.type==="bar"||cfg.type==="stackedBar")?Xb(i):X(i);
    const t=svg("text",{x,y:H-8,fill:PALETTE.text3,"font-size":10,"text-anchor":"middle","font-family":"var(--mono)"});
    t.textContent=String(lb).replace(":00","");gy.appendChild(t);});

  /* ---- BARS ---- */
  if(cfg.type==="bar"||cfg.type==="stackedBar"){
    const band=pw/n, groupPad=band*0.22;
    const inner=band-groupPad*2;
    const bw = stacked? inner : inner/series.length;
    labels.forEach((_,i)=>{
      let accTop=Y(0);
      series.forEach((s,si)=>{
        const v=s.data[i]||0;
        const x = stacked ? padL+groupPad+band*i : padL+groupPad+band*i+bw*si;
        let y,hgt;
        if(stacked){const y2=Y((cumulative(series,i,si))); const y1=Y(cumulative(series,i,si)+v);hgt=y2-y1;y=y1;}
        else {y=Y(v);hgt=Y(0)-y;}
        const rect=svg("rect",{x,y,width:Math.max(1,bw-1),height:Math.max(0,hgt),rx:stacked?0:3,
          fill:s.color,opacity:.92});
        if(animate){rect.style.transformBox="fill-box";rect.style.transformOrigin="bottom";
          rect.style.transform="scaleY(0)";rect.style.transition="transform .6s cubic-bezier(.2,.8,.2,1) "+(i*0.006)+"s";
          requestAnimationFrame(()=>requestAnimationFrame(()=>rect.style.transform="scaleY(1)"));}
        root.appendChild(rect);
        if(cfg.showValues&&!stacked&&series.length<=2){
          const vt=svg("text",{x:x+bw/2,y:y-5,fill:PALETTE.text2,"font-size":9.5,"text-anchor":"middle","font-family":"var(--mono)"});
          vt.textContent=fmtShort(v,cfg.yUnit);root.appendChild(vt);}
      });
    });
  } else {
    /* ---- LINE / AREA ---- */
    series.forEach(s=>{
      const pts=s.data.map((v,i)=>[X(i),Y(v)]);
      const d=cfg.curved!==false?catmull(pts):"M"+pts.map(p=>p.join(",")).join("L");
      if(cfg.type==="area"){
        const areaD=d+`L${X(s.data.length-1)},${Y(0)}L${X(0)},${Y(0)}Z`;
        const gid="grad"+Math.random().toString(36).slice(2,7);
        const defs=svg("defs",{});const lg=svg("linearGradient",{id:gid,x1:0,y1:0,x2:0,y2:1});
        lg.appendChild(svg("stop",{offset:"0%","stop-color":s.color,"stop-opacity":.34}));
        lg.appendChild(svg("stop",{offset:"100%","stop-color":s.color,"stop-opacity":0}));
        defs.appendChild(lg);root.appendChild(defs);
        const area=svg("path",{d:areaD,fill:"url(#"+gid+")"});root.appendChild(area);
        if(animate){area.style.opacity=0;area.style.transition="opacity .8s ease .2s";
          requestAnimationFrame(()=>area.style.opacity=1);}
      }
      const path=svg("path",{d,fill:"none",stroke:s.color,"stroke-width":2.2,"stroke-linejoin":"round","stroke-linecap":"round"});
      root.appendChild(path);
      if(animate){const len=path.getTotalLength();path.style.strokeDasharray=len;path.style.strokeDashoffset=len;
        path.style.transition="stroke-dashoffset 1s ease";requestAnimationFrame(()=>path.style.strokeDashoffset=0);}
      if(cfg.showValues){s.data.forEach((v,i)=>{root.appendChild(svg("circle",{cx:X(i),cy:Y(v),r:2.4,fill:s.color}));});}
    });
  }

  /* ---- crosshair + hover ---- */
  const guide=svg("line",{x1:0,y1:padT,x2:0,y2:padT+ph,stroke:PALETTE.borderStrong,"stroke-width":1,
    "stroke-dasharray":"3 3",opacity:0});root.appendChild(guide);
  const dots=svg("g",{});root.appendChild(dots);
  const isBar=cfg.type==="bar"||cfg.type==="stackedBar";
  const hit=svg("rect",{x:padL,y:padT,width:pw,height:ph,fill:"transparent"});root.appendChild(hit);
  hit.addEventListener("mousemove",e=>{
    const box=root.getBoundingClientRect();const relx=(e.clientX-box.left)*(W/box.width);
    let i=isBar?clamp(Math.floor((relx-padL)/(pw/n)),0,n-1):clamp(Math.round((relx-padL)/(pw/Math.max(1,n-1))),0,n-1);
    const cx=isBar?Xb(i):X(i);
    guide.setAttribute("x1",cx);guide.setAttribute("x2",cx);guide.setAttribute("opacity",1);
    dots.innerHTML="";
    if(!isBar)series.forEach(s=>dots.appendChild(svg("circle",{cx,cy:Y(s.data[i]||0),r:3.6,fill:s.color,stroke:PALETTE.bg1,"stroke-width":2})));
    let rows=series.map(s=>`<div class="ct-row"><span class="cl-sw" style="width:9px;height:9px;border-radius:3px;background:${s.color}"></span><span class="ct-k">${esc(s.name)}</span><span class="ct-v">${fmt(s.data[i]||0)}${cfg.yUnit?cfg.yUnit:""}</span></div>`).join("");
    showTip(e.clientX,e.clientY,`<div class="ct-t">${esc(String(labels[i]))}</div>${rows}`);
  });
  hit.addEventListener("mouseleave",()=>{guide.setAttribute("opacity",0);dots.innerHTML="";hideTip();});
}
function cumulative(series,i,upto){let s=0;for(let k=0;k<upto;k++)s+=series[k].data[i]||0;return s;}
function fmtShort(v,unit){let out;if(Math.abs(v)>=1e6)out=(v/1e6).toFixed(1)+"M";
  else if(Math.abs(v)>=1e3)out=(v/1e3).toFixed(v>=1e4?0:1)+"k";
  else out=Number.isInteger(v)?v:v.toFixed(1);const u=Math.abs(v)>=1e3?"":(unit||"");return out+u;}

/* ---- DONUT ---- */
function drawDonut(root,W,H,series,cfg,animate){
  const cx=W/2,cy=H/2,R=Math.min(W,H)/2-14,r=R*0.62;
  const data=series[0].data, labels=cfg.labels||data.map((_,i)=>i);
  const colors=cfg.colors||PALETTE.chart;
  const total=data.reduce((a,b)=>a+b,0)||1;
  let a0=-Math.PI/2;
  data.forEach((v,i)=>{
    const frac=v/total, a1=a0+frac*Math.PI*2;
    const p=arcPath(cx,cy,R,r,a0,a1);
    const seg=svg("path",{d:p,fill:colors[i%colors.length],opacity:.92,stroke:PALETTE.bg1,"stroke-width":2});
    root.appendChild(seg);
    if(animate){seg.style.opacity=0;seg.style.transition="opacity .5s ease "+(i*0.08)+"s";
      requestAnimationFrame(()=>seg.style.opacity=.92);}
    seg.addEventListener("mousemove",e=>{seg.setAttribute("opacity",1);
      showTip(e.clientX,e.clientY,`<div class="ct-row"><span class="cl-sw" style="width:9px;height:9px;border-radius:3px;background:${colors[i%colors.length]}"></span><span class="ct-k">${esc(String(labels[i]))}</span><span class="ct-v">${fmt(v)} · ${pct(frac*100)}</span></div>`);});
    seg.addEventListener("mouseleave",()=>{seg.setAttribute("opacity",.92);hideTip();});
    a0=a1;
  });
  const big=svg("text",{x:cx,y:cy-2,fill:PALETTE.text0,"font-size":Math.min(30,R*0.34),"text-anchor":"middle",
    "font-family":"var(--mono)","font-weight":700});big.textContent=cfg.centerLabel||fmtK(total);root.appendChild(big);
  const sub=svg("text",{x:cx,y:cy+16,fill:PALETTE.text3,"font-size":11,"text-anchor":"middle"});
  sub.textContent=cfg.centerSub||"total";root.appendChild(sub);
}
function arcPath(cx,cy,R,r,a0,a1){
  const x0=cx+R*Math.cos(a0),y0=cy+R*Math.sin(a0),x1=cx+R*Math.cos(a1),y1=cy+R*Math.sin(a1);
  const xi1=cx+r*Math.cos(a1),yi1=cy+r*Math.sin(a1),xi0=cx+r*Math.cos(a0),yi0=cy+r*Math.sin(a0);
  const large=(a1-a0)>Math.PI?1:0;
  return `M${x0},${y0} A${R},${R} 0 ${large} 1 ${x1},${y1} L${xi1},${yi1} A${r},${r} 0 ${large} 0 ${xi0},${yi0} Z`;}

/* ---- GAUGE (270°) ---- */
function drawGauge(root,W,H,cfg,animate){
  const cx=W/2,cy=H*0.58,R=Math.min(W,H*1.4)/2-16;
  const val=clamp(cfg.gaugeValue||0,0,cfg.gaugeMax||100),max=cfg.gaugeMax||100;
  const start=Math.PI*0.75,end=Math.PI*2.25,frac=val/max;
  const bg=svg("path",{d:arcStroke(cx,cy,R,start,end),fill:"none",stroke:PALETTE.bg3,"stroke-width":14,"stroke-linecap":"round"});
  root.appendChild(bg);
  const col=frac>=0.9?PALETTE.ok:frac>=0.75?PALETTE.warn:frac>=0.6?PALETTE.high:PALETTE.crit;
  const fg=svg("path",{d:arcStroke(cx,cy,R,start,start+(end-start)*frac),fill:"none",stroke:col,"stroke-width":14,"stroke-linecap":"round"});
  root.appendChild(fg);
  if(animate){const len=fg.getTotalLength();fg.style.strokeDasharray=len;fg.style.strokeDashoffset=len;
    fg.style.transition="stroke-dashoffset 1.1s cubic-bezier(.2,.8,.2,1)";requestAnimationFrame(()=>fg.style.strokeDashoffset=0);}
  const t=svg("text",{x:cx,y:cy+2,fill:PALETTE.text0,"font-size":34,"text-anchor":"middle","font-family":"var(--mono)","font-weight":800});
  t.textContent=cfg.gaugeText!=null?cfg.gaugeText:Math.round(val)+(cfg.gaugeUnit||"");root.appendChild(t);
  const s=svg("text",{x:cx,y:cy+22,fill:PALETTE.text3,"font-size":11,"text-anchor":"middle"});s.textContent=cfg.gaugeSub||"";root.appendChild(s);
}
function arcStroke(cx,cy,R,a0,a1){const x0=cx+R*Math.cos(a0),y0=cy+R*Math.sin(a0),x1=cx+R*Math.cos(a1),y1=cy+R*Math.sin(a1);
  const large=(a1-a0)>Math.PI?1:0;return `M${x0},${y0} A${R},${R} 0 ${large} 1 ${x1},${y1}`;}

/* ---- HORIZONTAL BAR ---- */
function drawHBar(root,W,H,series,cfg,animate){
  const s=series[0], data=s.data, labels=cfg.labels||data.map((_,i)=>i);
  const padL=Math.min(140,Math.max(...labels.map(l=>String(l).length))*7+16),padR=44,padT=8,padB=8;
  const pw=W-padL-padR, n=data.length, rowH=(H-padT-padB)/n, bh=Math.min(22,rowH*0.6);
  const max=cfg.yMax||Math.max(...data)*1.1||1;
  data.forEach((v,i)=>{
    const y=padT+rowH*i+(rowH-bh)/2;
    root.appendChild(svg("rect",{x:padL,y,width:pw,height:bh,rx:4,fill:PALETTE.bg3}));
    const w=pw*v/max, col=(cfg.colors&&cfg.colors[i])||PALETTE.chart[i%PALETTE.chart.length];
    const bar=svg("rect",{x:padL,y,width:Math.max(1,w),height:bh,rx:4,fill:col,opacity:.92});
    if(animate){bar.style.transformBox="fill-box";bar.style.transformOrigin="left";bar.style.transform="scaleX(0)";
      bar.style.transition="transform .7s cubic-bezier(.2,.8,.2,1) "+(i*0.04)+"s";
      requestAnimationFrame(()=>requestAnimationFrame(()=>bar.style.transform="scaleX(1)"));}
    root.appendChild(bar);
    const lt=svg("text",{x:padL-8,y:y+bh/2+4,fill:PALETTE.text2,"font-size":11.5,"text-anchor":"end"});lt.textContent=labels[i];root.appendChild(lt);
    const vt=svg("text",{x:padL+w+8,y:y+bh/2+4,fill:PALETTE.text1,"font-size":11,"font-family":"var(--mono)"});vt.textContent=fmtShort(v,cfg.yUnit);root.appendChild(vt);
  });
}

