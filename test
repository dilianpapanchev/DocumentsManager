    const parts = value.split(" ");
    if (parts.length !== 2) {
        return null;
    }

    const datePart = parts[0];
    const timePart = parts[1];

    return new Date(datePart + "T" + timePart);
}

function parseInputDateTime(value) {
    if (!value) {
        return null;
    }

    return new Date(value);
}

function parseRecords() {
    const content = document.getElementById("fileContent").value.trim();
    const lines = content.split(/\r?\n/);

    const records = [];

    for (let i = 1; i < lines.length; i++) {
        const line = lines[i].trim();

        if (!line) {
            continue;
        }

        const cols = line.split("|");

        const record = {
            recid: cols[0] || "",
            cobDate: cols[1] || "",
            startedRaw: cols[2] || "",
            stoppedRaw: cols[3] || "",
            elapsed: cols[4] || "",
            transactions: cols[5] || "",
            started: parseDateTime(cols[2]),
            stopped: parseDateTime(cols[3]),
            isValid: true
        };

        if (!record.started || !record.stopped || isNaN(record.started) || isNaN(record.stopped)) {
            record.isValid = false;
        }

        records.push(record);
    }

    return records;
}

function filterData() {
    const records = parseRecords();
    const mode = document.getElementById("filterMode").value;

    let filtered = [];

    if (mode === "single") {
        const inputValue = document.getElementById("singleDateTime").value;
        const selectedDateTime = parseInputDateTime(inputValue);

        if (!selectedDateTime || isNaN(selectedDateTime)) {
            alert("Моля избери валидна дата и час.");
            return;
        }

        filtered = records.filter(r =>
            r.isValid &&
            selectedDateTime >= r.started &&
            selectedDateTime <= r.stopped
        );
    }

    if (mode === "range") {
        const date = document.getElementById("rangeDate").value;
        const startTime = document.getElementById("rangeStartTime").value;
        const endTime = document.getElementById("rangeEndTime").value;

        if (!date || !startTime || !endTime) {
            alert("Моля избери дата, начален час и краен час.");
            return;
        }

        let rangeStart = new Date(date + "T" + startTime + ":00");
        let rangeEnd = new Date(date + "T" + endTime + ":00");

        if (rangeEnd < rangeStart) {
            rangeEnd.setDate(rangeEnd.getDate() + 1);
        }

        filtered = records.filter(r =>
            r.isValid &&
            r.started <= rangeEnd &&
            r.stopped >= rangeStart
        );
    }

    displayRecords(filtered);
}

function showAll() {
    const records = parseRecords().filter(r => r.isValid);
    displayRecords(records);
}

function displayRecords(records) {
    let html = "";

    html += "<table>";
    html += "<tr>";
    html += "<th>RECID</th>";
    html += "<th>COB_DATE</th>";
    html += "<th>STARTED</th>";
    html += "<th>STOPPED</th>";
    html += "<th>ELAPSED</th>";
    html += "<th>TRANSACTIONS</th>";
    html += "</tr>";

    if (records.length === 0) {
        html += "<tr><td colspan='6'>Няма намерени валидни редове.</td></tr>";
    }

    records.forEach(r => {
        html += "<tr>";
        html += "<td>" + r.recid + "</td>";
        html += "<td>" + r.cobDate + "</td>";
        html += "<td>" + r.startedRaw + "</td>";
        html += "<td>" + r.stoppedRaw + "</td>";
        html += "<td>" + r.elapsed + "</td>";
        html += "<td>" + r.transactions + "</td>";
        html += "</tr>";
    });

    html += "</table>";

    document.getElementById("result").innerHTML = html;
}
</script>

</body>
</html>








