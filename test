const TL_FILTERS=[["all","All"],["ORACLE","Oracle"],["MQ","MQ"],["API","API"],["errors","Errors"],["critical","Critical"]];
let tlFilter="all";
function renderTimeline(){
  const host=$("#sec-timeline");
