#!/usr/bin/env python3
# cob_anomalies_report.py
#
# Generates a single self-contained HTML anomaly report (email-friendly):
# - Only anomaly rows are shown in the main table (like your screenshot)
# - Columns: Date, Stage, Batch, Job, Elapsed, Median, P95, Δ%
# - Search + Reset filter
# - Click a row -> selects JOB.NAME and shows trend chart for last 31 banking dates:
#   ELAPSED (left axis) + THROUGHPUT (right axis) with tooltip
#
# Baseline grouping: JOB.NAME
#
# Usage:
#   python3 cob_anomalies_report.py /path/to/file.csv [output.html]

import csv
import os
import sys
import html
import json
from datetime import datetime


def read_csv(path: str):
    with open(path, "r", newline="", encoding="utf-8") as f:
        sample = f.read(4096)
        f.seek(0)
        try:
            dialect = csv.Sniffer().sniff(sample, delimiters=",;\t|")
        except Exception:
            dialect = csv.excel
        reader = csv.reader(f, dialect)
        rows = list(reader)
    if not rows:
        return [], []
    return rows[0], rows[1:]


def esc(s):
    return html.escape("" if s is None else str(s))


def build_html(source_name: str, header, rows):
    now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    header_js = json.dumps(header, ensure_ascii=False)
    data_js = json.dumps(rows, ensure_ascii=False)

    # Simple header map for readability in JS
    idx_map = {h: i for i, h in enumerate(header)}
    idx_map_js = json.dumps(idx_map, ensure_ascii=False)

    base_html = r"""<!doctype html>
