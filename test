  const stepL=Math.ceil(n/8);for(let i=0;i<n;i+=stepL)s+=`<text x="${xPos(i).toFixed(1)}" y="${H-9}" fill="${axis}" font-size="${(9.5*ls).toFixed(1)}" text-anchor="middle" font-family="JetBrains Mono">${cfg.x[i]}</text>`;
  if(cfg.markLine){const y=yPos(cfg.markLine.y);s+=`<line x1="${ML}" y1="${y.toFixed(1)}" x2="${W-MR}" y2="${y.toFixed(1)}" stroke="${cfg.markLine.color||cvar('--crit')}" stroke-width="1.3" stroke-dasharray="5 4"/><text x="${W-MR}" y="${(y-4).toFixed(1)}" fill="${cfg.markLine.color||cvar('--crit')}" font-size="${(9.5*ls).toFixed(1)}" text-anchor="end" font-family="JetBrains Mono">${cfg.markLine.label||''}</text>`;}
  if(t==='bar'||t==='stacked'){
    const gw=pw/n;
