#!/usr/bin/env python3
# csv_to_html.py

import csv
import os
import sys
import html
from datetime import datetime

def read_csv(path):
    with open(path, "r", newline="", encoding="utf-8") as f:
        sample = f.read(4096)
        f.seek(0)
        try:
            dialect = csv.Sniffer().sniff(sample, delimiters=",;\t|")
        except Exception:
            dialect = csv.excel
        reader = csv.reader(f, dialect)
        rows = list(reader)
    if not rows:
        return [], []
    header = rows[0]
    data = rows[1:]
    return header, data

def esc(s):
    return html.escape("" if s is None else str(s))

def build_html(title, header, rows):
    now = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    ths = "\n".join(f"<th>{esc(h)}</th>" for h in header)

    trs = []
    for r in rows:
        if len(r) < len(header):
            r = r + [""] * (len(header) - len(r))
        elif len(r) > len(header):
            r = r[:len(header)]
        tds = "".join(f"<td>{esc(v)}</td>" for v in r)
        trs.append(f"<tr>{tds}</tr>")
    tbody = "\n".join(trs)

    return f"""<!doctype html>
<html lang="bg">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{esc(title)}</title>
  <style>
    body {{ font-family: Arial, sans-serif; margin: 16px; }}
    .topbar {{ display:flex; gap:12px; align-items:center; flex-wrap:wrap; margin-bottom:12px; }}
    input[type="search"] {{ padding:8px 10px; min-width:260px; }}
    .meta {{ color:#666; font-size: 12px; }}
    table {{ border-collapse: collapse; width: 100%; }}
    th, td {{ border: 1px solid #ddd; padding: 8px; font-size: 13px; }}
    th {{ position: sticky; top: 0; background: #f5f5f5; cursor: pointer; user-select:none; }}
    tr:nth-child(even) {{ background: #fafafa; }}
    tr.hidden {{ display:none; }}
    .wrap {{ overflow:auto; max-height: 78vh; border:1px solid #eee; }}
    .hint {{ font-size:12px; color:#777; }}
  </style>
</head>
<body>
  <div class="topbar">
    <h2 style="margin:0">{esc(title)}</h2>
    <input id="q" type="search" placeholder="Филтър (търси във всички колони)..." />
    <span class="meta">Генерирано: {esc(now)} | Редове: <span id="rc"></span></span>
  </div>
  <div class="hint">Клик върху заглавие на колона = сортиране (asc/desc). Филтърът търси във всички колони.</div>

  <div class="wrap">
    <table id="t">
      <thead><tr>{ths}</tr></thead>
      <tbody>
{tbody}
      </tbody>
    </table>
  </div>

<script>
(function() {{
  const table = document.getElementById('t');
  const tbody = table.tBodies[0];
  const q = document.getElementById('q');
  const rc = document.getElementById('rc');

  function updateCount() {{
    const rows = Array.from(tbody.rows);
    const visible = rows.filter(r => !r.classList.contains('hidden')).length;
    rc.textContent = visible + " / " + rows.length;
  }}

  function normalize(s) {{
    return (s || "").toString().toLowerCase();
  }}

  q.addEventListener('input', () => {{
    const needle = normalize(q.value);
    Array.from(tbody.rows).forEach(tr => {{
      const hay = normalize(tr.innerText);
      if (!needle || hay.includes(needle)) tr.classList.remove('hidden');
      else tr.classList.add('hidden');
    }});
    updateCount();
  }});

  let sortState = {{ idx: -1, dir: 1 }};
  function isNumberLike(v) {{
    // supports 0:01:07, 21:46:34, 7160, 1740, etc.
    v = (v || "").trim();
    if (!v) return false;
    if (/^\\d+:\\d{2}:\\d{2}$/.test(v)) return true;
    if (/^\\d+(\\.\\d+)?$/.test(v)) return true;
    return false;
  }}

  function parseValue(v) {{
    v = (v || "").trim();
    if (/^\\d+:\\d{2}:\\d{2}$/.test(v)) {{
      const parts = v.split(':').map(x => parseInt(x,10));
      return parts[0]*3600 + parts[1]*60 + parts[2];
    }}
    if (/^\\d+(\\.\\d+)?$/.test(v)) return parseFloat(v);
    return v.toLowerCase();
  }}

  Array.from(table.tHead.rows[0].cells).forEach((th, idx) => {{
    th.addEventListener('click', () => {{
      const rows = Array.from(tbody.rows);
      const dir = (sortState.idx === idx) ? -sortState.dir : 1;
      sortState = {{ idx, dir }};

      rows.sort((a,b) => {{
        const av = a.cells[idx]?.innerText ?? "";
        const bv = b.cells[idx]?.innerText ?? "";

        const aNum = isNumberLike(av);
        const bNum = isNumberLike(bv);

        const pa = parseValue(av);
        const pb = parseValue(bv);

        if (aNum && bNum) return (pa - pb) * dir;
        return (pa > pb ? 1 : pa < pb ? -1 : 0) * dir;
      }});

      rows.forEach(r => tbody.appendChild(r));
      updateCount();
    }});
  }});

  updateCount();
}})();
</script>
</body>
</html>
"""

def main():
    if len(sys.argv) < 2:
        print("Usage: python3 csv_to_html.py /path/to/file.csv [output.html]", file=sys.stderr)
        sys.exit(2)

    csv_path = sys.argv[1]
    out_path = sys.argv[2] if len(sys.argv) >= 3 else os.path.splitext(csv_path)[0] + ".html"

    header, rows = read_csv(csv_path)
    title = os.path.basename(csv_path)

    html_doc = build_html(title, header, rows)

    with open(out_path, "w", encoding="utf-8") as f:
        f.write(html_doc)

    print(out_path)

if __name__ == "__main__":
    main()
