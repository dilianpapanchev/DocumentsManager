function filteredLogs(){
  let re=null;
  if(LOG_STATE.q&&LOG_STATE.regex){try{re=new RegExp(LOG_STATE.q,"i");}catch(e){re=null;}}
  const ql=LOG_STATE.q.toLowerCase();
  return DATA.logs.filter(l=>{
    if(LOG_STATE.sev&&l.sev!==LOG_STATE.sev)return false;
    if(LOG_STATE.sys&&l.system!==LOG_STATE.sys)return false;
    if(!LOG_STATE.q)return true;
    const hay=(l.msg+" "+l.host+" "+l.thread+" "+l.corr+" "+l.sev+" "+l.system);
    return re?re.test(hay):hay.toLowerCase().includes(ql);
  });
}
function hlt(text){
  if(!LOG_STATE.q||LOG_STATE.regex)return esc(text);
  const i=text.toLowerCase().indexOf(LOG_STATE.q.toLowerCase());
  if(i<0)return esc(text);
  return esc(text.slice(0,i))+'<span class="hl-match">'+esc(text.slice(i,i+LOG_STATE.q.length))+'</span>'+esc(text.slice(i+LOG_STATE.q.length));
}
function paintLogs(){
  const rows=filteredLogs();const cap=400;
  $("#logCount").textContent=fmt(rows.length)+" matching entries"+(rows.length>cap?` · showing first ${cap}`:"");
  const box=$("#logRows");box.innerHTML="";
  const frag=document.createDocumentFragment();
  rows.slice(0,cap).forEach((l,idx)=>{
    const r=el("div",{class:"lrow sev-"+l.sev});
    r.innerHTML=`<span style="color:var(--text-3)">${l.ts.slice(11)}</span>
      <span style="color:${sevColor(l.sev)};font-weight:600">${l.sev}</span>
      <span style="color:var(--text-2)">${l.system}</span>
      <span style="color:var(--text-3)">${l.host}</span>
      <span class="lmsg">${hlt(l.msg)}</span>`;
    r.addEventListener("click",()=>showLogDetail(l,r));
    frag.appendChild(r);
  });
  box.appendChild(frag);
  if(!rows.length)box.innerHTML='<div class="muted" style="padding:24px;text-align:center">No log entries match your query.</div>';
  $("#logDetail").innerHTML="";
}
function showLogDetail(l,row){
