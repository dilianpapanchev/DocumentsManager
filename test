<!DOCTYPE html>
<html lang="bg" data-theme="mission">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Log Analyser Report — MQ · Oracle · APM · API · SQL</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --font-ui:'Inter',system-ui,sans-serif;
  --font-display:'Space Grotesk',var(--font-ui);
  --font-mono:'JetBrains Mono','SFMono-Regular',monospace;
  --fs:1;--cs:1;--rad:1;--gridop:1;--anim:1;
  --radius:calc(14px*var(--rad));--radius-sm:calc(9px*var(--rad));
  --lv-debug:#8390ad; --lv-info:#5b8cff; --lv-warn:#f5b13d; --lv-error:#ff6f5e; --lv-high:#ff3d71;
  --ok:#2ecf86; --warn:#f5b13d; --crit:#ff5d6c;
}
html{font-size:calc(16px*var(--fs))}
html[data-theme="mission"]{--bg:#0a0f1c;--bg2:#0d1426;--surface:#111a30;--surface2:#16223e;--border:#23304f;--text:#e8edf7;--muted:#8a98b8;--faint:#5b6789;--accent:#3dd6c4;--accent2:#5b8cff;--grid:#1c2945;--axis:#6a78a0;--c1:#3dd6c4;--c2:#5b8cff;--c3:#b98cff;--c4:#ffb454;--c5:#ff6b9d;--c6:#48d597;}
html[data-theme="daylight"]{--bg:#eef1f6;--bg2:#e6eaf2;--surface:#ffffff;--surface2:#f5f7fb;--border:#dde3ee;--text:#1a2236;--muted:#5d6a85;--faint:#93a0bb;--accent:#1d8f7e;--accent2:#3b6fe0;--grid:#e6ebf4;--axis:#8090ac;--c1:#1d8f7e;--c2:#3b6fe0;--c3:#8a5cf0;--c4:#e0901f;--c5:#e0467a;--c6:#27a567;--lv-debug:#6b7793;--lv-info:#2f6fe0;--lv-warn:#c9881f;--lv-error:#e0492f;--lv-high:#d61f5a;}
html[data-theme="nord"]{--bg:#242a36;--bg2:#2b323f;--surface:#2e3440;--surface2:#3b4252;--border:#434c5e;--text:#eceff4;--muted:#a7b1c4;--faint:#717c94;--accent:#88c0d0;--accent2:#81a1c1;--grid:#3a424f;--axis:#7e8aa3;--c1:#88c0d0;--c2:#81a1c1;--c3:#b48ead;--c4:#ebcb8b;--c5:#bf616a;--c6:#a3be8c;}
html[data-theme="solarized"]{--bg:#022b36;--bg2:#03303c;--surface:#073642;--surface2:#0a4250;--border:#0d4f5f;--text:#eee8d5;--muted:#93a1a1;--faint:#5e7174;--accent:#2aa198;--accent2:#268bd2;--grid:#0c4b59;--axis:#6c8389;--c1:#2aa198;--c2:#268bd2;--c3:#6c71c4;--c4:#b58900;--c5:#dc322f;--c6:#859900;}
html[data-theme="synthwave"]{--bg:#15102b;--bg2:#1a1336;--surface:#1f1840;--surface2:#291f56;--border:#3a2c6e;--text:#f4eaff;--muted:#b6a4e0;--faint:#7c6bb0;--accent:#ff4ecd;--accent2:#37e0ff;--grid:#2c2160;--axis:#9683cc;--c1:#ff4ecd;--c2:#37e0ff;--c3:#b07bff;--c4:#ffd84e;--c5:#ff6f6f;--c6:#54f0b4;}
html[data-theme="matrix"]{--bg:#000604;--bg2:#02110a;--surface:#031a10;--surface2:#04261a;--border:#0a4a30;--text:#c8ffd9;--muted:#5fc888;--faint:#368a5a;--accent:#37ff8f;--accent2:#7affc0;--grid:#0a3a26;--axis:#3f9a68;--c1:#37ff8f;--c2:#7affc0;--c3:#aaff37;--c4:#ffe14e;--c5:#ff6f8f;--c6:#37ffd6;--font-ui:var(--font-mono);}
html[data-theme="dracula"]{--bg:#21222c;--bg2:#282a36;--surface:#2f313f;--surface2:#3a3d4d;--border:#454860;--text:#f8f8f2;--muted:#a9b0d0;--faint:#6c7196;--accent:#bd93f9;--accent2:#8be9fd;--grid:#3a3d50;--axis:#828bb0;--c1:#8be9fd;--c2:#bd93f9;--c3:#ff79c6;--c4:#f1fa8c;--c5:#ff5555;--c6:#50fa7b;}
html[data-theme="gruvbox"]{--bg:#1d2021;--bg2:#282828;--surface:#32302f;--surface2:#3c3836;--border:#504945;--text:#ebdbb2;--muted:#bdae93;--faint:#7c6f64;--accent:#fabd2f;--accent2:#83a598;--grid:#3a3735;--axis:#928374;--c1:#83a598;--c2:#fabd2f;--c3:#d3869b;--c4:#fe8019;--c5:#fb4934;--c6:#b8bb26;}
html[data-theme="oceanic"]{--bg:#0b1f2a;--bg2:#0e2733;--surface:#11313f;--surface2:#163d4e;--border:#1f4d61;--text:#e3f1f7;--muted:#8db3c4;--faint:#557282;--accent:#26c6da;--accent2:#4f8cff;--grid:#163f50;--axis:#5d8499;--c1:#26c6da;--c2:#4f8cff;--c3:#a77dff;--c4:#ffb74d;--c5:#ff6e7d;--c6:#4dd6a4;}
html[data-theme="rosepine"]{--bg:#191724;--bg2:#1f1d2e;--surface:#26233a;--surface2:#2f2b45;--border:#403d5e;--text:#e0def4;--muted:#a8a3c9;--faint:#6e6a8c;--accent:#ebbcba;--accent2:#9ccfd8;--grid:#322f4a;--axis:#7a7596;--c1:#9ccfd8;--c2:#c4a7e7;--c3:#ebbcba;--c4:#f6c177;--c5:#eb6f92;--c6:#31a78f;}
html[data-theme="paper"]{--bg:#f3efe6;--bg2:#eae5d8;--surface:#fffdf8;--surface2:#f6f2e9;--border:#e2dccc;--text:#352f26;--muted:#6e6557;--faint:#a59b88;--accent:#a8551f;--accent2:#3d6a8a;--grid:#ece6d8;--axis:#9a8f7c;--c1:#a8551f;--c2:#3d6a8a;--c3:#7b5ea0;--c4:#c08a1e;--c5:#b13b3b;--c6:#4f8a55;--lv-debug:#7c715d;--lv-info:#2f5f8a;--lv-warn:#b07818;--lv-error:#bf3b2a;--lv-high:#a8243f;}
html[data-theme="amoled"]{--bg:#000000;--bg2:#070707;--surface:#0c0c0e;--surface2:#151518;--border:#26262c;--text:#f0f0f4;--muted:#9a9aae;--faint:#5f5f70;--accent:#00e5c0;--accent2:#4d8dff;--grid:#1a1a20;--axis:#6a6a80;--c1:#00e5c0;--c2:#4d8dff;--c3:#c08bff;--c4:#ffc14d;--c5:#ff6b8e;--c6:#3ee08a;}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%}
body{font-family:var(--font-ui);font-size:.9375rem;background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased;transition:background .4s,color .4s}
.shell{display:flex;min-height:100vh}
body.compact{--radius:calc(11px*var(--rad))}
.sidebar{width:248px;flex:none;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;position:sticky;top:0;height:100vh;transition:background .4s,border-color .4s,transform .3s}
.sb-brand{display:flex;align-items:center;gap:11px;padding:18px 18px 14px}
.logo{width:38px;height:38px;border-radius:10px;display:grid;place-items:center;background:linear-gradient(135deg,var(--accent),var(--accent2));flex:none}
body.glow .logo{box-shadow:0 0 0 1px color-mix(in srgb,var(--accent) 30%,transparent),0 0 22px -4px var(--accent)}
.logo svg{width:22px;height:22px}
.sb-brand h1{font-family:var(--font-display);font-size:.94rem;line-height:1.1}
.sb-brand .sub{font-size:.66rem;color:var(--muted);font-family:var(--font-mono);letter-spacing:.4px}
.nav{flex:1;overflow-y:auto;padding:8px 10px}
.nav .grp{font-size:.625rem;text-transform:uppercase;letter-spacing:.8px;color:var(--faint);font-weight:700;padding:14px 10px 6px}
.nav a{display:flex;align-items:center;gap:11px;padding:9px 11px;border-radius:9px;color:var(--muted);text-decoration:none;font-size:.84rem;font-weight:500;cursor:pointer;transition:.15s;margin-bottom:2px;position:relative}
.nav a svg{width:17px;height:17px;flex:none}
.nav a:hover{background:var(--surface2);color:var(--text)}
.nav a.on{background:color-mix(in srgb,var(--accent) 14%,transparent);color:var(--accent)}
.nav a.on::before{content:"";position:absolute;left:0;top:8px;bottom:8px;width:3px;border-radius:2px;background:var(--accent)}
.nav a .ct{margin-left:auto;font-family:var(--font-mono);font-size:.66rem;color:var(--faint);background:var(--bg2);padding:1px 7px;border-radius:99px}
.nav a.alert .ct{color:var(--lv-high);background:color-mix(in srgb,var(--lv-high) 14%,transparent)}
.sb-foot{padding:12px 16px;border-top:1px solid var(--border)}
.legend{display:flex;flex-direction:column;gap:5px}
.legend .lg{display:flex;align-items:center;gap:8px;font-size:.69rem;color:var(--muted);font-family:var(--font-mono)}
.legend .lg i{width:11px;height:11px;border-radius:3px}
.main{flex:1;min-width:0;display:flex;flex-direction:column}
.topbar{position:sticky;top:0;z-index:50;display:flex;align-items:center;gap:10px;padding:13px 22px;background:color-mix(in srgb,var(--bg) 86%,transparent);backdrop-filter:blur(12px);border-bottom:1px solid var(--border)}
.burger{display:none;width:36px;height:36px;border-radius:9px;border:1px solid var(--border);background:var(--surface2);color:var(--text);cursor:pointer;place-items:center}
.burger svg{width:18px;height:18px}
.tb-title{margin-right:auto;min-width:0}
.tb-title h2{font-family:var(--font-display);font-size:1.12rem;line-height:1.1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tb-title p{font-size:.72rem;color:var(--muted);font-family:var(--font-mono);margin-top:1px}
.btn{font:inherit;font-size:.78rem;font-weight:600;color:var(--text);background:var(--surface2);border:1px solid var(--border);border-radius:10px;padding:8px 12px;cursor:pointer;display:inline-flex;align-items:center;gap:7px;transition:.16s;white-space:nowrap}
.btn:hover{border-color:var(--accent);color:var(--accent);transform:translateY(-1px)}
.btn svg{width:15px;height:15px}
.content{padding:20px 22px 60px;position:relative}
section[data-sec]{display:none}
section[data-sec].on{display:block;animation:fade calc(.35s*var(--anim)) ease}
@keyframes fade{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
.sec-intro{background:color-mix(in srgb,var(--surface) 70%,transparent);border:1px solid var(--border);border-left:3px solid var(--accent);border-radius:var(--radius);padding:14px 18px;margin-bottom:18px;font-size:.84rem;line-height:1.65;color:var(--muted)}
.sec-intro b{color:var(--text)}
.sec-intro .hl{color:var(--accent);font-family:var(--font-mono);font-weight:600}
.summary{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:11px;margin-bottom:18px}
.stat{background:color-mix(in srgb,var(--surface) 80%,transparent);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 13px}
.stat .sl{font-size:.62rem;text-transform:uppercase;letter-spacing:.5px;color:var(--faint);font-weight:700}
.stat .sv{font-family:var(--font-mono);font-size:1.18rem;font-weight:700;margin-top:3px}
.stat .sx{font-size:.66rem;color:var(--muted);font-family:var(--font-mono);margin-top:1px}
.kpis{display:grid;gap:13px;margin-bottom:18px}
.kpi{position:relative;overflow:hidden;background:color-mix(in srgb,var(--surface) 84%,transparent);border:1px solid var(--border);border-radius:var(--radius);padding:14px 16px;transition:transform .2s,border-color .2s;opacity:0;transform:translateY(8px);animation:rise calc(.45s*var(--anim)) forwards}
@keyframes rise{to{opacity:1;transform:none}}
.kpi:hover{transform:translateY(-3px);border-color:color-mix(in srgb,var(--accent) 45%,var(--border))}
.kpi .lbl{font-size:.66rem;text-transform:uppercase;letter-spacing:.6px;color:var(--muted);font-weight:700}
.kpi .val{font-family:var(--font-mono);font-size:1.56rem;font-weight:700;letter-spacing:-.5px;margin-top:3px;display:flex;align-items:baseline;gap:5px}
.kpi .val small{font-size:.75rem;color:var(--muted);font-weight:500}
.kpi .sub{font-size:.69rem;color:var(--faint);font-family:var(--font-mono);margin-top:2px}
.kpi .kspark{margin-top:6px;height:26px}
.kpi::after{content:"";position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--st,var(--accent))}
body.compact .kpi{padding:11px 13px}
.grid{display:grid;grid-template-columns:repeat(12,1fr);gap:15px}
.panel{position:relative;display:flex;flex-direction:column;min-width:0;background:color-mix(in srgb,var(--surface) 86%,transparent);border:1px solid var(--border);border-radius:var(--radius);box-shadow:0 14px 40px -22px rgba(0,0,0,.55);overflow:hidden;transition:border-color .2s,box-shadow .2s;opacity:0;transform:scale(.985);animation:pop calc(.45s*var(--anim)) forwards}
@keyframes pop{to{opacity:1;transform:none}}
.panel.dragging{opacity:.45}
.panel.drop-target{border-color:var(--accent);border-style:dashed}
.panel.maximized{position:fixed;inset:18px;z-index:200;grid-column:auto!important}
.scrim{position:fixed;inset:0;background:rgba(0,0,0,.55);backdrop-filter:blur(3px);z-index:150;display:none}
.scrim.show{display:block;animation:fade .25s}
.phead{display:flex;align-items:center;gap:9px;padding:11px 13px;border-bottom:1px solid var(--border);cursor:grab;user-select:none}
.phead:active{cursor:grabbing}
.phead .ico{width:26px;height:26px;border-radius:7px;display:grid;place-items:center;background:color-mix(in srgb,var(--accent) 16%,transparent);color:var(--accent);flex:none}
.phead .ico svg{width:15px;height:15px}
.phead .tt{display:flex;flex-direction:column;min-width:0;margin-right:auto}
.phead .tt b{font-family:var(--font-display);font-size:.84rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.phead .tt span{font-size:.66rem;color:var(--muted);font-family:var(--font-mono)}
.ptools{display:flex;align-items:center;gap:4px}
.ptype{font:inherit;font-size:.69rem;font-family:var(--font-mono);color:var(--muted);background:var(--bg2);border:1px solid var(--border);border-radius:7px;padding:5px 8px;cursor:pointer;transition:.15s;white-space:nowrap}
.ptype:hover{color:var(--text);border-color:var(--accent)}
.pbtn{width:27px;height:27px;border-radius:7px;display:grid;place-items:center;cursor:pointer;background:var(--bg2);border:1px solid var(--border);color:var(--muted);transition:.15s;flex:none}
.pbtn:hover{color:var(--accent);border-color:var(--accent)}
.pbtn svg{width:13.5px;height:13.5px}
.pbody{flex:1;min-height:0;position:relative;padding:6px}
.chart{width:100%;height:calc(260px*var(--cs))}
.panel.maximized .chart{height:100%!important}
.panel.maximized .pbody{overflow:auto}
.rsz{position:absolute;right:0;bottom:0;width:20px;height:20px;cursor:nwse-resize;z-index:5}
.rsz::after{content:"";position:absolute;right:4px;bottom:4px;width:8px;height:8px;border-right:2px solid var(--faint);border-bottom:2px solid var(--faint)}
.panel.maximized .rsz{display:none}
.s3{grid-column:span 3}.s4{grid-column:span 4}.s5{grid-column:span 5}.s6{grid-column:span 6}.s7{grid-column:span 7}.s8{grid-column:span 8}.s12{grid-column:span 12}
@media(max-width:1100px){.s3,.s4,.s5{grid-column:span 6}.s7,.s8{grid-column:span 12}}
@media(max-width:720px){.grid{grid-template-columns:1fr}.s3,.s4,.s5,.s6,.s7,.s8,.s12{grid-column:span 1}}
.pop{position:fixed;z-index:320;background:var(--surface);border:1px solid var(--border);border-radius:11px;padding:8px;box-shadow:0 18px 50px -18px rgba(0,0,0,.6);min-width:170px;display:none}
.pop.open{display:block;animation:drop calc(.18s*var(--anim)) ease}
@keyframes drop{from{opacity:0;transform:translateY(-6px)}to{opacity:1;transform:none}}
.pop .ph{font-size:.62rem;text-transform:uppercase;letter-spacing:.6px;color:var(--faint);font-weight:700;padding:4px 8px 7px}
.mrow{display:flex;align-items:center;gap:9px;padding:6px 8px;border-radius:7px;cursor:pointer;font-size:.78rem;transition:.12s}
.mrow:hover{background:var(--surface2)}
.mrow .mc{width:11px;height:11px;border-radius:3px;flex:none}
.mrow.off{opacity:.4}
.mrow .chk{margin-left:auto;width:15px;height:15px;border-radius:4px;border:1.5px solid var(--border);display:grid;place-items:center}
.mrow.on .chk{background:var(--accent);border-color:var(--accent)}
.mrow .chk svg{width:10px;height:10px;opacity:0}
.mrow.on .chk svg{opacity:1}
.chart svg{display:block;overflow:visible}
.tip{position:fixed;z-index:400;pointer-events:none;background:var(--surface);border:1px solid var(--border);border-radius:9px;padding:9px 11px;font-size:.72rem;font-family:var(--font-mono);box-shadow:0 12px 36px -12px rgba(0,0,0,.6);display:none;max-width:280px}
.tip .tt-h{font-weight:600;margin-bottom:5px;color:var(--text)}
.tip .tt-r{display:flex;align-items:center;gap:6px;color:var(--muted);line-height:1.5}
.tip .tt-r b{color:var(--text)}
.tip .tt-d{width:9px;height:9px;border-radius:2px;flex:none}
.tbl-wrap{overflow:auto;max-height:420px}
.panel.maximized .tbl-wrap{max-height:none}
table{width:100%;border-collapse:collapse;font-size:.78rem}
thead th{position:sticky;top:0;background:var(--surface);z-index:2;text-align:left;font-size:.65rem;text-transform:uppercase;letter-spacing:.5px;color:var(--muted);font-weight:700;padding:10px 12px;cursor:pointer;user-select:none;white-space:nowrap;border-bottom:1px solid var(--border)}
thead th:hover{color:var(--accent)}
thead th .ar{opacity:.4;font-size:.56rem;margin-left:3px}
thead th.sorted .ar{opacity:1;color:var(--accent)}
thead th.nos{cursor:default}thead th.nos:hover{color:var(--muted)}
tbody td{padding:9px 12px;border-bottom:1px solid color-mix(in srgb,var(--border) 60%,transparent);font-family:var(--font-mono)}
tbody td.txt{font-family:var(--font-ui)}
tbody tr{transition:background .15s}tbody tr:hover{background:var(--surface2)}
.mono{font-family:var(--font-mono)}
.lv{display:inline-flex;align-items:center;gap:5px;font-size:.65rem;font-weight:700;padding:2px 8px;border-radius:99px;font-family:var(--font-ui);letter-spacing:.3px}
.lv.debug{color:var(--lv-debug);background:color-mix(in srgb,var(--lv-debug) 16%,transparent)}
.lv.info{color:var(--lv-info);background:color-mix(in srgb,var(--lv-info) 16%,transparent)}
.lv.warn,.lv.warning{color:var(--lv-warn);background:color-mix(in srgb,var(--lv-warn) 16%,transparent)}
.lv.error{color:var(--lv-error);background:color-mix(in srgb,var(--lv-error) 16%,transparent)}
.lv.high{color:var(--lv-high);background:color-mix(in srgb,var(--lv-high) 16%,transparent)}
.lv.ok{color:var(--ok);background:color-mix(in srgb,var(--ok) 16%,transparent)}
.findings{list-style:none;display:flex;flex-direction:column;gap:11px;padding:4px}
.findings li{display:flex;gap:11px;font-size:.81rem;line-height:1.55;color:var(--muted)}
.findings li .fi{width:24px;height:24px;border-radius:7px;flex:none;display:grid;place-items:center;font-size:.81rem;font-weight:700}
.findings li b{color:var(--text)}
.findings .num{font-family:var(--font-mono);color:var(--accent);font-weight:600}
.tl-filter{display:flex;gap:6px;flex-wrap:wrap;padding:4px 4px 12px}
.tl-filter button{font:inherit;font-size:.69rem;font-weight:600;font-family:var(--font-mono);padding:5px 11px;border-radius:99px;border:1px solid var(--border);background:var(--bg2);color:var(--muted);cursor:pointer;transition:.15s}
.tl-filter button:hover{color:var(--text)}
.tl-filter button.on{border-color:var(--accent);color:var(--accent);background:color-mix(in srgb,var(--accent) 12%,transparent)}
.timeline{position:relative;padding:6px 4px 4px 4px;max-height:560px;overflow:auto}
.timeline::before{content:"";position:absolute;left:78px;top:0;bottom:0;width:1px;background:var(--border)}
.tl-item{display:flex;gap:14px;padding:9px 0;position:relative;animation:slideIn calc(.4s*var(--anim)) ease backwards}
@keyframes slideIn{from{opacity:0;transform:translateX(10px)}to{opacity:1;transform:none}}
.tl-time{width:62px;flex:none;text-align:right;font-family:var(--font-mono);font-size:.69rem;color:var(--faint);padding-top:1px}
.tl-dot{position:absolute;left:74px;top:13px;width:10px;height:10px;border-radius:50%;border:2px solid var(--surface);z-index:1}
.tl-body{margin-left:28px;flex:1;min-width:0}
.tl-body .tl-h{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
.tl-sys{font-family:var(--font-mono);font-size:.69rem;color:var(--accent2);font-weight:600}
.tl-msg{font-size:.78rem;color:var(--text);margin-top:3px;font-family:var(--font-mono)}
