function paintTimeline(){
  const body=$("#tlBody");body.innerHTML='<div class="tl-line"></div>';
  const items=DATA.timeline.filter(t=>{
    if(tlFilter==="all")return true;
    if(tlFilter==="errors")return t.sev==="ERROR"||t.sev==="HIGH";
    if(tlFilter==="critical")return t.sev==="ERROR";
    return t.system===tlFilter;});
  if(!items.length){body.innerHTML+='<div class="muted" style="padding:20px;text-align:center">No events match this filter.</div>';return;}
  items.forEach(t=>{
    const sevCls=t.sev==="ERROR"?"crit":t.sev==="HIGH"?"high":t.sev==="WARNING"?"warn":"info";
    const col=sevColor(t.sev);
    const hr=parseInt(t.time.slice(0,2));
    const logs=DATA.logs.filter(l=>l.system===t.system&&l._h===hr).slice(0,6)
      .map(l=>`[${l.ts.slice(11,19)}] ${l.sev} ${l.host} — ${l.msg}`).join("\n")||"No sampled logs for this window.";
    const item=el("div",{class:"tl-item"});
    item.innerHTML=`<div class="tl-node" style="background:${col};box-shadow:0 0 12px ${col}"></div>
      <div class="tl-card">
        <div class="tl-head"><span class="tl-time num">${t.time}</span>
          <span class="tl-title">${esc(t.title)}</span>
          <span class="tl-sys badge ${sevCls}">${t.sev}</span></div>
