<script>
// ─── RAW DATA ───────────────────────────────────────────────────────────────
const RAW = `RECID|COB_DATE|STARTED|STOPPED|ELAPSED|TRANSACTIONS
TSM|2026-04-13|2026-04-11 07:56:19.0|2026-04-25 03:57:09.0|20:00:50|
TSM|2026-04-27|2026-04-25 04:43:13.0|2026-04-26 06:03:46.0|01:20:33|
TSM|2026-04-27|2026-04-26 06:45:38.0|||
XML.TRANSFORMATION|2026-01-14|2026-01-13 23:37:33.0|2026-01-13 23:40:13.0|00:02:40|7970
XML.TRANSFORMATION|2026-01-15|2026-01-14 23:14:29.0|2026-01-14 23:14:47.0|00:00:18|
XML.TRANSFORMATION|2026-01-16|2026-01-15 23:57:17.0|2026-01-15 23:59:26.0|00:02:09|8370
XML.TRANSFORMATION|2026-01-19|2026-01-16 23:17:42.0|2026-01-16 23:19:56.0|00:02:14|7783
XML.TRANSFORMATION|2026-01-20|2026-01-19 23:31:32.0|2026-01-19 23:33:41.0|00:02:09|8563
XML.TRANSFORMATION|2026-01-21|2026-01-20 23:35:05.0|2026-01-20 23:35:13.0|00:00:08|
XML.TRANSFORMATION|2026-01-22|2026-01-21 23:07:18.0|2026-01-21 23:07:28.0|00:00:10|
XML.TRANSFORMATION|2026-01-23|2026-01-22 23:27:42.0|2026-01-22 23:27:53.0|00:00:11|
XML.TRANSFORMATION|2026-01-26|2026-01-23 23:13:44.0|2026-01-23 23:15:41.0|00:01:57|7392
XML.TRANSFORMATION|2026-01-27|2026-01-27 00:35:20.0|2026-01-27 00:37:25.0|00:02:05|8140`;

// ─── PARSE ──────────────────────────────────────────────────────────────────
const lines = RAW.trim().split('\n');
const headers = lines[0].split('|');
const DATA = lines.slice(1).map(line => {
  const cols = line.split('|');
  return {
    RECID:        cols[0] || '',
    COB_DATE:     cols[1] || '',
    STARTED:      cols[2] || '',
    STOPPED:      cols[3] || '',
    ELAPSED:      cols[4] || '',
    TRANSACTIONS: cols[5] || ''
  };
});

// Parse "2026-01-27 00:35:20.0" → Date object, or null if empty/invalid
function parseTs(s) {
  if (!s || s.trim() === '') return null;
  // Remove trailing ".0" sub-seconds for clean parse
  const clean = s.replace(/\.\d+$/, '').trim();
  const d = new Date(clean.replace(' ', 'T'));
  return isNaN(d.getTime()) ? null : d;
}

// Is a row "valid"? — both STARTED and STOPPED must be non-empty parseable
function isValid(row) {
  return parseTs(row.STARTED) !== null && parseTs(row.STOPPED) !== null;
}

// ─── UI STATE ────────────────────────────────────────────────────────────────
let currentMode = 'datetime';

function setMode(m) {
  currentMode = m;
  document.getElementById('mode-datetime').style.display = m === 'datetime' ? '' : 'none';
  document.getElementById('mode-range').style.display   = m === 'range'    ? '' : 'none';
  document.getElementById('tab-datetime').classList.toggle('active', m === 'datetime');
  document.getElementById('tab-range').classList.toggle('active', m === 'range');
}

// Auto-format time input: insert colons as user types (e.g. "2335" → "23:35")
function fmtTimeInput(el) {
  let v = el.value.replace(/[^0-9]/g, '');
  if (v.length >= 3) v = v.slice(0,2) + ':' + v.slice(2);
  if (v.length >= 6) v = v.slice(0,5) + ':' + v.slice(5,7);
  el.value = v;
  validateTimeInput(el);
}

// Validate HH:MM or HH:MM:SS — returns true/false and updates hint styling
function validateTimeInput(el) {
  const hintId = el.id + '-hint';
  const hint = document.getElementById(hintId);
  const v = el.value.trim();
  if (!v) {
    el.classList.remove('invalid-input');
    if (hint) { hint.classList.remove('error'); hint.textContent = 'пр. 23:35 или 00:35:20'; }
    return true;
  }
  const ok = /^([01]\d|2[0-3]):([0-5]\d)(:[0-5]\d)?$/.test(v);
  el.classList.toggle('invalid-input', !ok);
  if (hint) {
    hint.classList.toggle('error', !ok);
    hint.textContent = ok ? '✓' : 'Формат: HH:MM или HH:MM:SS';
  }
  return ok;
}

// Parse a text time value "HH:MM" or "HH:MM:SS" + a date string "YYYY-MM-DD" → Date
function parseTimeText(dateStr, timeStr) {
  const t = timeStr.trim();
  if (!t) return null;
  // Pad seconds if missing
  const full = /^\d{2}:\d{2}$/.test(t) ? t + ':00' : t;
  const d = new Date(`${dateStr}T${full}`);
  return isNaN(d.getTime()) ? null : d;
}

function resetFilter() {
  ['dt-date','dt-time','r-date','r-from','r-to'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.value = ''; el.classList.remove('invalid-input'); }
  });
  ['dt-time-hint','r-from-hint','r-to-hint'].forEach(id => {
    const el = document.getElementById(id);
    if (el) { el.classList.remove('error'); el.textContent = 'пр. 23:35 або 00:35:20'; }
  });
  renderRows(DATA);
}

function applyFilter() {
  let filtered;

  if (currentMode === 'datetime') {
    const dateVal = document.getElementById('dt-date').value;
    const timeEl  = document.getElementById('dt-time');

    if (!dateVal || !timeEl.value.trim()) { alert('Моля въведете дата и час.'); return; }
    if (!validateTimeInput(timeEl)) { alert('Невалиден формат на час. Използвайте HH:MM или HH:MM:SS.'); return; }

    const target = parseTimeText(dateVal, timeEl.value);
    if (!target) { alert('Невалидна дата/час.'); return; }

    filtered = DATA.filter(row => {
      if (!isValid(row)) return false;
      const started = parseTs(row.STARTED);
      const stopped = parseTs(row.STOPPED);
      return target >= started && target <= stopped;
    });

  } else {
    const dateVal = document.getElementById('r-date').value;
    const fromEl  = document.getElementById('r-from');
    const toEl    = document.getElementById('r-to');

    if (!dateVal || !fromEl.value.trim() || !toEl.value.trim()) {
      alert('Моля въведете дата, начален и краен час.'); return;
    }
    if (!validateTimeInput(fromEl) | !validateTimeInput(toEl)) {
      alert('Невалиден формат на час. Използвайте HH:MM или HH:MM:SS.'); return;
    }

    const from = parseTimeText(dateVal, fromEl.value);
    const to   = parseTimeText(dateVal, toEl.value);
    if (!from || !to) { alert('Невалидни часове.'); return; }
    if (from > to) { alert('Началният час трябва да е преди крайния.'); return; }

    filtered = DATA.filter(row => {
      if (!isValid(row)) return false;
      const started = parseTs(row.STARTED);
      const stopped = parseTs(row.STOPPED);
      return started <= to && stopped >= from;
    });
  }

  renderRows(filtered);
}

function fmt(s) {
  // Remove trailing .0 for display
  return s ? s.replace(/\.\d+$/, '') : '';
}

function renderRows(rows) {
  const tbody = document.getElementById('tbody');
  const empty = document.getElementById('empty');
  document.getElementById('shown-count').textContent = rows.length;

  if (rows.length === 0) {
    tbody.innerHTML = '';
    empty.style.display = '';
    return;
  }
  empty.style.display = 'none';

  tbody.innerHTML = rows.map(r => {
    const valid = isValid(r);
    const badge = valid
      ? `<span class="badge badge-valid">✓ Валиден</span>`
      : `<span class="badge badge-invalid">✗ Невалиден</span>`;
    return `<tr>
      <td class="td-recid">${r.RECID}</td>
      <td class="td-date">${r.COB_DATE}</td>
      <td class="td-date">${fmt(r.STARTED)}</td>
      <td class="td-date">${fmt(r.STOPPED)}</td>
      <td class="td-elapsed">${r.ELAPSED || '—'}</td>
      <td class="td-transactions">${r.TRANSACTIONS || '—'}</td>
      <td>${badge}</td>
    </tr>`;
  }).join('');
}

// Initial render — all rows
renderRows(DATA);
</script>

</body>
</html>









