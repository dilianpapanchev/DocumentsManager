<script>
// ─────────────────────────────────────────────
//  State
// ─────────────────────────────────────────────
let allRows = [];
let currentMode = 'datetime';
let sortCol = null, sortDir = 1;

// ─────────────────────────────────────────────
//  Mode switching
// ─────────────────────────────────────────────
function setMode(mode) {
  currentMode = mode;
  ['datetime','range','date'].forEach(m => {
    document.getElementById('inputs-' + m).classList.toggle('hidden', m !== mode);
    document.getElementById('tab-' + m).classList.toggle('active', m === mode);
  });
}

// ─────────────────────────────────────────────
//  Parse helpers
// ─────────────────────────────────────────────
function parseDateTime(datePart, timePart) {
  // datePart: "2026-01-27", timePart: " 22:30:20.0" or "22:30:20.0"
  if (!datePart || !datePart.trim()) return null;
  const d = datePart.trim();
  const t = timePart ? timePart.trim().split('.')[0] : '';
  if (!t) return new Date(d + 'T00:00:00');
  return new Date(d + 'T' + t);
}

function parseDuration(str) {
  if (!str || !str.trim()) return null;
  const parts = str.trim().split(':');
  if (parts.length < 2) return null;
  return parseInt(parts[0]) * 3600 + parseInt(parts[1]) * 60 + parseInt(parts[2] || '0');
}

function formatDurSecs(s) {
  if (s === null || isNaN(s)) return '—';
  const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
  return [h, m, sec].map(x => String(x).padStart(2,'0')).join(':');
}

function parseLine(line) {
  if (!line.trim()) return null;
  const parts = line.split('|');
  // Expected: Name | Date | StartDateTime | EndDate | EndTime | Duration | Number
  const name     = parts[0] || '';
  const date     = parts[1] || '';
  const startDT  = parts[2] || '';  // "2026-01-27 22:30:20.0"
  const endDate  = parts[3] || '';
  const endTime  = parts[4] || '';
  const duration = parts[5] || '';
  const number   = parts[6] || '';

  // Parse start: split date and time from startDT
  let startObj = null;
  if (startDT.trim()) {
    const sp = startDT.trim().split(' ');
    const sd = sp[0];
    const st = sp[1] ? sp[1].split('.')[0] : '00:00:00';
    startObj = new Date(sd + 'T' + st);
  } else if (date.trim()) {
    startObj = new Date(date.trim() + 'T00:00:00');
  }

  // Parse end
  let endObj = null;
  if (endDate.trim() && endTime.trim()) {
    const et = endTime.trim().split('.')[0];
    endObj = new Date(endDate.trim() + 'T' + et);
  }

  return {
    name,
    date: date.trim(),
    startDT: startDT.trim(),
    endDate: endDate.trim(),
    endTime: endTime.trim(),
    duration: duration.trim(),
    number: number.trim(),
    startObj,
    endObj,
    durationSecs: parseDuration(duration)
  };
}

// ─────────────────────────────────────────────
//  Load data
// ─────────────────────────────────────────────
function loadData() {
  const raw = document.getElementById('rawData').value.trim();
  if (!raw) return;
  const lines = raw.split('\n');
  allRows = lines.map(parseLine).filter(Boolean);
  document.getElementById('totalBadge').textContent = allRows.length + ' реда';
  applyFilter();
}

function loadSample() {
  const sample = `Иван Иванов|2026-01-27|2026-01-27 08:00:00.0|2026-01-27| 10:30:00.0|02:30:00|5200
Мария Петрова|2026-01-27|2026-01-27 22:30:20.0|2026-01-28| 01:30:21.0|03:00:01|8140
Георги Стоянов|2026-01-27|2026-01-27 09:15:00.0|2026-01-27| 11:00:00.0|01:45:00|3200
Анна Димитрова|2026-01-27||2026-01-27| |00:00:00|0
Петър Николов|2026-01-28|2026-01-28 06:00:00.0|2026-01-28| 14:00:00.0|08:00:00|12000
Елена Попова|2026-01-28|2026-01-28 22:00:00.0|2026-01-29| 02:30:00.0|04:30:00|9800
Христо Василев|2026-01-29|2026-01-29 07:30:00.0|2026-01-29| 09:00:00.0|01:30:00|2900
Ния Тодорова|2026-01-27|2026-01-27 14:00:00.0|2026-01-27| 18:45:00.0|04:45:00|6700
Борис Лазаров|2026-01-28|2026-01-28 10:00:00.0|2026-01-28| 12:00:00.0|02:00:00|4100
Светла Колева|2026-01-29|2026-01-29 23:00:00.0|2026-01-30| 01:00:00.0|02:00:00|3900`;
  document.getElementById('rawData').value = sample;
  loadData();
}

// ─────────────────────────────────────────────
//  Filter logic
// ─────────────────────────────────────────────
function applyFilter() {
  const nameQ = document.getElementById('searchName').value.toLowerCase();

  let fromDT = null, toDT = null;
  if (currentMode === 'datetime') {
    const v = document.getElementById('dt-from').value;
    if (v) fromDT = new Date(v);
  } else if (currentMode === 'range') {
    const vf = document.getElementById('range-from').value;
    const vt = document.getElementById('range-to').value;
    if (vf) fromDT = new Date(vf);
    if (vt) toDT = new Date(vt);
  } else if (currentMode === 'date') {
    const v = document.getElementById('date-only').value;
    if (v) {
      fromDT = new Date(v + 'T00:00:00');
      toDT   = new Date(v + 'T23:59:59');
    }
  }

  const filtered = allRows.filter(row => {
    // Name search
    if (nameQ && !row.name.toLowerCase().includes(nameQ)) return false;

    // No date filter → show all
    if (!fromDT && !toDT) return true;

    // Row must have start (and optionally end) to filter
    const s = row.startObj;
    const e = row.endObj;

    if (!s && !e) return false; // no timestamps → exclude when filtering

    if (currentMode === 'datetime') {
      // Show rows whose interval overlaps or starts at/after fromDT
      // We show rows where start >= fromDT OR (start < fromDT AND end >= fromDT)
      if (!fromDT) return true;
      if (s && s >= fromDT) return true;
      if (s && e && s < fromDT && e >= fromDT) return true;
      return false;
    } else {
      // Range / date-only: row's start-end interval must overlap [fromDT, toDT]
      const f = fromDT || new Date(0);
      const t = toDT || new Date(8640000000000000);
      // Overlap: row_start <= range_end AND row_end >= range_start
      const rowStart = s || f;
      const rowEnd   = e || (s ? new Date(s.getTime() + 86400000) : t);
      return rowStart <= t && rowEnd >= f;
    }
  });

  // Sort
  let sorted = [...filtered];
  if (sortCol !== null) {
    sorted.sort((a, b) => {
      const va = getSortVal(a, sortCol);
      const vb = getSortVal(b, sortCol);
      if (va === vb) return 0;
      if (va === null || va === '') return 1;
      if (vb === null || vb === '') return -1;
      return va < vb ? -sortDir : sortDir;
    });
  }

  renderTable(sorted);
  updateStats(filtered);
}

function getSortVal(row, col) {
  switch(col) {
    case 0: return row.name;
    case 1: return row.startObj ? row.startObj.getTime() : null;
    case 2: return row.endObj ? row.endObj.getTime() : null;
    case 3: return row.durationSecs;
    case 4: return parseInt(row.number) || 0;
    default: return null;
  }
}

function clearFilter() {
  document.getElementById('dt-from').value = '';
  document.getElementById('range-from').value = '';
  document.getElementById('range-to').value = '';
  document.getElementById('date-only').value = '';
  document.getElementById('searchName').value = '';
  applyFilter();
}

// ─────────────────────────────────────────────
//  Render
// ─────────────────────────────────────────────
function renderTable(rows) {
  const container = document.getElementById('tableContainer');

  if (rows.length === 0) {
    container.innerHTML = `<div class="no-results">
      <div class="icon">🔍</div>
      <h3>Няма намерени редове</h3>
      <p>Опитайте с различен диапазон или изчистете филтъра</p>
    </div>`;
    return;
  }

  const cols = [
    { label: 'Име', idx: 0 },
    { label: 'Начало', idx: 1 },
    { label: 'Край', idx: 2 },
    { label: 'Времетраене', idx: 3 },
    { label: 'Номер', idx: 4 },
  ];

  let html = `<table><thead><tr>`;
  cols.forEach(c => {
    const sorted = sortCol === c.idx;
    const icon = sorted ? (sortDir === 1 ? '↑' : '↓') : '⇅';
    html += `<th class="${sorted ? 'sorted' : ''}" onclick="toggleSort(${c.idx})">${c.label} <span class="sort-icon">${icon}</span></th>`;
  });
  html += `</tr></thead><tbody>`;

  for (const row of rows) {
    const startStr = row.startDT || '';
    const endStr   = (row.endDate && row.endTime)
                       ? row.endDate + ' ' + row.endTime.trim()
                       : (row.endDate || '');

    const nameCell = `<td class="name-col" title="${esc(row.name)}">${esc(row.name) || '<span class="empty">—</span>'}</td>`;
    const startCell = startStr
      ? `<td class="date-col">${esc(startStr)}</td>`
      : `<td class="empty">—</td>`;
    const endCell = endStr
      ? `<td class="time-col">${esc(endStr)}</td>`
      : `<td class="empty">—</td>`;
    const durCell = row.duration
      ? `<td class="duration-col"><span class="dur-badge">${esc(row.duration)}</span></td>`
      : `<td class="empty">—</td>`;
    const numCell = row.number
      ? `<td class="number-col">${esc(row.number)}</td>`
      : `<td class="empty">—</td>`;

    html += `<tr>${nameCell}${startCell}${endCell}${durCell}${numCell}</tr>`;
  }

  html += `</tbody></table>`;
  container.innerHTML = html;
}

function esc(s) {
  if (!s) return '';
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ─────────────────────────────────────────────
//  Sort
// ─────────────────────────────────────────────
function toggleSort(colIdx) {
  if (sortCol === colIdx) {
    sortDir *= -1;
  } else {
    sortCol = colIdx;
    sortDir = 1;
  }
  applyFilter();
}

// ─────────────────────────────────────────────
//  Stats
// ─────────────────────────────────────────────
function updateStats(filtered) {
  const withoutTime = filtered.filter(r => !r.startObj).length;
  document.getElementById('statAll').textContent = allRows.length;
  document.getElementById('statFiltered').textContent = filtered.length;
  document.getElementById('statEmpty').textContent = withoutTime;

  const totalSecs = filtered.reduce((sum, r) => sum + (r.durationSecs || 0), 0);
  if (totalSecs > 0) {
    document.getElementById('statDur').textContent = formatDurSecs(totalSecs);
    document.getElementById('statDurGroup').style.display = '';
  } else {
    document.getElementById('statDurGroup').style.display = 'none';
  }
}
</script>

</body>
</html>
