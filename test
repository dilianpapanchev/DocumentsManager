const SYS=["MQ","ORACLE","API","APM","SQL"];
const ORA_ERRS=["ORA-00060","ORA-01555","ORA-00600","ORA-12170","ORA-04031","ORA-01652"];
const API_PATHS=["/api/v2/payments","/api/v2/checkout","/api/v2/orders","/api/v2/users","/api/v1/auth","/api/v2/inventory"];
const MQ_QUEUES=["PAYMENT.IN","PAYMENT.OUT","ORDER.EVENTS","NOTIFY.SMS","AUDIT.LOG","DLQ.PAYMENT"];

function bump(base,hour,peak,width,amp,noise){/* baseline + gaussian incident bump + noise */
  const g=Math.exp(-Math.pow(hour-peak,2)/(2*width*width));
  return Math.max(0,base+amp*g+(RND()-0.5)*noise);}

let DATA=null;
function generateDataset(seed){
  RND=mulberry32(seed>>>0);
  const peak=rint(13,15), pv=peak;      // incident peak hour
  const dName="report_"+(["today","2026-06-30","2026-06-29","batch_night","staging_run"][seed%5]||"today");

  /* ---- severity totals (millions processed; explorer shows a sample) ---- */
  const totalEvents=rint(3_800_000,5_200_000);
  const errors=rint(900,1600), high=rint(8,26), warnings=rint(9000,17000);
  const info=Math.floor(totalEvents*0.62), debug=totalEvents-info-warnings-errors-high;
  const severity={DEBUG:debug,INFO:info,WARNING:warnings,ERROR:errors,HIGH:high};

  /* ---- per-system hourly series ---- */
  const mq={queueDepth:[],consumerLag:[],throughput:[],messages:[]};
  const oracle={sessions:[],deadlocks:[],cpu:[],undo:[],waits:[]};
  const apm={p50:[],p95:[],p99:[],throughput:[],errRate:[]};
  const api={calls:[],c2xx:[],c4xx:[],c5xx:[],latency:[],availability:[]};
  const sql={volume:[]};
  for(let h=0;h<24;h++){
    const day=h>=8&&h<=20?1:0.45;
    mq.throughput.push(Math.round(bump(1800*day,h,pv,4,-600,300)));
    mq.messages.push(Math.round(bump(4200*day,h,pv,3,1600,600)));
    mq.queueDepth.push(Math.round(bump(90*day,h,pv,1.6,620,60)));
    mq.consumerLag.push(Math.round(bump(20,h,pv,1.4,340,20)));
    oracle.sessions.push(Math.round(bump(180*day,h,pv,2.5,260,40)));
    oracle.deadlocks.push(Math.round(bump(0.4,h,pv,1.2,42,1)));
    oracle.cpu.push(Math.round(clamp(bump(38*day,h,pv,1.8,52,8),4,99)));
    oracle.undo.push(Math.round(clamp(bump(46,h,pv,2.2,46,4),20,99)));
    oracle.waits.push(Math.round(bump(120*day,h,pv,1.6,900,60)));
    apm.p50.push(Math.round(bump(60*day,h,pv,2,120,20)));
    apm.p95.push(Math.round(bump(180*day,h,pv,1.8,900,60)));
    apm.p99.push(Math.round(bump(320*day,h,pv,1.6,2200,120)));
    apm.throughput.push(Math.round(bump(2400*day,h,pv,4,-700,300)));
    apm.errRate.push(+clamp(bump(0.6,h,pv,1.4,7,0.4),0,100).toFixed(2));
    const calls=Math.round(bump(52000*day,h,pv,4,9000,4000));
    const err5=Math.round(calls*clamp(bump(0.004,h,pv,1.3,0.07,0.002),0,0.2));
    const err4=Math.round(calls*0.012*(0.6+RND()));
    api.calls.push(calls); api.c5xx.push(err5); api.c4xx.push(err4); api.c2xx.push(calls-err4-err5);
    api.latency.push(Math.round(bump(140*day,h,pv,1.8,1600,80)));
    api.availability.push(+clamp(100-(err5/calls)*100,90,100).toFixed(2));
    sql.volume.push(Math.round(bump(2_400_000,h,pv,6,900_000,120000)+h*38000));
  }
  const avg=a=>a.reduce((x,y)=>x+y,0)/a.length;
  const mqStat={status:"ok",avail:99.9,latency:Math.round(avg(mq.consumerLag)),errors:0.2};
  const oraStat={status:"warn",avail:99.4,latency:Math.round(avg(oracle.waits)/5),errors:2.1};
  const apiStat={status:"crit",avail:97.2,latency:Math.round(avg(api.latency)),errors:8.4};
  const apmStat={status:"ok",avail:99.8,latency:Math.round(avg(apm.p95)),errors:0.6};
  const sqlStat={status:"ok",avail:99.95,latency:12,errors:0.1};

  /* ---- SQL table volumes ---- */
  const sqlTables=[["PAYMENT_TXN",rint(38_000_000,52_000_000)],["ORDER_HDR",rint(12_000_000,20_000_000)],
    ["AUDIT_LOG",rint(180_000_000,320_000_000)],["USER_SESSION",rint(2_000_000,6_000_000)],
    ["INVENTORY",rint(400_000,900_000)],["NOTIFY_OUT",rint(9_000_000,18_000_000)]]
    .map(([n,rows])=>({name:n,rows,sizeMB:Math.round(rows*rint(180,420)/1000/1000),growth:+(RND()*4+0.3).toFixed(1)}))
    .sort((a,b)=>b.rows-a.rows);

  /* ---- hosts ---- */
  const hosts=HOSTS_META.map(([n,os],i)=>{
    const stress=n.includes("api")||n.includes("ora")?1:0;
    const cpu=clamp(Math.round(40+RND()*30+stress*22),8,98);
    const ram=clamp(Math.round(45+RND()*25+stress*18),20,97);
    const disk=clamp(Math.round(55+RND()*30+(n.includes("sql")?12:0)),30,96);
    const st=cpu>88||ram>90||disk>92?"crit":cpu>75||ram>82||disk>85?"warn":"ok";
    const svc=[["MQ","host-mq"],["Oracle","host-ora"],["API","host-api"],["APM","host-apm"],["SQL","host-sql"]]
      .filter(([,p])=>n.startsWith(p)).map(([s])=>s);
    return {name:n,os,cpu,ram,disk,procs:rint(120,320),status:st,
      services:svc.length?svc:[pick(["API","MQ","Cache"])]};
  });

  /* ---- incident + timeline ---- */
  const ph=pad2(peak); const oraId="a91xz"+rint(1,9)+"q";
  const incidents=[{time:ph+":21",title:"Payment Service Outage",system:"API",severity:"crit",
    duration:rint(14,32),affected:["MQ","Oracle","API"],logsCount:rint(340,890),
    desc:"Oracle row-lock contention cascaded into MQ queue accumulation and API 503 responses on the payment path."}];
  const tl=[
    {time:pad2(peak-1)+":52",title:"Baseline nominal",sev:"INFO",system:"APM",detail:"All services within SLA. p95 latency "+apm.p95[peak-1]+"ms."},
    {time:ph+":14",title:"Oracle wait events rising",sev:"WARNING",system:"ORACLE",detail:"enq: TX - row lock contention climbing. Active sessions "+oracle.sessions[peak]+"."},
    {time:ph+":18",title:"MQ consumer lag spike",sev:"WARNING",system:"MQ",detail:"PAYMENT.IN consumer lag "+mq.consumerLag[peak]+" msgs; queue depth "+mq.queueDepth[peak]+"."},
    {time:ph+":21",title:"API 503 errors",sev:"HIGH",system:"API",detail:"Checkout + Payment endpoints returning 503. 5xx rate "+pct(apm.errRate[peak])+"."},
    {time:ph+":22",title:"Oracle deadlock detected",sev:"ERROR",system:"ORACLE",detail:"ORA-00060 deadlock. UNDO tablespace at "+oracle.undo[peak]+"%. SQL_ID "+oraId+"."},
    {time:ph+":28",title:"Consumer group restarted",sev:"INFO",system:"MQ",detail:"Ops restarted PAYMENT consumer group; lag draining."},
    {time:ph+":35",title:"Service recovered",sev:"INFO",system:"API",detail:"Availability restored to "+pct(api.availability[peak+2])+". Incident closed."}
  ];

  /* ---- root cause ---- */
  const rootcause={
    chain:[{title:"503 Errors",sub:"Checkout + Payment API"},{title:"Payment Service Timeout",sub:"upstream call > 2.8s"},
      {title:"MQ Queue Lag",sub:"PAYMENT.IN +"+mq.consumerLag[peak]+" msgs"},{title:"Oracle Deadlock",sub:"ORA-00060 · enq: TX"},
      {title:"UNDO Tablespace "+oracle.undo[peak]+"%",sub:"long-running DML"},{title:"Unindexed bulk UPDATE",sub:"SQL_ID "+oraId,cause:true}],
    prob:[{name:"Oracle",val:82},{name:"MQ",val:13},{name:"API",val:5}],
    timeline:[{time:ph+":20",ev:"Oracle waits"},{time:ph+":21",ev:"MQ lag"},{time:ph+":22",ev:"API latency"},{time:ph+":23",ev:"503 errors"}],
    sqlId:oraId,maxLatency:(2+RND()).toFixed(1),peak503:apm.errRate[peak]
  };

  /* ---- log sample (~4000 lines) ---- */
  const logs=[];
  const N=4000;
  const msgFor=(sys,sev,h)=>{
    if(sys==="ORACLE")return sev==="ERROR"?pick(ORA_ERRS)+": deadlock detected while waiting for resource":
      sev==="WARNING"?"enq: TX - row lock contention; UNDO usage "+oracle.undo[h]+"%":
      sev==="HIGH"?"Long-running query exceeded threshold (SQL_ID "+oraId+")":"Session established, sid="+rint(100,999);
    if(sys==="MQ")return sev==="ERROR"?"Message delivery failed, moved to DLQ.PAYMENT":
      sev==="WARNING"?"Consumer lag on "+pick(MQ_QUEUES)+" = "+rint(50,900):
      "Message consumed from "+pick(MQ_QUEUES)+" ("+rint(1,40)+"ms)";
    if(sys==="API")return sev==="ERROR"?"HTTP 503 upstream unavailable "+pick(API_PATHS):
      sev==="HIGH"?"Request timeout after 3000ms "+pick(API_PATHS):
      sev==="WARNING"?"Slow response "+rint(800,2900)+"ms "+pick(API_PATHS):
      "HTTP 200 "+pick(API_PATHS)+" "+rint(20,300)+"ms";
    if(sys==="APM")return sev==="WARNING"?"Transaction p99 "+rint(900,3200)+"ms (trace sampled)":
      "Span recorded service=payment dur="+rint(10,400)+"ms";
    return sev==="WARNING"?"Table PAYMENT_TXN growth +"+rint(200,900)+"MB/h":
      "Batch insert "+rint(1000,50000)+" rows into "+pick(sqlTables).name;
  };
  const stackFor=sys=>sys==="ORACLE"
    ? "ORA-00060: deadlock detected while waiting for resource\n  at oracle.jdbc.driver.T4CTTIoer.processError()\n  at com.acme.payment.dao.TxnDao.update(TxnDao.java:142)\n  at com.acme.payment.PaymentService.settle(PaymentService.java:88)"
    : sys==="API"
    ? "java.net.SocketTimeoutException: Read timed out\n  at com.acme.gateway.HttpClient.exec(HttpClient.java:210)\n  at com.acme.checkout.PaymentClient.charge(PaymentClient.java:64)\n  at com.acme.checkout.CheckoutController.pay(CheckoutController.java:39)"
    : "com.acme.mq.ConsumerException: delivery failed\n  at com.acme.mq.Listener.onMessage(Listener.java:77)\n  at javax.jms.MessageListener.onMessage()";
  for(let i=0;i<N;i++){
    const h=clamp(Math.round(bump(11,0,pv,4,6,10)*RND()*2)%24,0,23);
    const inWin=Math.abs(h-peak)<=1;
    const r=RND();
    let sev = r<(inWin?0.14:0.02)?"ERROR": r<(inWin?0.20:0.05)?"HIGH": r<(inWin?0.42:0.16)?"WARNING": r<0.62?"INFO":"DEBUG";
    if(sev==="DEBUG"&&RND()<0.3)sev="INFO";
    const sys=sev==="ERROR"||sev==="HIGH"?pick(["ORACLE","API","MQ"]):pick(SYS);
    const host=pick(hosts.filter(x=>x.name.includes(sys.slice(0,3).toLowerCase()))||hosts).name||pick(hosts).name;
    const m=rint(0,59), s=rint(0,59);
    logs.push({ts:`2026-06-30 ${pad2(h)}:${pad2(m)}:${pad2(s)}.${rint(100,999)}`,
      sev,system:sys,host,thread:"t-"+rint(1,64),
      msg:msgFor(sys,sev,h),corr:"c-"+Math.random().toString(16).slice(2,10),
      stack:(sev==="ERROR")?stackFor(sys):null,_h:h});
  }
  logs.sort((a,b)=>a.ts<b.ts?-1:1);

  /* ---- health score ---- */
  const factors=[
    {name:"Error rate",weight:20,val:clamp(100-(errors/900)*30,0,100)},
    {name:"High severity",weight:15,val:clamp(100-high*3,0,100)},
    {name:"API availability",weight:25,val:apiStat.avail},
    {name:"MQ lag",weight:15,val:clamp(100-Math.max(...mq.consumerLag)/8,0,100)},
    {name:"Oracle health",weight:15,val:clamp(100-Math.max(...oracle.undo)/2,0,100)},
    {name:"SLA compliance",weight:10,val:92}
  ];
  const score=Math.round(factors.reduce((s,f)=>s+f.val*f.weight,0)/factors.reduce((s,f)=>s+f.weight,0));
  const label=score>=90?"Healthy":score>=75?"Degraded":score>=60?"At Risk":"Critical";

  DATA={
    meta:{name:dName,start:"2026-06-30 00:00",end:"2026-06-30 23:59",windowLabel:"24h · 2026-06-30",
      totalEvents,peakHour:ph+":00",generated:new Date().toLocaleString("en-GB")},
    severity,peak,
    systems:{
      mq:{...mqStat,...mq},oracle:{...oraStat,...oracle},apm:{...apmStat,...apm},
      api:{...apiStat,...api},sql:{...sqlStat,...sql,tables:sqlTables}
    },
    statuses:{MQ:mqStat,ORACLE:oraStat,API:apiStat,APM:apmStat,SQL:sqlStat},
    hosts,incidents,timeline:tl,rootcause,logs,
    health:{score,label,factors},
    kpis:{events:totalEvents,errors,critical:high,availability:apiStat.avail,peakHour:ph+":00",
      longestIncident:incidents[0].duration}
  };
  return DATA;
}

