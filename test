<script>
// ── State ──────────────────────────────────────────────
let allRows = [];
let mode = 'datetime';
let sortCol = null, sortDir = 1;

// ── Mode switch ────────────────────────────────────────
function setMode(m) {
  mode = m;
  ['datetime','range','date'].forEach(x => {
    document.getElementById('fi-' + x).classList.toggle('hidden', x !== m);
    document.getElementById('tab-' + x).classList.toggle('active', x === m);
  });
}

// ── Parse timestamp ─────────────────────────────────────
// Handles "2026-04-18 01:00:43.0" — removes fractional seconds
function parseTS(s) {
  if (!s || !s.trim()) return null;
  const clean = s.trim().replace(/\.\d+$/, '').replace(' ', 'T');
  const d = new Date(clean);
  return isNaN(d.getTime()) ? null : d;
}

function parseDurSecs(s) {
  if (!s || !s.trim()) return null;
  const p = s.trim().split(':');
  if (p.length < 2) return null;
  return (+p[0]) * 3600 + (+p[1]) * 60 + (+(p[2] || 0));
}

function fmtSecs(s) {
  if (s === null || isNaN(s)) return '—';
  const h = Math.floor(s / 3600), m = Math.floor((s % 3600) / 60), sec = s % 60;
  return [h, m, sec].map(x => String(x).padStart(2, '0')).join(':');
}

// ── Parse one line ──────────────────────────────────────
// Format: RECID|DATE|STARTED|STOPPED|ELAPSED|TRANSACTIONS
function parseLine(line) {
  if (!line.trim()) return null;
  const p = line.split('|');
  const recid        = (p[0] || '').trim();
  const date         = (p[1] || '').trim();
  const startedRaw   = (p[2] || '').trim();
  const stoppedRaw   = (p[3] || '').trim();
  const elapsed      = (p[4] || '').trim();
  const transactions = (p[5] || '').trim();

  return {
    recid, date, startedRaw, stoppedRaw, elapsed, transactions,
    startObj:     parseTS(startedRaw),
    stopObj:      parseTS(stoppedRaw),
    elapsedSecs:  parseDurSecs(elapsed)
  };
}

// ── Load data ──────────────────────────────────────────
function loadData() {
  const raw = document.getElementById('rawData').value.trim();
  if (!raw) return;
  const lines = raw.split('\n').filter(l => {
    const t = l.trim().toUpperCase();
    // Skip empty lines and the header row
    return t && !t.startsWith('RECID|');
  });
  allRows = lines.map(parseLine).filter(Boolean);
  document.getElementById('totalBadge').textContent = allRows.length + ' реда';
  applyFilter();
}

function loadSample() {
  document.getElementById('rawData').value =
`RECID|DATE|STARTED|STOPPED|ELAPSED|TRANSACTIONS
