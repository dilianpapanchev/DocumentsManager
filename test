.mode-tabs {
display: flex;
gap: 8px;
margin-bottom: 20px;
}

.mode-tab {
padding: 8px 18px;
border: 1px solid var(–border);
border-radius: 6px;
background: transparent;
color: var(–text-dim);
font-family: ‘JetBrains Mono’, monospace;
font-size: 0.8rem;
cursor: pointer;
transition: all 0.15s;
}

.mode-tab.active {
background: var(–accent);
