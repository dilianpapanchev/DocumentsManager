   ========================================================================= */
const HOURS=Array.from({length:24},(_,i)=>pad2(i)+":00");
const HOSTS_META=[["host-mq-01","RHEL 9"],["host-ora-01","Oracle Linux 8"],["host-api-01","Ubuntu 22.04"],
