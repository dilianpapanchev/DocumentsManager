<script>
/* =====================================================================
   0. UTIL + SEEDED RNG  (stable report data)
   ===================================================================== */
function mulberry32(a){return function(){a|=0;a=a+0x6D2B79F5|0;let t=Math.imul(a^a>>>15,1|a);t=t+Math.imul(t^t>>>7,61|t)^t;return((t^t>>>14)>>>0)/4294967296;};}
const rnd=mulberry32(20260628);
const ri=(a,b)=>Math.floor(rnd()*(b-a+1))+a;
const rf=(a,b)=>rnd()*(b-a)+a;
const pick=a=>a[Math.floor(rnd()*a.length)];
const cvar=n=>getComputedStyle(document.documentElement).getPropertyValue(n).trim();
const pal=()=>[cvar('--c1'),cvar('--c2'),cvar('--c3'),cvar('--c4'),cvar('--c5'),cvar('--c6')];
const lvCol={DEBUG:'--lv-debug',INFO:'--lv-info',WARNING:'--lv-warn',ERROR:'--lv-error',HIGH:'--lv-high'};
function fmt(n){return Math.round(n).toLocaleString('en-US');}
function fmtShort(v){const a=Math.abs(v);if(a>=1e6)return (v/1e6).toFixed(1)+'M';if(a>=1e4)return (v/1e3).toFixed(0)+'k';if(a>=1e3)return (v/1e3).toFixed(1)+'k';if(a<10&&a%1!==0)return v.toFixed(1);return Math.round(v).toString();}
function niceMax(v){if(v<=0)return 1;const mag=Math.pow(10,Math.floor(Math.log10(v)));const n=v/mag;const s=n<=1?1:n<=1.5?1.5:n<=2?2:n<=2.5?2.5:n<=3?3:n<=5?5:n<=7.5?7.5:10;return s*mag;}
function tween(from,to,dur,delay,cb){setTimeout(()=>{const s=performance.now();(function fr(t){const p=Math.min(1,(t-s)/dur);const e=1-Math.pow(1-p,3);cb(from+(to-from)*e);if(p<1)requestAnimationFrame(fr);})(performance.now());},delay||0);}

/* =====================================================================
   1. SYNTHETIC LOG-DERIVED DATASET
   ===================================================================== */
const HOURS=Array.from({length:24},(_,h)=>('0'+h).slice(-2)+':00');
const dayCurve=[.30,.24,.20,.20,.26,.42,.62,.82,.96,1,1,.95,.9,.95,1,1,.95,.9,.86,.8,.7,.6,.5,.4];
const INCIDENT=[14,15,16]; // часове на инцидент

// --- log levels per hour ---
const LV=['DEBUG','INFO','WARNING','ERROR','HIGH'];
const lvHourly={DEBUG:[],INFO:[],WARNING:[],ERROR:[],HIGH:[]};
for(let h=0;h<24;h++){
  const d=dayCurve[h];const inc=INCIDENT.includes(h);
  const info=Math.round(rf(1800,2600)*d);
  lvHourly.INFO.push(info);
  lvHourly.DEBUG.push(Math.round(info*rf(1.5,2.3)));
  lvHourly.WARNING.push(Math.round(rf(50,150)*d)+(inc?ri(60,140):0));
  lvHourly.ERROR.push(Math.round(rf(6,26)*d)+(inc?ri(110,240):0));
  lvHourly.HIGH.push(Math.round(rf(0,3))+(inc?ri(7,22):0));
}
const lvTotals={};LV.forEach(l=>lvTotals[l]=lvHourly[l].reduce((a,b)=>a+b,0));
const totalEvents=LV.reduce((s,l)=>s+lvTotals[l],0);
const errRatePct=((lvTotals.ERROR+lvTotals.HIGH)/totalEvents*100);
const busiestHour=lvHourly.INFO.indexOf(Math.max(...lvHourly.INFO));
const healthScore=Math.max(0,Math.min(100,Math.round(100 - lvTotals.HIGH*0.09 - lvTotals.ERROR*0.013 - lvTotals.WARNING*0.0016)));

// --- top messages per level ---
const topMessages=[
  {lv:'HIGH',sys:'MQ',msg:'Consumer group ORDER.IN stalled — lag > 5000',count:lvTotals.HIGH? ri(40,80):0},
  {lv:'HIGH',sys:'ORACLE',msg:'ORA-00060 deadlock detected on ORDERS',count:ri(18,46)},
  {lv:'ERROR',sys:'API',msg:'POST /api/v1/checkout → 503 upstream timeout',count:ri(180,420)},
  {lv:'ERROR',sys:'APM',msg:'payment-service transaction error rate spike',count:ri(120,300)},
  {lv:'ERROR',sys:'ORACLE',msg:'ORA-01555 snapshot too old (UNDO)',count:ri(30,90)},
  {lv:'WARNING',sys:'MQ',msg:'Queue depth PAYMENT.REQ above 70% threshold',count:ri(400,900)},
  {lv:'WARNING',sys:'SQL',msg:'Table AUDIT_LOG growth > 8% in 24h',count:ri(120,260)},
  {lv:'WARNING',sys:'APM',msg:'p95 latency > SLA for catalog-service',count:ri(200,500)},
  {lv:'INFO',sys:'API',msg:'Auth token refreshed for service account',count:ri(8000,15000)},
  {lv:'DEBUG',sys:'MQ',msg:'Heartbeat ack received from broker node-2',count:ri(40000,80000)},
];

// --- MQ ---
const mqQueues=['ORDER.IN','ORDER.OUT','PAYMENT.REQ','PAYMENT.RESP','NOTIFY.EMAIL','NOTIFY.SMS','AUDIT.LOG','DLQ.ORDER'];
const mq=mqQueues.map((q,i)=>{
  const enq=ri(20000,180000);const deq=Math.round(enq*rf(0.92,1.0));
  const depth=q.startsWith('DLQ')?ri(120,900):Math.max(0,enq-deq+ri(-200,2400));
  return {q,enq,deq,depth,consumers:q.startsWith('DLQ')?0:ri(2,8),maxDepth:depth+ri(200,3000),dlq:q.startsWith('DLQ')?depth:ri(0,80)};
});
const mqIn=HOURS.map((_,h)=>Math.round(rf(3000,9000)*dayCurve[h]));
const mqOut=mqIn.map((v,h)=>Math.round(v*(INCIDENT.includes(h)?rf(0.6,0.8):rf(0.95,1.02))));
const mqLag=HOURS.map((_,h)=>INCIDENT.includes(h)?ri(2500,6200):ri(20,800));

// --- ORACLE ---
const oraActive=HOURS.map((_,h)=>Math.round(rf(40,120)*dayCurve[h])+(INCIDENT.includes(h)?ri(60,140):0));
const oraTotal=oraActive.map(v=>v+ri(80,200));
const oraSql=[
  {id:'7g3k9m2',sql:'SELECT * FROM ORDERS WHERE status=:1 AND created>:2',execs:ri(12000,40000),avgMs:ri(120,480)},
  {id:'a91xz4q',sql:'UPDATE INVENTORY SET qty=qty-:1 WHERE sku=:2',execs:ri(30000,90000),avgMs:ri(40,160)},
  {id:'p2m7v8s',sql:'SELECT t.* FROM TXN t JOIN ACCT a ON ... ',execs:ri(4000,15000),avgMs:ri(300,1400)},
  {id:'kk0d3f1',sql:'INSERT INTO AUDIT_LOG (...) VALUES (...)',execs:ri(80000,200000),avgMs:ri(8,40)},
  {id:'z5n6b2c',sql:'DELETE FROM SESSION WHERE expires<:1',execs:ri(200,2000),avgMs:ri(500,2200)},
  {id:'w8q1r4t',sql:'SELECT COUNT(*) FROM CART_ITEMS GROUP BY cart_id',execs:ri(6000,20000),avgMs:ri(180,700)},
].map(s=>({...s,totalS:Math.round(s.execs*s.avgMs/1000)})).sort((a,b)=>b.totalS-a.totalS);
const oraTbs=[
  {name:'USERS',usedPct:ri(58,72),sizeGB:ri(40,80)},
  {name:'DATA_TS',usedPct:ri(74,88),sizeGB:ri(200,420)},
  {name:'INDEX_TS',usedPct:ri(62,78),sizeGB:ri(120,260)},
  {name:'UNDO_TS',usedPct:ri(80,95),sizeGB:ri(20,60)},
  {name:'TEMP_TS',usedPct:ri(40,66),sizeGB:ri(30,90)},
];
const oraWaits=[
  {name:'db file sequential read',pct:ri(24,34)},
  {name:'log file sync',pct:ri(14,22)},
  {name:'CPU time',pct:ri(16,26)},
  {name:'enq: TX - row lock',pct:ri(6,14)},
  {name:'gc buffer busy',pct:ri(4,10)},
];

// --- APM ELASTIC ---
const apmServices=['order-service','payment-service','auth-service','catalog-service','notify-service'];
const apm=apmServices.map((s,i)=>{
  const incFactor=s==='payment-service'?2.4:s==='catalog-service'?1.8:1;
  const p50=Math.round(rf(20,80)*incFactor);
  const p95=Math.round(p50*rf(3,6));const p99=Math.round(p95*rf(1.4,2.2));
  return {svc:s,tpm:ri(2000,18000),errPct:+(rf(0.2,1.2)*incFactor).toFixed(2),p50,p95,p99};
});
const apmLatP95={};['payment-service','catalog-service','order-service'].forEach((s,si)=>{
  apmLatP95[s]=HOURS.map((_,h)=>{const base=apm.find(a=>a.svc===s).p95;return Math.round(base*(INCIDENT.includes(h)?rf(2,3.4):rf(0.7,1.15)));});
});
const apmSlowTx=[
  {tx:'POST /checkout',svc:'payment-service',ms:ri(1200,3800),count:ri(400,1200)},
  {tx:'GET /catalog/search',svc:'catalog-service',ms:ri(800,2400),count:ri(2000,6000)},
  {tx:'POST /orders',svc:'order-service',ms:ri(400,1400),count:ri(1500,4000)},
  {tx:'GET /cart',svc:'order-service',ms:ri(200,900),count:ri(3000,9000)},
  {tx:'POST /auth/login',svc:'auth-service',ms:ri(150,700),count:ri(5000,12000)},
].sort((a,b)=>b.ms-a.ms);

// --- API CALLS ---
const apiEndpoints=[
  {m:'GET',path:'/api/v1/products',calls:ri(120000,260000),errPct:+rf(0.1,0.8).toFixed(2),p95:ri(60,180)},
  {m:'POST',path:'/api/v1/checkout',calls:ri(8000,22000),errPct:+rf(2,7).toFixed(2),p95:ri(600,2200)},
  {m:'GET',path:'/api/v1/cart',calls:ri(60000,140000),errPct:+rf(0.2,1.4).toFixed(2),p95:ri(80,260)},
  {m:'POST',path:'/api/v1/auth/login',calls:ri(40000,90000),errPct:+rf(0.5,2.5).toFixed(2),p95:ri(120,420)},
  {m:'GET',path:'/api/v1/orders',calls:ri(30000,70000),errPct:+rf(0.3,1.8).toFixed(2),p95:ri(140,520)},
  {m:'GET',path:'/api/v1/search',calls:ri(50000,110000),errPct:+rf(0.4,2.0).toFixed(2),p95:ri(200,800)},
  {m:'POST',path:'/api/v1/payment',calls:ri(7000,18000),errPct:+rf(1.5,6).toFixed(2),p95:ri(400,1600)},
].map(e=>{const t=e.calls;const s5=Math.round(t*e.errPct/100*rf(0.5,0.8));const s4=Math.round(t*e.errPct/100*rf(0.2,0.5))+ri(50,400);const s3=Math.round(t*rf(0.02,0.06));return {...e,s5,s4,s3,s2:t-s5-s4-s3};});
const apiCallsH=HOURS.map((_,h)=>Math.round(rf(20000,52000)*dayCurve[h]));
const api5xxH=HOURS.map((_,h)=>INCIDENT.includes(h)?ri(1200,3400):ri(40,400));
const api4xxH=HOURS.map((_,h)=>Math.round(rf(200,900)*dayCurve[h]));

// --- SQL TABLE VOLUME ---
const sqlTables=[
  {name:'AUDIT_LOG',rows:ri(820,980)*1e6,sizeGB:ri(380,520),growth:+rf(6,11).toFixed(1)},
  {name:'ORDERS',rows:ri(140,210)*1e6,sizeGB:ri(120,200),growth:+rf(2,4).toFixed(1)},
  {name:'TXN_HISTORY',rows:ri(400,600)*1e6,sizeGB:ri(240,360),growth:+rf(3,6).toFixed(1)},
  {name:'CART_ITEMS',rows:ri(60,120)*1e6,sizeGB:ri(40,90),growth:+rf(1,3).toFixed(1)},
  {name:'SESSION',rows:ri(8,30)*1e6,sizeGB:ri(10,40),growth:+rf(0.5,2).toFixed(1)},
  {name:'PRODUCT_CACHE',rows:ri(20,50)*1e6,sizeGB:ri(20,60),growth:+rf(-1,1).toFixed(1)},
  {name:'NOTIFY_OUTBOX',rows:ri(30,80)*1e6,sizeGB:ri(15,45),growth:+rf(4,9).toFixed(1)},
].map(t=>({...t,growthGB:+(t.sizeGB*t.growth/100).toFixed(1)}));
const sqlGrowthTop=[...sqlTables].sort((a,b)=>b.growthGB-a.growthGB).slice(0,3);
const sqlVolH={};sqlGrowthTop.forEach(t=>{let cur=t.sizeGB-t.growthGB;sqlVolH[t.name]=HOURS.map((_,h)=>+(cur+t.growthGB*(h/23)).toFixed(1));});

// --- ALERTS (from ERROR/HIGH) ---
const alertMsgs=[
  ['MQ','HIGH','Consumer group ORDER.IN stalled, lag=5821'],
  ['ORACLE','HIGH','ORA-00060 deadlock on table ORDERS (sid 142)'],
  ['APM','ERROR','payment-service error rate 8.4% over 5m'],
  ['API','ERROR','POST /api/v1/checkout 503 upstream timeout'],
  ['ORACLE','ERROR','ORA-01555 snapshot too old in UNDO_TS'],
  ['MQ','ERROR','PAYMENT.REQ depth 71% — backpressure applied'],
  ['SQL','WARNING','AUDIT_LOG +9.2% growth in window'],
  ['APM','ERROR','catalog-service p95 1.9s breaches SLA 800ms'],
  ['API','ERROR','POST /api/v1/payment 502 from gateway'],
  ['MQ','HIGH','DLQ.ORDER received 412 poisoned messages'],
];
const alerts=[];
for(let i=0;i<26;i++){
  const inc=i<16;const hour=inc?pick(INCIDENT):ri(0,23);
  const m=alertMsgs[i%alertMsgs.length];
  alerts.push({time:('0'+hour).slice(-2)+':'+('0'+ri(0,59)).slice(-2),hourN:hour,sys:m[0],lv:(inc&&i<6)?'HIGH':(inc?'ERROR':pick(['WARNING','ERROR'])),msg:m[2]});
}
alerts.sort((a,b)=>b.hourN-a.hourN || (b.time>a.time?-1:1));

/* =====================================================================
   2. CHART ENGINE (pure SVG, no deps)
   ===================================================================== */
const tip=document.getElementById('tip');
function showTip(e,html){tip.innerHTML=html;tip.style.display='block';let x=e.clientX+14,y=e.clientY+14;if(x+tip.offsetWidth>innerWidth-8)x=e.clientX-tip.offsetWidth-14;if(y+tip.offsetHeight>innerHeight-8)y=e.clientY-tip.offsetHeight-14;tip.style.left=x+'px';tip.style.top=y+'px';}
function hideTip(){tip.style.display='none';}
function toast(html){const w=document.getElementById('toasts');const el=document.createElement('div');el.className='toast';el.innerHTML='<svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="var(--accent)" stroke-width="2.2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>'+html;w.appendChild(el);setTimeout(()=>el.remove(),3000);}

function drawCartesian(host,cfg){
  const W=host.clientWidth, H=host.clientHeight; if(W<20||H<20)return;
  const ML=cfg.dual?54:46, MR=cfg.dual?48:14, MT=cfg.series.length>1?26:14, MB=28;
  const pw=W-ML-MR, ph=H-MT-MB, n=cfg.x.length;
  const colors=pal(); const t=cfg.type;
  let max=0, max2=0;
  if(t==='stacked'){for(let i=0;i<n;i++){let s=0;cfg.series.forEach(se=>{if(!se.axis2)s+=se.data[i]||0;});max=Math.max(max,s);}}
  else cfg.series.forEach(se=>se.data.forEach(v=>{if(se.axis2)max2=Math.max(max2,v||0);else max=Math.max(max,v||0);}));
  max=niceMax(max); if(cfg.dual)max2=niceMax(max2);
  const xPos=i=>ML+(n<=1?pw/2:(i/(n-1))*pw);
  const yPos=v=>MT+ph-(v/max)*ph;
  const yPos2=v=>MT+ph-(v/(max2||1))*ph;
  const grid=cvar('--grid'),axis=cvar('--axis');
  let s=`<svg viewBox="0 0 ${W} ${H}" width="${W}" height="${H}">`;
  const ticks=4;
  for(let k=0;k<=ticks;k++){const y=MT+ph-(k/ticks)*ph;s+=`<line x1="${ML}" y1="${y.toFixed(1)}" x2="${W-MR}" y2="${y.toFixed(1)}" stroke="${grid}" stroke-dasharray="3 4"/>`;s+=`<text x="${ML-6}" y="${(y+3).toFixed(1)}" fill="${axis}" font-size="10" text-anchor="end" font-family="JetBrains Mono">${fmtShort(max*k/ticks)}</text>`;if(cfg.dual)s+=`<text x="${W-MR+6}" y="${(y+3).toFixed(1)}" fill="${axis}" font-size="10" text-anchor="start" font-family="JetBrains Mono">${fmtShort(max2*k/ticks)}</text>`;}
  const stepL=Math.ceil(n/8);
  for(let i=0;i<n;i+=stepL){s+=`<text x="${xPos(i).toFixed(1)}" y="${H-9}" fill="${axis}" font-size="9.5" text-anchor="middle" font-family="JetBrains Mono">${cfg.x[i]}</text>`;}
  if(t==='bar'||t==='stacked'){
    const gw=pw/n;
    if(t==='stacked'){
      for(let i=0;i<n;i++){let acc=0;cfg.series.forEach((se,si)=>{const v=se.data[i]||0;const h=(v/max)*ph;const bw=gw*0.62;const x=ML+i*gw+gw/2-bw/2;s+=`<rect class="bar" data-h="${h.toFixed(1)}" data-y="${(MT+ph-acc).toFixed(1)}" x="${x.toFixed(1)}" y="${(MT+ph-acc).toFixed(1)}" width="${bw.toFixed(1)}" height="0" rx="2" fill="${se.color||colors[si]}"/>`;acc+=h;});}
    } else {
      const bw=Math.max(2,(gw*0.66)/cfg.series.length);
      cfg.series.forEach((se,si)=>{for(let i=0;i<n;i++){const v=se.data[i]||0;const h=(v/max)*ph;const x=ML+i*gw+gw/2-(bw*cfg.series.length)/2+si*bw;s+=`<rect class="bar" data-h="${h.toFixed(1)}" data-y="${(MT+ph).toFixed(1)}" x="${x.toFixed(1)}" y="${(MT+ph).toFixed(1)}" width="${(bw*0.86).toFixed(1)}" height="0" rx="2" fill="${se.color||colors[si]}"/>`;}});
    }
  } else {
    cfg.series.forEach((se,si)=>{const col=se.color||colors[si];const yp=se.axis2?yPos2:yPos;let d='';se.data.forEach((v,i)=>{d+=(i?'L':'M')+xPos(i).toFixed(1)+' '+yp(v).toFixed(1)+' ';});if(t==='area'&&!se.axis2){let a=d+`L${xPos(n-1).toFixed(1)} ${(MT+ph).toFixed(1)} L${xPos(0).toFixed(1)} ${(MT+ph).toFixed(1)} Z`;s+=`<path class="ar" d="${a}" fill="${col}" opacity="0"/>`;}s+=`<path class="ln" d="${d}" fill="none" stroke="${col}" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>`;});
  }
  s+=`<line class="guide" x1="0" y1="${MT}" x2="0" y2="${MT+ph}" stroke="${cvar('--accent')}" stroke-width="1" opacity="0"/>`;
  s+=`<rect class="ov" x="${ML}" y="${MT}" width="${pw}" height="${ph}" fill="transparent"/></svg>`;
  host.innerHTML=s;
  host.querySelectorAll('.ln').forEach(p=>{const len=p.getTotalLength();p.style.strokeDasharray=len;p.style.strokeDashoffset=len;requestAnimationFrame(()=>{p.style.transition='stroke-dashoffset .85s ease';p.style.strokeDashoffset=0;});});
  host.querySelectorAll('.ar').forEach(p=>requestAnimationFrame(()=>{p.style.transition='opacity .7s ease .2s';p.style.opacity='.16';}));
  [...host.querySelectorAll('.bar')].forEach((b,bi)=>{const h=+b.dataset.h,by=+b.dataset.y;tween(0,h,520,bi*6,val=>{b.setAttribute('height',val.toFixed(1));b.setAttribute('y',(by-val).toFixed(1));});});
  const ov=host.querySelector('.ov'),guide=host.querySelector('.guide'),svg=host.querySelector('svg');
  const idxAt=e=>{const r=svg.getBoundingClientRect();const sx=(e.clientX-r.left)*(W/r.width);let idx=Math.round(((sx-ML)/pw)*(n-1));return Math.max(0,Math.min(n-1,idx));};
  ov.addEventListener('mousemove',e=>{const idx=idxAt(e);const gx=xPos(idx);guide.setAttribute('x1',gx);guide.setAttribute('x2',gx);guide.setAttribute('opacity','.5');showTip(e,`<div class="tt-h">${cfg.x[idx]}</div>`+cfg.series.map((se,si)=>`<div class="tt-r"><span class="tt-d" style="background:${se.color||colors[si]}"></span>${se.name}: <b>${fmt(se.data[idx])}${cfg.unit?' '+cfg.unit:''}</b></div>`).join(''));});
  ov.addEventListener('mouseleave',()=>{guide.setAttribute('opacity','0');hideTip();});
