function spark(mount,data,color,area=true){
  if(!mount)return;const W=mount.clientWidth||160,H=mount.clientHeight||34,pad=2;
  const max=Math.max(...data)||1,min=Math.min(...data);
  const X=i=>pad+(W-2*pad)*i/(data.length-1);
  const Y=v=>H-pad-(H-2*pad)*((v-min)/((max-min)||1));
  const s=svg("svg",{viewBox:`0 0 ${W} ${H}`,width:W,height:H,style:"display:block"});
  const pts=data.map((v,i)=>[X(i),Y(v)]);
  const d="M"+pts.map(p=>p.join(",")).join("L");
  if(area){const gid="sg"+Math.random().toString(36).slice(2,6);
    const defs=svg("defs",{});const lg=svg("linearGradient",{id:gid,x1:0,y1:0,x2:0,y2:1});
    lg.appendChild(svg("stop",{offset:"0%","stop-color":color,"stop-opacity":.35}));
    lg.appendChild(svg("stop",{offset:"100%","stop-color":color,"stop-opacity":0}));
    defs.appendChild(lg);s.appendChild(defs);
    s.appendChild(svg("path",{d:d+`L${X(data.length-1)},${H}L${X(0)},${H}Z`,fill:"url(#"+gid+")"}));}
  const path=svg("path",{d,fill:"none",stroke:color,"stroke-width":1.8,"stroke-linecap":"round","stroke-linejoin":"round"});
  s.appendChild(path);mount.innerHTML="";mount.appendChild(s);
