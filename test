<script>
const HEADERS = %%HEADER_JS%%;
const DATA = %%DATA_JS%%;
const IDX = %%IDX_MAP_JS%%;

(function() {
  const tb = document.getElementById('tb');
  const q = document.getElementById('q');
  const resetBtn = document.getElementById('resetBtn');
  const rowCount = document.getElementById('rowCount');
  const selJobEl = document.getElementById('selJob');

  const chartPanel = document.getElementById('chartPanel');
  const chartSub = document.getElementById('chartSub');
  const chartInfo = document.getElementById('chartInfo');
  const chart = document.getElementById('chart');
  const ctx = chart.getContext('2d');
  const tt = document.getElementById('tt');

  // ---- Column helpers (safe) ----
  function col(name) { return (IDX[name] != null) ? IDX[name] : -1; }
  const C = {
    stage: col('BATCH.STAGE'),
    batch: col('BATCH'),
    job: col('JOB.NAME'),
    bdate: col('BATCH.DATE'),
    start: col('START.TIME'),
    end: col('END.TIME'),
    elapsed: col('ELAPSED'),
    recs: col('PROCESSED RECS'),
    thr: col('THROUGHPUT'),
  };

  function getCell(row, i) { return (i < 0) ? "" : (row[i] ?? ""); }
  function normalize(s) { return (s || "").toString().toLowerCase(); }
  function isNum(v) { v = (v || "").trim(); return /^\d+(\.\d+)?$/.test(v); }

  function fmtHMS(sec) {
    if (sec == null || !isFinite(sec)) return "";
    sec = Math.max(0, Math.floor(sec));
    const h = Math.floor(sec / 3600);
    const m = Math.floor((sec % 3600) / 60);
    const s = sec % 60;
    const pad = (x) => String(x).padStart(2, '0');
    return `${h}:${pad(m)}:${pad(s)}`;
  }

  function parseElapsedToSec(v) {
    v = (v || "").trim();
    if (!v) return NaN;
    if (/^\d+:\d{2}:\d{2}$/.test(v)) {
      const p = v.split(':').map(x => parseInt(x,10));
      return (p[0]||0)*3600 + (p[1]||0)*60 + (p[2]||0);
    }
    if (isNum(v)) return parseFloat(v);
    return NaN;
  }

  function parseTimeToSec(v) {
    v = (v || "").trim();
    if (!v) return NaN;
    if (/^\d+:\d{2}:\d{2}$/.test(v)) {
      const p = v.split(':').map(x=>parseInt(x,10));
      return (p[0]||0)*3600 + (p[1]||0)*60 + (p[2]||0);
    }
    return NaN;
  }

  function escapeHtml(s) {
    return (s||"")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#39;");
  }

  function quantile(sorted, q) {
    const n = sorted.length;
    if (n === 0) return NaN;
    const pos = (n - 1) * q;
    const base = Math.floor(pos);
    const rest = pos - base;
    const a = sorted[base];
    const b = sorted[Math.min(base + 1, n - 1)];
    return a + rest * (b - a);
  }

  function computeStats(nums) {
    const arr = nums.filter(x => isFinite(x)).slice().sort((a,b)=>a-b);
    if (arr.length === 0) return null;
    const med = quantile(arr, 0.50);
    const p95 = quantile(arr, 0.95);
    return { n: arr.length, med, p95 };
  }

  // ---- Collect all dates + per-job history (JOB.NAME baseline) ----
  const allDatesSet = new Set();
  const jobInfo = new Map(); // job -> { dates:Set, elapsedVals:[], thrVals:[], byDate: Map(date->{elapsedSec,thr,recs}), stats }

  for (let i=0; i<DATA.length; i++) {
    const row = DATA[i];
    const job = String(getCell(row, C.job)).trim();
    const d = String(getCell(row, C.bdate)).trim();
    if (d) allDatesSet.add(d);
    if (!job) continue;

    if (!jobInfo.has(job)) {
      jobInfo.set(job, { dates:new Set(), elapsedVals:[], thrVals:[], byDate:new Map(), stats:null });
    }
    const ji = jobInfo.get(job);
    if (d) ji.dates.add(d);

    const e = parseElapsedToSec(getCell(row, C.elapsed));
    if (isFinite(e) && e >= 0) ji.elapsedVals.push(e);

    const tStr = String(getCell(row, C.thr)).trim();
    const t = isNum(tStr) ? parseFloat(tStr) : NaN;
    if (isFinite(t) && t >= 0) ji.thrVals.push(t);

    if (d) {
      const recsStr = String(getCell(row, C.recs)).trim();
      const recs = /^\d+$/.test(recsStr) ? parseInt(recsStr, 10) : NaN;
      const prev = ji.byDate.get(d) || { elapsedSec: NaN, thr: NaN, recs: 0 };
      const next = {
        elapsedSec: isFinite(e) ? Math.max((prev.elapsedSec || 0), e) : prev.elapsedSec,
        thr: isFinite(t) ? t : prev.thr,
        recs: isFinite(recs) ? (prev.recs + recs) : prev.recs
      };
      ji.byDate.set(d, next);
    }
  }

  const allDates = Array.from(allDatesSet).sort();

  // Compute baseline stats per job (median + p95) for elapsed
  for (const [job, ji] of jobInfo.entries()) {
    ji.stats = computeStats(ji.elapsedVals);
    ji.nDates = ji.dates.size;
  }

  // ---- Determine anomalies list ----
  // Rules:
  // - Performance anomaly: elapsed > p95 (only if job has enough history)
  // - Data-quality anomaly always included
  const REGULAR_MIN = 10;

  function dataQualityReasons(row) {
    let sev = "none";
    const reasons = [];

    const d = String(getCell(row, C.bdate)).trim();
    const st = parseTimeToSec(getCell(row, C.start));
    const en = parseTimeToSec(getCell(row, C.end));
    const el = parseElapsedToSec(getCell(row, C.elapsed));
    const recsStr = String(getCell(row, C.recs)).trim();
    const thrStr = String(getCell(row, C.thr)).trim();
    const recs = /^\d+$/.test(recsStr) ? parseInt(recsStr,10) : NaN;
    const thr = isNum(thrStr) ? parseFloat(thrStr) : NaN;

    function bump(s) {
      const rank = { none:0, info:1, warning:2, critical:3 };
      if (rank[s] > rank[sev]) sev = s;
    }

    if (!d || !/^\d{8}$/.test(d)) { bump("warning"); reasons.push("Invalid/missing BATCH.DATE"); }
    if (C.start >= 0 && !isFinite(st)) { bump("warning"); reasons.push("Missing/invalid START.TIME"); }
    if (C.end >= 0 && !isFinite(en)) { bump("warning"); reasons.push("Missing/invalid END.TIME"); }
    if (isFinite(st) && isFinite(en) && en < st) { bump("warning"); reasons.push("END.TIME < START.TIME"); }
    if (isFinite(el) && el < 0) { bump("warning"); reasons.push("Negative ELAPSED"); }
    if (isFinite(recs) && recs > 0 && (thrStr === "0" || thrStr === "" || (!isFinite(thr) || thr === 0))) {
      bump("warning"); reasons.push("PROCESSED RECS > 0 but THROUGHPUT missing/0");
    }
    if (isFinite(recs) && recs > 0 && isFinite(el) && el === 0) {
      bump("warning"); reasons.push("PROCESSED RECS > 0 but ELAPSED = 0");
    }

    return { sev, reasons };
  }

  // Build anomaly rows for display
  // Each item: {date, stage, batch, job, elapsedSec, elapsedStr, medSec, p95Sec, medStr, p95Str, deltaPct, sev, reason, srcIndex}
  const anomalies = [];

  for (let i=0; i<DATA.length; i++) {
    const row = DATA[i];
    const job = String(getCell(row, C.job)).trim();
    if (!job) continue;

    const dq = dataQualityReasons(row);

    const e = parseElapsedToSec(getCell(row, C.elapsed));
    const ji = jobInfo.get(job);
    const st = ji ? ji.stats : null;

    const med = st ? st.med : NaN;
    const p95 = st ? st.p95 : NaN;

    const enoughHist = ji && ji.nDates >= REGULAR_MIN && isFinite(p95) && isFinite(e);

    let isPerfAnom = false;
    if (enoughHist) {
      isPerfAnom = (e > p95);
    }

    const isDqAnom = (dq.sev !== "none");

    if (!isPerfAnom && !isDqAnom) continue;

    // severity for row coloring
    let sev = "info";
    if (isDqAnom) sev = "warning";
    if (isPerfAnom) sev = "critical";

    const date = String(getCell(row, C.bdate)).trim();
    const stage = String(getCell(row, C.stage)).trim();
    const batch = String(getCell(row, C.batch)).trim();

    const elapsedStr = isFinite(e) ? fmtHMS(e) : String(getCell(row, C.elapsed)).trim();
    const medStr = (isFinite(med) && med > 0) ? fmtHMS(med) : "";
    const p95Str = (isFinite(p95) && p95 > 0) ? fmtHMS(p95) : "";

    let deltaPct = "";
    if (isFinite(e) && isFinite(med) && med > 0) {
      deltaPct = ((e / med - 1) * 100);
    }

    const reasonParts = [];
    if (isPerfAnom && isFinite(e) && isFinite(med) && isFinite(p95)) {
      reasonParts.push(`ELAPSED>${p95Str} (median ${medStr})`);
    } else if (isPerfAnom) {
      reasonParts.push("ELAPSED above P95");
    }
    if (isDqAnom) reasonParts.push(dq.reasons.join(" | "));
    const reason = reasonParts.join(" | ");

    anomalies.push({
      date, stage, batch, job,
      elapsedSec: e,
      elapsedStr,
      medSec: med,
      p95Sec: p95,
      medStr,
      p95Str,
      deltaPct,
      sev,
      reason,
      srcIndex: i
    });
  }

  // Default sort: Δ% desc, then elapsed desc
  anomalies.sort((a,b) => {
    const ad = (typeof a.deltaPct === "number" && isFinite(a.deltaPct)) ? a.deltaPct : -Infinity;
    const bd = (typeof b.deltaPct === "number" && isFinite(b.deltaPct)) ? b.deltaPct : -Infinity;
    if (bd !== ad) return bd - ad;
    const ae = isFinite(a.elapsedSec) ? a.elapsedSec : -Infinity;
    const be = isFinite(b.elapsedSec) ? b.elapsedSec : -Infinity;
    return be - ae;
  });

  // ---- Render anomaly table ----
  function fmtDelta(v) {
    if (typeof v !== "number" || !isFinite(v)) return "";
    return Math.round(v).toString() + "%";
  }

  function rowClass(sev) {
    if (sev === "critical") return "sev-critical";
    if (sev === "warning") return "sev-warning";
    return "sev-info";
  }

  function renderTable(items) {
    tb.innerHTML = "";
    const frag = document.createDocumentFragment();

    for (const it of items) {
      const tr = document.createElement('tr');
      tr.className = rowClass(it.sev);
      tr.setAttribute("data-job", it.job);
      tr.setAttribute("data-reason", it.reason || "");
      tr.innerHTML = `
        <td class="mono" title="${escapeHtml(it.reason)}">${escapeHtml(it.date)}</td>
        <td class="mono" title="${escapeHtml(it.stage)}">${escapeHtml(it.stage)}</td>
        <td title="${escapeHtml(it.batch)}">${escapeHtml(it.batch)}</td>
        <td title="${escapeHtml(it.job)}">${escapeHtml(it.job)}</td>
        <td class="mono right" title="${escapeHtml(it.elapsedStr)}">${escapeHtml(it.elapsedStr)}</td>
        <td class="mono right" title="${escapeHtml(it.medStr)}">${escapeHtml(it.medStr)}</td>
        <td class="mono right" title="${escapeHtml(it.p95Str)}">${escapeHtml(it.p95Str)}</td>
        <td class="mono right" title="${escapeHtml(fmtDelta(it.deltaPct))}">${escapeHtml(fmtDelta(it.deltaPct))}</td>
      `;
      frag.appendChild(tr);
    }

    tb.appendChild(frag);
    rowCount.textContent = String(items.length);
    wireRowHandlers();
  }

  // ---- Search / filter ----
  let current = anomalies.slice();

  function applySearch(text) {
    const needle = normalize(text).trim();
    if (!needle) {
      current = anomalies.slice();
      renderTable(current);
      return;
    }
    current = anomalies.filter(r => {
      const hay = normalize([r.date, r.stage, r.batch, r.job, r.elapsedStr, r.medStr, r.p95Str, fmtDelta(r.deltaPct)].join(" "));
      return hay.includes(needle);
    });
    renderTable(current);

    // auto-select if unique job
    const jobs = new Set(current.map(x => x.job));
    if (jobs.size === 1) {
      setSelectedJob(jobs.values().next().value);
    }
  }

  q.addEventListener('input', () => applySearch(q.value));
  resetBtn.addEventListener('click', () => {
    q.value = "";
    applySearch("");
    setSelectedJob(null);
  });

  // ---- Row hover tooltip + click selection ----
  function showTooltip(px, py, html) {
    tt.innerHTML = html;
    tt.style.display = "block";
    tt.style.left = (px + 12) + "px";
    tt.style.top = (py + 12) + "px";
  }

  function hideTooltip() { tt.style.display = "none"; }

  function wireRowHandlers() {
    const rows = tb.querySelectorAll("tr");
    rows.forEach(tr => {
      if (tr.__wired) return;
      tr.__wired = true;

      tr.addEventListener("mousemove", (e) => {
        const reason = tr.getAttribute("data-reason") || "";
        if (!reason) { hideTooltip(); return; }
        showTooltip(e.clientX, e.clientY, `<div style="font-weight:700;margin-bottom:4px;">Anomaly</div><div>${escapeHtml(reason)}</div>`);
      });
      tr.addEventListener("mouseleave", hideTooltip);

      tr.addEventListener("click", () => {
        const job = tr.getAttribute("data-job");
        if (job) setSelectedJob(job);
      });
    });
  }

  // ---- Chart (selected JOB): ELAPSED + THROUGHPUT ----
  let selectedJob = null;
  let chartPoints = null;

  function setSelectedJob(job) {
    if (!job) {
      selectedJob = null;
      selJobEl.textContent = "(none)";
      chartPanel.style.display = "none";
      return;
    }
    selectedJob = job;
    selJobEl.textContent = job;
    drawChartFor(job);
  }

  function drawChartFor(job) {
    const ji = jobInfo.get(job);
    if (!ji) {
      chartPanel.style.display = "none";
      return;
    }

    chartPanel.style.display = "block";

    const cls = (ji.nDates >= 10) ? "REGULAR" : (ji.nDates >= 2) ? "OCCASIONAL" : "RARE";
    chartSub.textContent = `${job} | class=${cls} | history N=${ji.nDates} | banking dates=${allDates.length}`;

    chartInfo.textContent =
      (cls === "RARE") ? "RARE (EOM/EOY вероятно) – малко точки е нормално."
      : (cls === "OCCASIONAL") ? "OCCASIONAL – baseline е ограничен."
      : "REGULAR – baseline е стабилен.";

    const xs = allDates.slice();
    const elapsed = xs.map(d => {
      const v = ji.byDate.get(d);
      return v ? v.elapsedSec : null;
    });
    const thr = xs.map(d => {
      const v = ji.byDate.get(d);
      return v ? v.thr : null;
    });
    const recs = xs.map(d => {
      const v = ji.byDate.get(d);
      return v ? v.recs : null;
    });

    const eVals = elapsed.filter(x=>isFinite(x));
    const tVals = thr.filter(x=>isFinite(x));
    const eMax = eVals.length ? Math.max(...eVals) : 1;
    const tMax = tVals.length ? Math.max(...tVals) : 1;

    const padMax = (m)=> (m<=0 ? 1 : m*1.1);
    const eTop = padMax(eMax);
    const tTop = padMax(tMax);

    const W = chart.width, H = chart.height;
    ctx.clearRect(0,0,W,H);

    const L = 56, R = 56, T = 14, B = 34;
    const PW = W - L - R;
    const PH = H - T - B;

    ctx.fillStyle = "#fafafa";
    ctx.fillRect(0,0,W,H);

    ctx.strokeStyle = "#e8e8e8";
    ctx.lineWidth = 1;
    for (let i=0;i<=5;i++) {
      const y = T + (PH*i/5);
      ctx.beginPath();
      ctx.moveTo(L, y);
      ctx.lineTo(W-R, y);
      ctx.stroke();
    }

    ctx.strokeStyle = "#cfcfcf";
    ctx.beginPath();
    ctx.moveTo(L, T);
    ctx.lineTo(L, H-B);
    ctx.lineTo(W-R, H-B);
    ctx.stroke();

    ctx.fillStyle = "#333";
    ctx.font = "12px Arial";

    function yElapsed(v) { return T + (PH * (1 - (v / eTop))); }
    function yThr(v) { return T + (PH * (1 - (v / tTop))); }

    for (let i=0;i<=5;i++) {
      const v = eTop * (1 - i/5);
      const y = T + (PH*i/5);
      ctx.fillText(fmtHMS(v), 6, y+4);
    }
    for (let i=0;i<=5;i++) {
      const v = tTop * (1 - i/5);
      const y = T + (PH*i/5);
      const label = (Math.round(v*100)/100).toString();
      const textW = ctx.measureText(label).width;
      ctx.fillText(label, W - textW - 6, y+4);
    }

    const n = xs.length;
    const step = Math.max(1, Math.floor(n/6));
    for (let i=0; i<n; i+=step) {
      const x = L + (PW * (i/(n-1 || 1)));
      const d = xs[i];
      const lbl = d.slice(4,6) + "-" + d.slice(6,8);
      ctx.fillText(lbl, x-14, H-12);
    }

    ctx.fillStyle = "#111";
    ctx.font = "12px Arial";
    ctx.fillText("ELAPSED (left) + THROUGHPUT (right)", L+8, T+12);

    function drawLine(series, yMap, stroke) {
      ctx.strokeStyle = stroke;
      ctx.lineWidth = 2;
      ctx.beginPath();
      let started = false;
      for (let i=0; i<n; i++) {
        const v = series[i];
        if (!isFinite(v)) { started = false; continue; }
        const x = L + (PW * (i/(n-1 || 1)));
        const y = yMap(v);
        if (!started) { ctx.moveTo(x,y); started = true; }
        else ctx.lineTo(x,y);
      }
      ctx.stroke();

      ctx.fillStyle = stroke;
      for (let i=0; i<n; i++) {
        const v = series[i];
        if (!isFinite(v)) continue;
        const x = L + (PW * (i/(n-1 || 1)));
        const y = yMap(v);
        ctx.beginPath();
        ctx.arc(x,y,3,0,Math.PI*2);
        ctx.fill();
      }
    }

    drawLine(elapsed, yElapsed, "#d21b1b");
    drawLine(thr, yThr, "#0b62c4");

    ctx.font = "12px Arial";
    ctx.fillStyle = "#111";
    ctx.fillText("● ELAPSED", L+8, H-B+18);
    ctx.fillText("● THROUGHPUT", L+110, H-B+18);
    ctx.fillStyle = "#d21b1b"; ctx.beginPath(); ctx.arc(L+2, H-B+14, 4, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = "#0b62c4"; ctx.beginPath(); ctx.arc(L+104, H-B+14, 4, 0, Math.PI*2); ctx.fill();

    chartPoints = xs.map((d, i) => {
      const x = L + (PW * (i/(n-1 || 1)));
      return { d, x, e: elapsed[i], t: thr[i], r: recs[i] };
    });
  }

  function showChartTooltip(px, py, html) {
    tt.innerHTML = html;
    tt.style.display = "block";
    tt.style.left = (px + 12) + "px";
    tt.style.top = (py + 12) + "px";
  }

  chart.addEventListener('mousemove', (e) => {
    if (!chartPoints || !selectedJob) return;
    const rect = chart.getBoundingClientRect();
    const mx = e.clientX - rect.left;

    let best = null;
    let bestDist = 1e9;
    for (const p of chartPoints) {
      const d = Math.abs(p.x - mx);
      if (d < bestDist) { bestDist = d; best = p; }
    }
    if (!best || bestDist > 18) { tt.style.display = "none"; return; }

    const eVal = isFinite(best.e) ? `${fmtHMS(best.e)} (${Math.round(best.e)}s)` : "(no run)";
    const tVal = isFinite(best.t) ? String(best.t) : "(no run)";
    const rVal = (best.r != null && isFinite(best.r)) ? String(best.r) : "-";

    const html = `
      <div style="font-weight:700;margin-bottom:4px;">${escapeHtml(selectedJob)}</div>
      <div><b>Date:</b> ${escapeHtml(best.d)}</div>
      <div><b>ELAPSED:</b> ${escapeHtml(eVal)}</div>
      <div><b>THROUGHPUT:</b> ${escapeHtml(tVal)}</div>
      <div><b>PROCESSED RECS:</b> ${escapeHtml(rVal)}</div>
    `;
    showChartTooltip(e.clientX, e.clientY, html);
  });
  chart.addEventListener('mouseleave', () => { tt.style.display = "none"; });

  // ---- Sorting in anomalies table ----
  let sortCol = "Delta";
  let sortDir = -1; // desc

  function sortKey(row, colName) {
    if (colName === "Delta") return (typeof row.deltaPct === "number" && isFinite(row.deltaPct)) ? row.deltaPct : -Infinity;
    if (colName === "Elapsed") return isFinite(row.elapsedSec) ? row.elapsedSec : -Infinity;
    if (colName === "Median") return isFinite(row.medSec) ? row.medSec : -Infinity;
    if (colName === "P95") return isFinite(row.p95Sec) ? row.p95Sec : -Infinity;
    if (colName === "Date") return row.date || "";
    if (colName === "Stage") return row.stage || "";
    if (colName === "Batch") return row.batch || "";
    if (colName === "Job") return row.job || "";
    return "";
  }

  function applySort() {
    current.sort((a,b) => {
      const ka = sortKey(a, sortCol);
      const kb = sortKey(b, sortCol);
      if (ka === kb) return 0;
      return (ka > kb ? 1 : -1) * sortDir;
    });
    renderTable(current);
  }

  document.querySelectorAll('thead th[data-col]').forEach(th => {
    th.addEventListener('click', () => {
      const c = th.getAttribute('data-col');
      if (c === sortCol) sortDir *= -1;
      else { sortCol = c; sortDir = -1; }
      applySort();
    });
  });

  // Initial render
  current = anomalies.slice();
  applySort();

})();
</script>
</body>
</html>
