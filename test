function heatColor(t){ // t in 0..1
  t=clamp(t,0,1);
  const mix=(a,b,f)=>a.map((x,i)=>Math.round(x+(b[i]-x)*f));
  const hex=c=>c.replace("#","").match(/../g).map(h=>parseInt(h,16));
  const bg=hex(PALETTE.bg3),w=hex(PALETTE.warn),cr=hex(PALETTE.crit);
  const rgb=t<0.5?mix(bg,w,t/0.5):mix(w,cr,(t-0.5)/0.5);
  return `rgb(${rgb[0]},${rgb[1]},${rgb[2]})`;
}
function paintHeat(){
  const metric=HEAT_METRICS[heatMetric];const rows=Object.keys(metric);
  let html='<table><thead><tr><th class="hlabel"></th>'+HOURS.map((h,i)=>`<th>${i%2===0?pad2(i):""}</th>`).join("")+'</tr></thead><tbody>';
  rows.forEach(sysName=>{
    const arr=metric[sysName](DATA.systems).map(Number);
    const mx=Math.max(...arr)||1;
    html+=`<tr><td class="hlabel">${sysName}</td>`+arr.map((v,i)=>{
      const t=v/mx;const col=heatColor(t);
      return `<td><div class="cell" style="background:${col}" data-t="${sysName} ${pad2(i)}:00: ${fmt(Math.round(v))}"></div></td>`;
    }).join("")+'</tr>';
  });
  html+='</tbody></table>';
  const body=$("#heatBody");body.innerHTML=html;
  body.querySelectorAll(".cell").forEach(c=>{
    c.addEventListener("mousemove",e=>showTip(e.clientX,e.clientY,`<div class="ct-row"><span class="ct-k">${esc(c.dataset.t.split(":")[0])}:00</span><span class="ct-v">${esc(c.dataset.t.split(": ")[1])}</span></div>`));
    c.addEventListener("mouseleave",hideTip);
  });
}

