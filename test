    const fromVal = document.getElementById('r-from').value;
    const toVal   = document.getElementById('r-to').value;

    if (!dateVal || !fromVal || !toVal) { alert('Моля въведете дата, начален и краен час.'); return; }

    const from = new Date(`${dateVal}T${fromVal}`);
    const to   = new Date(`${dateVal}T${toVal}`);
    if (isNaN(from.getTime()) || isNaN(to.getTime())) { alert('Невалидни часове.'); return; }
    if (from > to) { alert('Началният час трябва да е преди крайния.'); return; }

    // Row matches if its [STARTED, STOPPED] interval overlaps with [from, to]
    filtered = DATA.filter(row => {
      if (!isValid(row)) return false;
      const started = parseTs(row.STARTED);
      const stopped = parseTs(row.STOPPED);
      // Overlap: started <= to AND stopped >= from
      return started <= to && stopped >= from;
    });
  }

  renderRows(filtered);
}

function fmt(s) {
  // Remove trailing .0 for display
  return s ? s.replace(/\.\d+$/, '') : '';
}

function renderRows(rows) {
  const tbody = document.getElementById('tbody');
  const empty = document.getElementById('empty');
  document.getElementById('shown-count').textContent = rows.length;

  if (rows.length === 0) {
    tbody.innerHTML = '';
    empty.style.display = '';
