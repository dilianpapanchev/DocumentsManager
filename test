function el(tag,attrs,html){const e=document.createElement(tag);
  if(attrs)for(const k in attrs){if(k==="class")e.className=attrs[k];else if(k==="style")e.style.cssText=attrs[k];else e.setAttribute(k,attrs[k]);}
