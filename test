<script>
const HEADERS = %%HEADER_JS%%;
const DATA = %%DATA_JS%%;

(function() {
  const wrap = document.getElementById('wrap');
  const tb = document.getElementById('tb');
  const q = document.getElementById('q');
  const vc = document.getElementById('vc');
  const tc = document.getElementById('tc');
  const topSpacer = document.getElementById('topSpacer');
  const botSpacer = document.getElementById('botSpacer');

  const onlyAnoms = document.getElementById('onlyAnoms');
  const clearSel = document.getElementById('clearSel');

  const selJobEl = document.getElementById('selJob');
  const selClassEl = document.getElementById('selClass');
  const selNEl = document.getElementById('selN');
  const selDatesEl = document.getElementById('selDates');

  const kCrit = document.getElementById('kCrit');
  const kWarn = document.getElementById('kWarn');
  const kInfo = document.getElementById('kInfo');

  const chartPanel = document.getElementById('chartPanel');
  const chartSub = document.getElementById('chartSub');
  const chartInfo = document.getElementById('chartInfo');
  const chart = document.getElementById('chart');
  const ctx = chart.getContext('2d');
  const tt = document.getElementById('tt');

  // -------- Performance knobs --------
  const ROW_HEIGHT = 34;
  const OVERSCAN = 10;
  const MAX_RENDER = 400;

  // Classification knobs
  const REGULAR_MIN = 10;   // >= 10 of 31 -> regular
  const OCC_MIN = 2;        // 2..9 -> occasional; 1 -> rare

  // Column indices
  const COL = {
    stage: HEADERS.indexOf('BATCH.STAGE'),
    batch: HEADERS.indexOf('BATCH'),
    job: HEADERS.indexOf('JOB.NAME'),
    bdate: HEADERS.indexOf('BATCH.DATE'),
    start: HEADERS.indexOf('START.TIME'),
    end: HEADERS.indexOf('END.TIME'),
    elapsed: HEADERS.indexOf('ELAPSED'),
    recs: HEADERS.indexOf('PROCESSED RECS'),
    thr: HEADERS.indexOf('THROUGHPUT'),
  };

  function getCell(row, i) {
    if (i < 0) return '';
    return (row[i] ?? '');
  }

  function normalize(s) {
    return (s || "").toString().toLowerCase();
  }

  function fmtHMS(sec) {
    if (sec == null || !isFinite(sec)) return "";
    sec = Math.max(0, Math.floor(sec));
    const h = Math.floor(sec / 3600);
    const m = Math.floor((sec % 3600) / 60);
    const s = sec % 60;
    const pad = (x) => String(x).padStart(2, '0');
    return `${h}:${pad(m)}:${pad(s)}`;
  }

  function isNum(v) {
    v = (v || "").trim();
    return /^\d+(\.\d+)?$/.test(v);
  }

  function parseElapsedToSec(v) {
    v = (v || "").trim();
    if (!v) return NaN;
    if (/^\d+:\d{2}:\d{2}$/.test(v)) {
      const p = v.split(':').map(x => parseInt(x,10));
      return (p[0]||0)*3600 + (p[1]||0)*60 + (p[2]||0);
    }
    if (isNum(v)) return parseFloat(v);
    return NaN;
  }

  function parseTimeToSec(v) {
    v = (v || "").trim();
    if (!v) return NaN;
    if (/^\d+:\d{2}:\d{2}$/.test(v)) {
      const p = v.split(':').map(x=>parseInt(x,10));
      return (p[0]||0)*3600 + (p[1]||0)*60 + (p[2]||0);
    }
    return NaN;
  }

  function escapeHtml(s) {
    return (s||"")
      .replaceAll("&","&amp;")
      .replaceAll("<","&lt;")
      .replaceAll(">","&gt;")
      .replaceAll('"',"&quot;")
      .replaceAll("'","&#39;");
  }

  function quantile(sorted, q) {
    const n = sorted.length;
    if (n === 0) return NaN;
    const pos = (n - 1) * q;
    const base = Math.floor(pos);
    const rest = pos - base;
    const a = sorted[base];
    const b = sorted[Math.min(base + 1, n - 1)];
    return a + rest * (b - a);
  }

  function computeStats(nums) {
    const arr = nums.filter(x => isFinite(x)).slice().sort((a,b)=>a-b);
    if (arr.length === 0) return null;
    const q1 = quantile(arr, 0.25);
    const med = quantile(arr, 0.50);
    const q3 = quantile(arr, 0.75);
    const p95 = quantile(arr, 0.95);
    const p5  = quantile(arr, 0.05);
    const iqr = q3 - q1;
    return { n: arr.length, q1, med, q3, iqr, p95, p5 };
  }

  // Build per-job history (by banking date)
  const jobInfo = new Map();
  const allDatesSet = new Set();

  for (let i=0; i<DATA.length; i++) {
    const row = DATA[i];
    const job = String(getCell(row, COL.job)).trim();
    const bdate = String(getCell(row, COL.bdate)).trim();
    if (bdate) allDatesSet.add(bdate);
    if (!job) continue;

    if (!jobInfo.has(job)) {
      jobInfo.set(job, {
        dates: new Set(),
        elapsedVals: [],
        thrVals: [],
        byDate: new Map(), // bdate -> { elapsedSec, thr, recs }
      });
    }

    const ji = jobInfo.get(job);
    if (bdate) ji.dates.add(bdate);

    const e = parseElapsedToSec(getCell(row, COL.elapsed));
    if (isFinite(e) && e >= 0) ji.elapsedVals.push(e);

    const tStr = String(getCell(row, COL.thr)).trim();
    const t = isNum(tStr) ? parseFloat(tStr) : NaN;
    if (isFinite(t) && t >= 0) ji.thrVals.push(t);

    if (bdate) {
      const recsStr = String(getCell(row, COL.recs)).trim();
      const recs = /^\d+$/.test(recsStr) ? parseInt(recsStr, 10) : NaN;

      const prev = ji.byDate.get(bdate) || { elapsedSec: NaN, thr: NaN, recs: 0 };
      const next = {
        elapsedSec: isFinite(e) ? Math.max((prev.elapsedSec || 0), e) : prev.elapsedSec,
        thr: isFinite(t) ? t : prev.thr,
        recs: isFinite(recs) ? (prev.recs + recs) : prev.recs
      };
      ji.byDate.set(bdate, next);
    }
  }

  const allDates = Array.from(allDatesSet).sort();

  for (const [job, ji] of jobInfo.entries()) {
    const dn = ji.dates.size;
    let cls = "RARE";
    if (dn >= REGULAR_MIN) cls = "REGULAR";
    else if (dn >= OCC_MIN) cls = "OCCASIONAL";
    ji.class = cls;
    ji.nDates = dn;
    ji.statsElapsed = computeStats(ji.elapsedVals);
    ji.statsThr = computeStats(ji.thrVals);
  }

  // Row anomaly evaluation
  const rowMeta = new Array(DATA.length);
  let baseCrit=0, baseWarn=0, baseInfo=0;

  function maxSev(a,b) {
    const rank = { none:0, info:1, warning:2, critical:3 };
    return (rank[b] > rank[a]) ? b : a;
  }

  function evalRow(i) {
    const row = DATA[i];
    const job = String(getCell(row, COL.job)).trim();
    const bdate = String(getCell(row, COL.bdate)).trim();

    let sev = "none";
    const reasons = [];

    // Data-quality checks
    const st = parseTimeToSec(getCell(row, COL.start));
    const en = parseTimeToSec(getCell(row, COL.end));
    const el = parseElapsedToSec(getCell(row, COL.elapsed));

    const recsStr = String(getCell(row, COL.recs)).trim();
    const thrStr  = String(getCell(row, COL.thr)).trim();

    const recs = /^\d+$/.test(recsStr) ? parseInt(recsStr,10) : NaN;
    const thr = isNum(thrStr) ? parseFloat(thrStr) : NaN;

    if (!bdate || !/^\d{8}$/.test(bdate)) {
      sev = maxSev(sev, "warning");
      reasons.push("Invalid/missing BATCH.DATE");
    }
    if (COL.start >= 0 && !isFinite(st)) {
      sev = maxSev(sev, "warning");
      reasons.push("Missing/invalid START.TIME");
    }
    if (COL.end >= 0 && !isFinite(en)) {
      sev = maxSev(sev, "warning");
      reasons.push("Missing/invalid END.TIME");
    }
    if (isFinite(st) && isFinite(en) && en < st) {
      sev = maxSev(sev, "warning");
      reasons.push("END.TIME < START.TIME");
    }
    if (isFinite(el) && el < 0) {
      sev = maxSev(sev, "warning");
      reasons.push("Negative ELAPSED");
    }
    if (isFinite(recs) && recs > 0 && (thrStr === "0" || thrStr === "" || (!isFinite(thr) || thr === 0))) {
      sev = maxSev(sev, "warning");
      reasons.push("PROCESSED RECS > 0 but THROUGHPUT missing/0");
    }
    if (isFinite(recs) && recs > 0 && isFinite(el) && el === 0) {
      sev = maxSev(sev, "warning");
      reasons.push("PROCESSED RECS > 0 but ELAPSED = 0");
    }

    // Performance anomaly
    if (job && jobInfo.has(job)) {
      const ji = jobInfo.get(job);

      if (ji.class === "REGULAR" && ji.statsElapsed && isFinite(el)) {
        const s = ji.statsElapsed;
        const critA = isFinite(s.p95) && el > s.p95 * 1.2;
        const critB = isFinite(s.med) && isFinite(s.iqr) && s.iqr > 0 && el > (s.med + 2*s.iqr);
        const warnA = isFinite(s.p95) && el > s.p95;

        if (critA || critB) {
          sev = maxSev(sev, "critical");
          reasons.push(`ELAPSED spike: ${fmtHMS(el)} (median ${fmtHMS(s.med)}, p95 ${fmtHMS(s.p95)})`);
        } else if (warnA) {
          sev = maxSev(sev, "warning");
          reasons.push(`ELAPSED high: ${fmtHMS(el)} (p95 ${fmtHMS(s.p95)})`);
        }
      } else if (ji.class === "OCCASIONAL" && ji.statsElapsed && isFinite(el)) {
        const s = ji.statsElapsed;
        if (isFinite(s.p95) && el > s.p95) {
          sev = maxSev(sev, "warning");
          reasons.push(`ELAPSED high (limited history N=${ji.nDates}): ${fmtHMS(el)} (p95 ${fmtHMS(s.p95)})`);
        }
      }

      // Throughput low -> info
      if (ji.class !== "RARE" && ji.statsThr && isFinite(thr)) {
        const s = ji.statsThr;
        if (isFinite(s.p5) && thr < s.p5) {
          sev = maxSev(sev, "info");
          reasons.push(`THROUGHPUT low: ${thr} (p5 ${s.p5})`);
        }
      }
    }

    return { sev, reason: reasons.join(" | "), job, bdate };
  }

  for (let i=0; i<DATA.length; i++) {
    const m = evalRow(i);
    rowMeta[i] = m;
    if (m.sev === "critical") baseCrit++;
    else if (m.sev === "warning") baseWarn++;
    else if (m.sev === "info") baseInfo++;
  }

  function updateKPIsForCurrentView() {
    let c=0,w=0,inf=0;
    for (let k=0; k<filteredIdx.length; k++) {
      const sev = rowMeta[filteredIdx[k]].sev;
      if (sev === "critical") c++;
      else if (sev === "warning") w++;
      else if (sev === "info") inf++;
    }
    kCrit.textContent = String(c);
    kWarn.textContent = String(w);
    kInfo.textContent = String(inf);
  }

  // Search cache
  const searchCache = new Array(DATA.length).fill(null);
  function rowSearchString(i) {
    let s = searchCache[i];
    if (s !== null) return s;
    s = normalize(DATA[i].join(" "));
    searchCache[i] = s;
    return s;
  }

  // Sorting
  let sortState = { col: -1, dir: 1 };
  function isNumberLike(v) {
    v = (v || "").trim();
    if (!v) return false;
    if (/^\d+:\d{2}:\d{2}$/.test(v)) return true;
    if (/^\d+(\.\d+)?$/.test(v)) return true;
    return false;
  }
  function parseValue(v) {
    v = (v || "").trim();
    if (/^\d+:\d{2}:\d{2}$/.test(v)) {
      const p = v.split(':').map(x=>parseInt(x,10));
      return (p[0]||0)*3600 + (p[1]||0)*60 + (p[2]||0);
    }
    if (/^\d+(\.\d+)?$/.test(v)) return parseFloat(v);
    return v.toLowerCase();
  }

  // Main index
  const idx = Array.from({length: DATA.length}, (_, i) => i);
  let filteredIdx = idx.slice();

  // Selection
  let selectedJob = null;

  function setSelectedJob(job) {
    if (!job) {
      selectedJob = null;
      selJobEl.textContent = "(none)";
      selClassEl.textContent = "-";
      selNEl.textContent = "-";
      selDatesEl.textContent = "-";
      chartPanel.style.display = "none";
      return;
    }
    selectedJob = job;
    selJobEl.textContent = job;

    const ji = jobInfo.get(job);
    if (ji) {
      selClassEl.textContent = ji.class;
      selNEl.textContent = String(ji.nDates);
      selDatesEl.textContent = `${ji.nDates} / ${allDates.length}`;
    } else {
      selClassEl.textContent = "-";
      selNEl.textContent = "-";
      selDatesEl.textContent = "-";
    }
    drawChartFor(job);
  }

  clearSel.addEventListener('click', () => {
    setSelectedJob(null);
    render();
  });

  // Filtering
  let tmr = null;
  q.addEventListener('input', () => {
    if (tmr) clearTimeout(tmr);
    tmr = setTimeout(() => applyFilter(q.value), 140);
  });

  onlyAnoms.addEventListener('change', () => {
    applyFilter(q.value);
  });

  function maybeAutoSelectJob(needle) {
    if (!needle) return;
    const jobs = new Set();
    for (let k=0; k<filteredIdx.length; k++) {
      const j = rowMeta[filteredIdx[k]].job;
      if (j) jobs.add(j);
      if (jobs.size > 1) break;
    }
    if (jobs.size === 1) {
      setSelectedJob(jobs.values().next().value);
    }
  }

  function applyFilter(text) {
    const needle = normalize(text).trim();
    const anomaliesOnly = !!onlyAnoms.checked;

    if (!needle) {
      filteredIdx = anomaliesOnly ? idx.filter(i => rowMeta[i].sev !== "none") : idx.slice();
      wrap.scrollTop = 0;
      render();
      updateKPIsForCurrentView();
      return;
    }

    // with filter: show matches including non-anomalies
    const out = [];
    for (let k=0; k<idx.length; k++) {
      const i = idx[k];
      if (rowSearchString(i).includes(needle)) out.push(i);
    }
    filteredIdx = out;

    maybeAutoSelectJob(needle);

    wrap.scrollTop = 0;
    render();
    updateKPIsForCurrentView();
  }

  // Sorting headers
  document.querySelectorAll('th[data-idx]').forEach(th => {
    th.addEventListener('click', () => {
      const col = parseInt(th.getAttribute('data-idx'), 10);
      const dir = (sortState.col === col) ? -sortState.dir : 1;
      sortState = { col, dir };

      filteredIdx.sort((ia, ib) => {
        const a = DATA[ia][col] ?? "";
        const b = DATA[ib][col] ?? "";
        const an = isNumberLike(a);
        const bn = isNumberLike(b);
        const pa = parseValue(a);
        const pb = parseValue(b);
        if (an && bn) return (pa - pb) * dir;
        return (pa > pb ? 1 : pa < pb ? -1 : 0) * dir;
      });

      wrap.scrollTop = 0;
      render();
    });
  });

  // Virtual render
  let raf = null;
  wrap.addEventListener('scroll', () => {
    if (raf) return;
    raf = requestAnimationFrame(() => {
      raf = null;
      render();
    });
  });

  function clearRenderedRows() {
    while (tb.rows.length > 2) tb.deleteRow(1);
  }

  function labelSeverity(sev) {
    if (sev === "critical") return `<span class="badge b-critical"><span class="dot d-critical"></span>CRIT</span>`;
    if (sev === "warning")  return `<span class="badge b-warning"><span class="dot d-warning"></span>WARN</span>`;
    if (sev === "info")     return `<span class="badge b-info"><span class="dot d-info"></span>INFO</span>`;
    return "";
  }

  function buildRowHTML(row, i) {
    const meta = rowMeta[i];
    const sevBadge = labelSeverity(meta.sev);
    const reason = meta.reason ? meta.reason.replaceAll('"','&quot;') : "";
    const sev = meta.sev;
    const job = meta.job ? meta.job.replaceAll('"','&quot;') : "";

    let tds = "";
    for (let c=0; c<HEADERS.length; c++) {
      const val = (row[c] ?? "");
      if (c === 0 && sevBadge) {
        tds += `<td title="${reason}">${sevBadge}&nbsp;${escapeHtml(String(val))}</td>`;
      } else {
        tds += `<td title="${escapeHtml(String(val))}">${escapeHtml(String(val))}</td>`;
      }
    }
    return `<tr data-sev="${sev}" data-reason="${reason}" data-job="${job}">${tds}</tr>`;
  }

  function wireRowHandlers() {
    for (let r=1; r<tb.rows.length-1; r++) {
      const tr = tb.rows[r];
      if (tr.__wired) continue;
      tr.__wired = true;

      tr.addEventListener('click', () => {
        const job = tr.getAttribute('data-job');
        if (job) setSelectedJob(job);
      });

      tr.addEventListener('mousemove', (e) => {
        const reason = tr.getAttribute('data-reason') || "";
        if (!reason) { tt.style.display = "none"; return; }
        tt.innerHTML = `<div style="font-weight:700;margin-bottom:4px;">Anomaly</div><div>${escapeHtml(reason)}</div>`;
        tt.style.display = "block";
        tt.style.left = (e.clientX + 12) + "px";
        tt.style.top = (e.clientY + 12) + "px";
      });
      tr.addEventListener('mouseleave', () => { tt.style.display = "none"; });
    }
  }

  function render() {
    const total = filteredIdx.length;
    tc.textContent = total.toString();

    const viewH = wrap.clientHeight;
    const scrollTop = wrap.scrollTop;

    const approxStart = Math.floor(scrollTop / ROW_HEIGHT);
    let start = Math.max(0, approxStart - OVERSCAN);
    let end = Math.min(total, approxStart + Math.ceil(viewH / ROW_HEIGHT) + OVERSCAN);
    if (end - start > MAX_RENDER) end = start + MAX_RENDER;

    topSpacer.style.height = (start * ROW_HEIGHT) + "px";
    botSpacer.style.height = Math.max(0, (total - end) * ROW_HEIGHT) + "px";

    clearRenderedRows();

    const frag = document.createDocumentFragment();
    for (let p=start; p<end; p++) {
      const idxRow = filteredIdx[p];
      const tmp = document.createElement('tbody');
      tmp.innerHTML = buildRowHTML(DATA[idxRow], idxRow);
      frag.appendChild(tmp.firstElementChild);
    }
    tb.insertBefore(frag, tb.rows[tb.rows.length - 1]);

    vc.textContent = (end - start).toString();
    wireRowHandlers();
  }

  // ---------------- Chart ----------------
  let chartPoints = null;

  function drawChartFor(job) {
    const ji = jobInfo.get(job);
    if (!ji) { chartPanel.style.display = "none"; return; }
    chartPanel.style.display = "block";

    chartSub.textContent = `${job} | class=${ji.class} | history N=${ji.nDates} | banking dates=${allDates.length}`;
    chartInfo.textContent =
      (ji.class === "RARE") ? "RARE (EOM/EOY вероятно) – малко точки е нормално."
      : (ji.class === "OCCASIONAL") ? "OCCASIONAL – baseline е ограничен."
      : "REGULAR – baseline е стабилен.";

    const xs = allDates.slice();
    const elapsed = xs.map(d => {
      const v = ji.byDate.get(d);
      return v ? v.elapsedSec : null;
    });
    const thr = xs.map(d => {
      const v = ji.byDate.get(d);
      return v ? v.thr : null;
    });
    const recs = xs.map(d => {
      const v = ji.byDate.get(d);
      return v ? v.recs : null;
    });

    const eVals = elapsed.filter(x=>isFinite(x));
    const tVals = thr.filter(x=>isFinite(x));
    const eMax = eVals.length ? Math.max(...eVals) : 1;
    const tMax = tVals.length ? Math.max(...tVals) : 1;

    const padMax = (m)=> (m<=0 ? 1 : m*1.1);
    const eTop = padMax(eMax);
    const tTop = padMax(tMax);

    const W = chart.width, H = chart.height;
    ctx.clearRect(0,0,W,H);

    const L = 56, R = 56, T = 14, B = 34;
    const PW = W - L - R;
    const PH = H - T - B;

    ctx.fillStyle = "#fafafa";
    ctx.fillRect(0,0,W,H);

    ctx.strokeStyle = "#e8e8e8";
    ctx.lineWidth = 1;
    for (let i=0;i<=5;i++) {
      const y = T + (PH*i/5);
      ctx.beginPath();
      ctx.moveTo(L, y);
      ctx.lineTo(W-R, y);
      ctx.stroke();
    }

    ctx.strokeStyle = "#cfcfcf";
    ctx.beginPath();
    ctx.moveTo(L, T);
    ctx.lineTo(L, H-B);
    ctx.lineTo(W-R, H-B);
    ctx.stroke();

    ctx.fillStyle = "#333";
    ctx.font = "12px Arial";

    function yElapsed(v) { return T + (PH * (1 - (v / eTop))); }
    function yThr(v) { return T + (PH * (1 - (v / tTop))); }

    for (let i=0;i<=5;i++) {
      const v = eTop * (1 - i/5);
      const y = T + (PH*i/5);
      ctx.fillText(fmtHMS(v), 6, y+4);
    }
    for (let i=0;i<=5;i++) {
      const v = tTop * (1 - i/5);
      const y = T + (PH*i/5);
      const label = (Math.round(v*100)/100).toString();
      const textW = ctx.measureText(label).width;
      ctx.fillText(label, W - textW - 6, y+4);
    }

    const n = xs.length;
    const step = Math.max(1, Math.floor(n/6));
    for (let i=0; i<n; i+=step) {
      const x = L + (PW * (i/(n-1 || 1)));
      const d = xs[i];
      const lbl = d.slice(4,6) + "-" + d.slice(6,8);
      ctx.fillText(lbl, x-14, H-12);
    }

    ctx.fillStyle = "#111";
    ctx.font = "12px Arial";
    ctx.fillText("ELAPSED (left) + THROUGHPUT (right)", L+8, T+12);

    function drawLine(series, yMap, stroke) {
      ctx.strokeStyle = stroke;
      ctx.lineWidth = 2;
      ctx.beginPath();
      let started = false;
      for (let i=0; i<n; i++) {
        const v = series[i];
        if (!isFinite(v)) { started = false; continue; }
        const x = L + (PW * (i/(n-1 || 1)));
        const y = yMap(v);
        if (!started) { ctx.moveTo(x,y); started = true; }
        else ctx.lineTo(x,y);
      }
      ctx.stroke();

      ctx.fillStyle = stroke;
      for (let i=0; i<n; i++) {
        const v = series[i];
        if (!isFinite(v)) continue;
        const x = L + (PW * (i/(n-1 || 1)));
        const y = yMap(v);
        ctx.beginPath();
        ctx.arc(x,y,3,0,Math.PI*2);
        ctx.fill();
      }
    }

    drawLine(elapsed, yElapsed, "#d21b1b");
    drawLine(thr, yThr, "#0b62c4");

    ctx.font = "12px Arial";
    ctx.fillStyle = "#111";
    ctx.fillText("● ELAPSED", L+8, H-B+18);
    ctx.fillText("● THROUGHPUT", L+110, H-B+18);
    ctx.fillStyle = "#d21b1b"; ctx.beginPath(); ctx.arc(L+2, H-B+14, 4, 0, Math.PI*2); ctx.fill();
    ctx.fillStyle = "#0b62c4"; ctx.beginPath(); ctx.arc(L+104, H-B+14, 4, 0, Math.PI*2); ctx.fill();

    chartPoints = xs.map((d, i) => {
      const x = L + (PW * (i/(n-1 || 1)));
      const e = elapsed[i];
      const t = thr[i];
      return { d, x, e, t, recs: recs[i] };
    });
  }

  function showChartTooltip(px, py, html) {
    tt.innerHTML = html;
    tt.style.display = "block";
    tt.style.left = (px + 12) + "px";
    tt.style.top = (py + 12) + "px";
  }

  chart.addEventListener('mousemove', (e) => {
    if (!chartPoints || !selectedJob) return;
    const rect = chart.getBoundingClientRect();
    const mx = e.clientX - rect.left;

    let best = null;
    let bestDist = 1e9;
    for (const p of chartPoints) {
      const d = Math.abs(p.x - mx);
      if (d < bestDist) { bestDist = d; best = p; }
    }
    if (!best || bestDist > 18) { tt.style.display = "none"; return; }

    const eVal = isFinite(best.e) ? `${fmtHMS(best.e)} (${Math.round(best.e)}s)` : "(no run)";
    const tVal = isFinite(best.t) ? String(best.t) : "(no run)";
    const rVal = (best.recs != null && isFinite(best.recs)) ? String(best.recs) : "-";

    const html = `
      <div style="font-weight:700;margin-bottom:4px;">${escapeHtml(selectedJob)}</div>
      <div><b>Date:</b> ${escapeHtml(best.d)}</div>
      <div><b>ELAPSED:</b> ${escapeHtml(eVal)}</div>
      <div><b>THROUGHPUT:</b> ${escapeHtml(tVal)}</div>
      <div><b>PROCESSED RECS:</b> ${escapeHtml(rVal)}</div>
    `;
    showChartTooltip(e.clientX, e.clientY, html);
  });
  chart.addEventListener('mouseleave', () => { tt.style.display = "none"; });

  // Init KPIs baseline (for initial anomalies-only view)
  kCrit.textContent = String(baseCrit);
  kWarn.textContent = String(baseWarn);
  kInfo.textContent = String(baseInfo);

  // Initial view: anomalies only
  applyFilter("");
})();
</script>
</body>
</html>
"""

    out = base_html
    out = out.replace("%%TITLE%%", esc(title))
    out = out.replace("%%NOW%%", esc(now))
    out = out.replace("%%THS%%", ths)
    out = out.replace("%%COLCOUNT%%", str(col_count))
    out = out.replace("%%HEADER_JS%%", header_js)
    out = out.replace("%%DATA_JS%%", data_js)
    return out


def main():
    if len(sys.argv) < 2:
        print("Usage: python3 csv_to_html_anomalies_virtual_chart.py /path/to/file.csv [output.html]", file=sys.stderr)
        sys.exit(2)

    csv_path = sys.argv[1]
    out_path = sys.argv[2] if len(sys.argv) >= 3 else os.path.splitext(csv_path)[0] + ".html"

    header, rows = read_csv(csv_path)
    title = os.path.basename(csv_path)

    doc = build_html(title, header, rows)

    with open(out_path, "w", encoding="utf-8") as f:
        f.write(doc)

    print(out_path)


if __name__ == "__main__":
    main()
