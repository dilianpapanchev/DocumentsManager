function panelId(el){for(const k in charts)if(charts[k].body&&el.contains(charts[k].body))return k;return null;}
function cycleType(el,id,btn){const d=charts[id];if(!d)return;const i=d.types.indexOf(d.cfg.type);d.cfg.type=d.types[(i+1)%d.types.length];btn.textContent=L().types[d.cfg.type]||d.cfg.type;renderChart(id);}
function toggleMax(el,id){const on=el.classList.toggle('maximized');scrim.classList.toggle('show',on);scrim.onclick=on?()=>toggleMax(el,id):null;setTimeout(()=>{if(id)renderChart(id);},60);}
function wireResize(handle,el){handle.addEventListener('pointerdown',e=>{e.preventDefault();e.stopPropagation();handle.setPointerCapture(e.pointerId);const grid=el.parentElement;const cols=getComputedStyle(grid).gridTemplateColumns.split(' ').length;const gap=15;const cw=(grid.clientWidth-(cols-1)*gap)/cols;const sx=e.clientX,sy=e.clientY;const startSpan=spanOf(el);const startH=el.querySelector('.chart')?el.querySelector('.chart').clientHeight:el.clientHeight;const id=panelId(el);const chartEl=el.querySelector('.chart');
  const move=ev=>{const dCol=Math.round((ev.clientX-sx)/(cw+gap));let nc=Math.max(3,Math.min(12,startSpan+dCol));setSpan(el,nc);if(chartEl){const nh=Math.max(180,startH+(ev.clientY-sy));chartEl.style.height=nh+'px';}if(id)renderChart(id);};
  const up=()=>{handle.releasePointerCapture(e.pointerId);document.removeEventListener('pointermove',move);document.removeEventListener('pointerup',up);};
  document.addEventListener('pointermove',move);document.addEventListener('pointerup',up);});}
function spanOf(el){for(const n of[12,8,7,6,5,4,3])if(el.classList.contains('s'+n))return n;return 6;}
function setSpan(el,n){[3,4,5,6,7,8,12].forEach(x=>el.classList.remove('s'+x));el.style.gridColumn='span '+n;}
let dragEl=null;
function wireReorder(head,el){head.addEventListener('pointerdown',e=>{if(e.target.closest('[data-act]')||e.target.closest('[data-resize]'))return;if(el.classList.contains('maximized'))return;const grid=el.parentElement;let moved=false;const sx=e.clientX,sy=e.clientY;
  const move=ev=>{if(!moved&&(Math.abs(ev.clientX-sx)>6||Math.abs(ev.clientY-sy)>6)){moved=true;dragEl=el;el.classList.add('dragging');}if(!moved)return;const over=document.elementFromPoint(ev.clientX,ev.clientY)?.closest('.panel');grid.querySelectorAll('.panel').forEach(x=>x.classList.remove('drop-target'));if(over&&over!==el&&over.parentElement===grid){over.classList.add('drop-target');const r=over.getBoundingClientRect();const after=(ev.clientX-r.left)>r.width/2;grid.insertBefore(el,after?over.nextSibling:over);}};
  const up=()=>{document.removeEventListener('pointermove',move);document.removeEventListener('pointerup',up);grid.querySelectorAll('.panel').forEach(x=>x.classList.remove('drop-target'));if(dragEl){dragEl.classList.remove('dragging');dragEl=null;renderActive();}};
  document.addEventListener('pointermove',move);document.addEventListener('pointerup',up);});}

