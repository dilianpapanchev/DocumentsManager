  } else {
    series.forEach((se,si)=>{const col=se.color||colors[si];const yp=se.axis2?yPos2:yPos;let d='';se.data.forEach((v,i)=>{d+=(i?'L':'M')+xPos(i).toFixed(1)+' '+yp(v).toFixed(1)+' ';});if(t==='area'&&!se.axis2){s+=`<path class="ar" d="${d}L${xPos(n-1).toFixed(1)} ${(MT+ph).toFixed(1)} L${xPos(0).toFixed(1)} ${(MT+ph).toFixed(1)} Z" fill="${col}" opacity="0"/>`;}s+=`<path class="ln" d="${d}" fill="none" stroke="${col}" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>`;});
