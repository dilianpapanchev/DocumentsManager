function drawDonut(host,cfg){
  const W=host.clientWidth,H=host.clientHeight; if(W<20||H<20)return;
  const t=cfg.type||'donut';const cx=W/2,cy=H/2-8;const R=Math.min(W,H*1.4)/2-30;
  const total=cfg.data.reduce((a,b)=>a+b.value,0)||1;
  let s=`<svg viewBox="0 0 ${W} ${H}" width="${W}" height="${H}">`;
  let a0=-Math.PI/2;
  const maxV=Math.max(...cfg.data.map(d=>d.value));
  cfg.data.forEach((d,i)=>{
    const frac=d.value/total;const a1=a0+frac*Math.PI*2;
    const r=t==='rose'?(R*(0.42+0.58*(d.value/maxV))):R;
    const x0=cx+r*Math.cos(a0),y0=cy+r*Math.sin(a0),x1=cx+r*Math.cos(a1),y1=cy+r*Math.sin(a1);
    const large=(a1-a0)>Math.PI?1:0;
    const path=`M${cx} ${cy} L${x0.toFixed(1)} ${y0.toFixed(1)} A${r} ${r} 0 ${large} 1 ${x1.toFixed(1)} ${y1.toFixed(1)} Z`;
    s+=`<path class="wedge" data-i="${i}" d="${path}" fill="${d.color}" stroke="${cvar('--surface')}" stroke-width="2" opacity="0" style="transform-origin:${cx}px ${cy}px"/>`;
    a0=a1;
  });
  if(t==='donut')s+=`<circle cx="${cx}" cy="${cy}" r="${R*0.56}" fill="${cvar('--surface')}"/>`;
  if(t==='donut'){s+=`<text x="${cx}" y="${cy-2}" text-anchor="middle" fill="${cvar('--text')}" font-size="20" font-weight="700" font-family="JetBrains Mono">${fmtShort(total)}</text>`;s+=`<text x="${cx}" y="${cy+16}" text-anchor="middle" fill="${cvar('--muted')}" font-size="10.5" font-family="JetBrains Mono">${cfg.centerLabel||'общо'}</text>`;}
  // legend bottom
  const lgY=H-12;let lx=14;
  cfg.data.forEach(d=>{s+=`<rect x="${lx}" y="${lgY-9}" width="9" height="9" rx="2" fill="${d.color}"/><text x="${lx+13}" y="${lgY-1}" fill="${cvar('--muted')}" font-size="10" font-family="JetBrains Mono">${d.name}</text>`;lx+=22+d.name.length*6.4;});
  s+=`</svg>`;host.innerHTML=s;
  host.querySelectorAll('.wedge').forEach((w,i)=>{setTimeout(()=>{w.style.transition='opacity .4s ease,transform .25s';w.style.opacity='1';},i*70);
    w.addEventListener('mouseenter',e=>{w.style.transform='scale(1.04)';const d=cfg.data[i];showTip(e,`<div class="tt-r"><span class="tt-d" style="background:${d.color}"></span>${d.name}: <b>${fmt(d.value)}</b> (${(d.value/total*100).toFixed(1)}%)</div>`);});
    w.addEventListener('mousemove',e=>{const d=cfg.data[i];showTip(e,`<div class="tt-r"><span class="tt-d" style="background:${d.color}"></span>${d.name}: <b>${fmt(d.value)}</b> (${(d.value/total*100).toFixed(1)}%)</div>`);});
    w.addEventListener('mouseleave',()=>{w.style.transform='scale(1)';hideTip();});
    w.addEventListener('click',()=>{const d=cfg.data[i];toast(`${d.name}: <b>${fmt(d.value)}</b> (${(d.value/total*100).toFixed(1)}%)`);});
  });
}

function drawGauge(host,cfg){
  const W=host.clientWidth,H=host.clientHeight; if(W<20||H<20)return;
  const cx=W/2,cy=H*0.72,R=Math.min(W/2-20,H*0.62);
  const a0=Math.PI*0.82,a1=Math.PI*0.18; // from left-up to right-up (sweep)
  const start=Math.PI-a0, end=Math.PI+ (Math.PI - (Math.PI-a1)); // simpler: use 210->-30 deg
  const sA=210*Math.PI/180, eA=-30*Math.PI/180;
  const val=cfg.value,max=cfg.max;const frac=Math.min(1,val/max);
  const arc=(r,fr)=>{const aa=sA+(eA-sA)*fr;const x0=cx+r*Math.cos(sA),y0=cy-r*Math.sin(sA);const x1=cx+r*Math.cos(aa),y1=cy-r*Math.sin(aa);const large=(sA-aa)>Math.PI?1:0;return `M${x0.toFixed(1)} ${y0.toFixed(1)} A${r} ${r} 0 ${large} 1 ${x1.toFixed(1)} ${y1.toFixed(1)}`;};
  const col=val>=cfg.crit?cvar('--crit'):val>=cfg.warn?cvar('--warn'):cvar('--ok');
  let s=`<svg viewBox="0 0 ${W} ${H}" width="${W}" height="${H}">`;
  s+=`<path d="${arc(R,1)}" fill="none" stroke="${cvar('--grid')}" stroke-width="14" stroke-linecap="round"/>`;
  s+=`<path class="gv" d="${arc(R,frac)}" fill="none" stroke="${col}" stroke-width="14" stroke-linecap="round"/>`;
  s+=`<text x="${cx}" y="${cy-4}" text-anchor="middle" fill="${cvar('--text')}" font-size="30" font-weight="700" font-family="JetBrains Mono">0</text>`;
  s+=`<text x="${cx}" y="${cy+18}" text-anchor="middle" fill="${cvar('--muted')}" font-size="11" font-family="JetBrains Mono">${cfg.label||''}</text>`;
  s+=`</svg>`;host.innerHTML=s;
  const gv=host.querySelector('.gv');const len=gv.getTotalLength();gv.style.strokeDasharray=len;gv.style.strokeDashoffset=len;requestAnimationFrame(()=>{gv.style.transition='stroke-dashoffset 1s ease';gv.style.strokeDashoffset=0;});
  const txt=host.querySelector('text');tween(0,val,900,100,v=>{txt.textContent=Math.round(v)+(cfg.unit?' '+cfg.unit:'');});
  host.querySelector('svg').addEventListener('click',()=>toast(`${cfg.label}: <b>${val}${cfg.unit?' '+cfg.unit:''}</b>`));
}

function drawHbar(host,cfg){
  const W=host.clientWidth,H=host.clientHeight; if(W<20||H<20)return;
  const items=cfg.items;const n=items.length;const lblW=cfg.lblW||120;const rowH=Math.min(34,(H-12)/n);
