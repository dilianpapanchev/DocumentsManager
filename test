let currentMode = 'datetime';

function setMode(m) {
  currentMode = m;
  document.getElementById('mode-datetime').style.display = m === 'datetime' ? '' : 'none';
  document.getElementById('mode-range').style.display   = m === 'range'    ? '' : 'none';
  document.getElementById('tab-datetime').classList.toggle('active', m === 'datetime');
  document.getElementById('tab-range').classList.toggle('active', m === 'range');
