/* =========================================================================
   PNG EXPORT (SVG -> canvas -> blob), copy + download
   ========================================================================= */
function svgToPng(svgNode,scale,cb,rec){
  const clone=svgNode.cloneNode(true);
  const box=svgNode.getBoundingClientRect();
  const w=Math.max(1,Math.round(box.width)),h=Math.max(1,Math.round(box.height));
  clone.setAttribute("width",w);clone.setAttribute("height",h);
  clone.setAttribute("xmlns",SVGNS);
  // background rect so PNG isn't transparent
  const bg=svg("rect",{x:0,y:0,width:w,height:h,fill:PALETTE.bg1});clone.insertBefore(bg,clone.firstChild);
  const str=new XMLSerializer().serializeToString(clone);
  const url="data:image/svg+xml;base64,"+btoa(unescape(encodeURIComponent(str)));
  const img=new Image();
  img.onload=()=>{const c=document.createElement("canvas");c.width=w*scale;c.height=h*scale;
    const ctx=c.getContext("2d");ctx.scale(scale,scale);ctx.drawImage(img,0,0);
    c.toBlob(b=>cb(b),"image/png");};
  img.onerror=()=>toast("Export failed","Could not rasterize chart","info");
  img.src=url;
}
function dlBlob(blob,name){const u=URL.createObjectURL(blob);const a=el("a",{href:u,download:name});
  document.body.appendChild(a);a.click();a.remove();setTimeout(()=>URL.revokeObjectURL(u),2000);
  toast("Downloaded",name,"ok");}
async function copyBlob(blob){
  try{await navigator.clipboard.write([new ClipboardItem({"image/png":blob})]);
    toast("Copied","PNG copied to clipboard","ok");}
  catch(e){dlBlob(blob,"chart.png");toast("Clipboard unavailable","Downloaded PNG instead","info");}
}

