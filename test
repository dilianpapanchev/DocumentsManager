let SEARCH_INDEX=[];
function buildSearchIndex(){
  SEARCH_INDEX=[];
  NAV.filter(n=>n.id).forEach(n=>SEARCH_INDEX.push({label:n.label,section:n.id,kind:"Section",kw:n.label.toLowerCase()}));
  Object.keys(DATA.statuses).forEach(sy=>SEARCH_INDEX.push({label:sy+" dashboard",section:sy.toLowerCase(),kind:"System",
    kw:(sy+" "+SYSMETA[sy.toLowerCase()].sub).toLowerCase()}));
  [["ORA errors → Log Explorer","logs","ora oracle ora-00060 ora-01555 deadlock undo"],
   ["503 responses → API","api","503 5xx errors availability http"],
   ["Payment path → Root Cause","rootcause","payment checkout timeout latency 503 root cause"],
   ["MQ queue lag → MQ","mq","queue lag consumer payment.in depth backlog broker"],
   ["Latency percentiles → APM","apm","latency p95 p99 slow response percentile"],
   ["SLA compliance → SLA","sla","sla availability target pass fail"],
   ["Deadlocks → Oracle","oracle","deadlock ora-00060 lock undo waits sessions"],
   ["Table volumes → SQL","sql","table volume rows growth audit_log payment_txn storage"],
   ["Disk capacity → Infrastructure","infra","disk cpu ram host capacity forecast"]]
   .forEach(([label,section,kw])=>SEARCH_INDEX.push({label,section,kind:"Shortcut",kw}));
  DATA.hosts.forEach(h=>SEARCH_INDEX.push({label:h.name,section:"infra",kind:"Host",kw:h.name.toLowerCase()+" "+h.os.toLowerCase()}));
}
function runSearch(q){
  const res=$("#searchResults");
  q=q.trim();if(!q){res.classList.remove("show");return;}
  const ql=q.toLowerCase();
  const hits=SEARCH_INDEX.filter(x=>x.kw.includes(ql)||x.label.toLowerCase().includes(ql)).slice(0,8);
  const logMatches=DATA.logs.filter(l=>l.msg.toLowerCase().includes(ql)).length;
  const groups={};hits.forEach(h=>{(groups[h.kind]=groups[h.kind]||[]).push(h);});
  let html="";
  Object.entries(groups).forEach(([g,items])=>{
    html+=`<div class="rgrp">${g}</div>`+items.map((h,i)=>`<div class="ri" data-sec="${h.section}" data-log="">
      <span class="k">${esc(h.label)}</span><span class="m">${h.kind}</span></div>`).join("");
  });
  if(logMatches>0){html+=`<div class="rgrp">Logs</div><div class="ri" data-sec="logs" data-log="${esc(q)}">
    <span class="k">Search logs for “${esc(q)}”</span><span class="m">${fmt(logMatches)} hits</span></div>`;}
  if(!html)html=`<div class="ri"><span class="muted">No matches for “${esc(q)}”</span></div>`;
  res.innerHTML=html;res.classList.add("show");
  res.querySelectorAll(".ri[data-sec]").forEach(ri=>ri.addEventListener("click",()=>{
    const sec=ri.dataset.sec,lg=ri.dataset.log;res.classList.remove("show");$("#smartSearch").value="";
    navTo(sec);if(sec==="logs"&&lg){LOG_STATE.q=lg;LOG_STATE.sys="";LOG_STATE.sev="";const inp=$("#logQ");if(inp){inp.value=lg;paintLogs();}}
  }));
}

