<script>
const SETTINGS={theme:'mission',fontScale:1,chartScale:1,labelScale:1,anim:true,animSpeed:1,radius:1,gridOpacity:1,compact:false,glow:true,numFmt:'short'};
function mulberry32(a){return function(){a|=0;a=a+0x6D2B79F5|0;let t=Math.imul(a^a>>>15,1|a);t=t+Math.imul(t^t>>>7,61|t)^t;return((t^t>>>14)>>>0)/4294967296;};}
const rnd=mulberry32(20260628);
const ri=(a,b)=>Math.floor(rnd()*(b-a+1))+a;
const rf=(a,b)=>rnd()*(b-a)+a;
const cvar=n=>getComputedStyle(document.documentElement).getPropertyValue(n).trim();
const pal=()=>[cvar('--c1'),cvar('--c2'),cvar('--c3'),cvar('--c4'),cvar('--c5'),cvar('--c6')];
const lvCol={DEBUG:'--lv-debug',INFO:'--lv-info',WARNING:'--lv-warn',ERROR:'--lv-error',HIGH:'--lv-high'};
const LS=()=>SETTINGS.labelScale;
const aDur=ms=>SETTINGS.anim?Math.max(1,Math.round(ms/SETTINGS.animSpeed)):1;
function fmt(n){return Math.round(n).toLocaleString('en-US');}
function fmtShort(v){const a=Math.abs(v);if(a>=1e6)return (v/1e6).toFixed(1)+'M';if(a>=1e4)return (v/1e3).toFixed(0)+'k';if(a>=1e3)return (v/1e3).toFixed(1)+'k';if(a<10&&a%1!==0)return v.toFixed(1);return Math.round(v).toString();}
function niceMax(v){if(v<=0)return 1;const mag=Math.pow(10,Math.floor(Math.log10(v)));const n=v/mag;const s=n<=1?1:n<=1.5?1.5:n<=2?2:n<=2.5?2.5:n<=3?3:n<=5?5:n<=7.5?7.5:10;return s*mag;}
function tween(from,to,dur,delay,cb){if(dur<=1){cb(to);return;}setTimeout(()=>{const s=performance.now();(function fr(t){const p=Math.min(1,(t-s)/dur);const e=1-Math.pow(1-p,3);cb(from+(to-from)*e);if(p<1)requestAnimationFrame(fr);})(performance.now());},delay||0);}
const mean=a=>a.reduce((x,y)=>x+y,0)/a.length;
const std=a=>{const m=mean(a);return Math.sqrt(mean(a.map(x=>(x-m)**2)));};
const pctl=(a,p)=>{const s=[...a].sort((x,y)=>x-y);const i=(s.length-1)*p;const lo=Math.floor(i),hi=Math.ceil(i);return s[lo]+(s[hi]-s[lo])*(i-lo);};
const HOURS=Array.from({length:24},(_,h)=>('0'+h).slice(-2)+':00');
const dayCurve=[.30,.24,.20,.20,.26,.42,.62,.82,.96,1,1,.95,.9,.95,1,1,.95,.9,.86,.8,.7,.6,.5,.4];
const INCIDENT=[14,15,16];
const LV=['DEBUG','INFO','WARNING','ERROR','HIGH'];
const lvHourly={DEBUG:[],INFO:[],WARNING:[],ERROR:[],HIGH:[]};
for(let h=0;h<24;h++){const d=dayCurve[h];const inc=INCIDENT.includes(h);const info=Math.round(rf(1800,2600)*d);lvHourly.INFO.push(info);lvHourly.DEBUG.push(Math.round(info*rf(1.5,2.3)));lvHourly.WARNING.push(Math.round(rf(50,150)*d)+(inc?ri(60,140):0));lvHourly.ERROR.push(Math.round(rf(6,26)*d)+(inc?ri(110,240):0));lvHourly.HIGH.push(Math.round(rf(0,3))+(inc?ri(7,22):0));}
const lvTotals={};LV.forEach(l=>lvTotals[l]=lvHourly[l].reduce((a,b)=>a+b,0));
const totalEvents=LV.reduce((s,l)=>s+lvTotals[l],0);
const errRatePct=((lvTotals.ERROR+lvTotals.HIGH)/totalEvents*100);
const busiestHour=lvHourly.INFO.indexOf(Math.max(...lvHourly.INFO));
const healthScore=Math.max(0,Math.min(100,Math.round(100-lvTotals.HIGH*0.09-lvTotals.ERROR*0.013-lvTotals.WARNING*0.0016)));
const errMean=mean(lvHourly.ERROR),errStd=std(lvHourly.ERROR);
const errZ=lvHourly.ERROR.map(v=>errStd?((v-errMean)/errStd):0);
const anomalyHours=errZ.map((z,h)=>({h,z})).filter(o=>o.z>2);
const topMessages=[{lv:'HIGH',sys:'MQ',msg:'Consumer group ORDER.IN stalled — lag > 5000',count:ri(40,80)},{lv:'HIGH',sys:'ORACLE',msg:'ORA-00060 deadlock detected on ORDERS',count:ri(18,46)},{lv:'ERROR',sys:'API',msg:'POST /api/v1/checkout 503 upstream timeout',count:ri(180,420)},{lv:'ERROR',sys:'APM',msg:'payment-service transaction error rate spike',count:ri(120,300)},{lv:'ERROR',sys:'ORACLE',msg:'ORA-01555 snapshot too old (UNDO)',count:ri(30,90)},{lv:'WARNING',sys:'MQ',msg:'Queue depth PAYMENT.REQ above 70% threshold',count:ri(400,900)},{lv:'WARNING',sys:'SQL',msg:'Table AUDIT_LOG growth > 8% in 24h',count:ri(120,260)},{lv:'WARNING',sys:'APM',msg:'p95 latency > SLA for catalog-service',count:ri(200,500)},{lv:'INFO',sys:'API',msg:'Auth token refreshed for service account',count:ri(8000,15000)},{lv:'DEBUG',sys:'MQ',msg:'Heartbeat ack received from broker node-2',count:ri(40000,80000)}];
const mqQueues=['ORDER.IN','ORDER.OUT','PAYMENT.REQ','PAYMENT.RESP','NOTIFY.EMAIL','NOTIFY.SMS','AUDIT.LOG','DLQ.ORDER'];
const mq=mqQueues.map(q=>{const enq=ri(20000,180000);const deq=Math.round(enq*rf(0.92,1.0));const depth=q.startsWith('DLQ')?ri(120,900):Math.max(0,enq-deq+ri(-200,2400));return {q,enq,deq,depth,consumers:q.startsWith('DLQ')?0:ri(2,8),maxDepth:depth+ri(200,3000),dlq:q.startsWith('DLQ')?depth:ri(0,80)};});
const mqIn=HOURS.map((_,h)=>Math.round(rf(3000,9000)*dayCurve[h]));
const mqOut=mqIn.map((v,h)=>Math.round(v*(INCIDENT.includes(h)?rf(0.6,0.8):rf(0.95,1.02))));
const mqLag=HOURS.map((_,h)=>INCIDENT.includes(h)?ri(2500,6200):ri(20,800));
