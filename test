    else{const bw=Math.max(2,(gw*0.66)/series.length);series.forEach((se,si)=>{for(let i=0;i<n;i++){const v=se.data[i]||0;const h=(v/max)*ph;const x=ML+i*gw+gw/2-(bw*series.length)/2+si*bw;s+=`<rect class="bar" data-h="${h.toFixed(1)}" data-y="${(MT+ph).toFixed(1)}" x="${x.toFixed(1)}" y="${(MT+ph).toFixed(1)}" width="${(bw*0.86).toFixed(1)}" height="0" rx="2" fill="${se.color||colors[si]}"/>`;}});}
  } else {
    series.forEach((se,si)=>{const col=se.color||colors[si];const yp=se.axis2?yPos2:yPos;let d='';se.data.forEach((v,i)=>{d+=(i?'L':'M')+xPos(i).toFixed(1)+' '+yp(v).toFixed(1)+' ';});if(t==='area'&&!se.axis2){s+=`<path class="ar" d="${d}L${xPos(n-1).toFixed(1)} ${(MT+ph).toFixed(1)} L${xPos(0).toFixed(1)} ${(MT+ph).toFixed(1)} Z" fill="${col}" opacity="0"/>`;}s+=`<path class="ln" d="${d}" fill="none" stroke="${col}" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>`;});
  }
  s+=`<line class="guide" x1="0" y1="${MT}" x2="0" y2="${MT+ph}" stroke="${cvar('--accent')}" stroke-width="1" opacity="0"/>`;
