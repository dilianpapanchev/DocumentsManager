  const g=gridEl();sec.appendChild(g);
  panel(g,{id:'sql-size',span:'s6',icon:'bars',title:'Размер по таблица',sub:'GB',types:[],cfg:{},draw:(h)=>drawHbar(h,{lblW:140,items:[...sqlTables].sort((a,b)=>b.sizeGB-a.sizeGB).map((t,i)=>({name:t.name,value:t.sizeGB,color:pal()[i%6]})),fmt:v=>v+' GB'})});
  panel(g,{id:'sql-grow',span:'s6',icon:'overview',title:'Прираст / 24h',sub:'GB добавени',types:[],cfg:{},draw:(h)=>drawHbar(h,{lblW:140,items:[...sqlTables].sort((a,b)=>b.growthGB-a.growthGB).map(t=>({name:t.name,value:t.growthGB,color:t.growthGB<0?cvar('--ok'):t.growth>6?cvar('--crit'):cvar('--c4')})),fmt:v=>(v>0?'+':'')+v+' GB'})});
  panel(g,{id:'sql-trend',span:'s8',icon:'sql',title:'Растеж на обема',sub:'топ 3 таблици · 24 часа',types:['line','area'],cfg:{type:'line',unit:'GB',x:HOURS,series:sqlGrowthTop.map((t,i)=>({name:t.name,data:sqlVolH[t.name],color:pal()[i]}))},draw:drawCartesian});
  panel(g,{id:'sql-share',span:'s4',icon:'pie',title:'Дял от обема',sub:'по таблица',types:['donut','pie','rose'],cfg:{type:'donut',centerLabel:'GB',data:[...sqlTables].sort((a,b)=>b.sizeGB-a.sizeGB).slice(0,6).map((t,i)=>({name:t.name,value:t.sizeGB,color:pal()[i%6]}))},draw:drawDonut});
  const cols=[{k:'name',label:'Таблица',cls:'mono'},{k:'rows',label:'Редове',cell:r=>fmtShort(r.rows)},{k:'sizeGB',label:'Размер GB',cell:r=>fmt(r.sizeGB)},{k:'growth',label:'Растеж %',cell:r=>`<span class="lv ${r.growth>6?'error':r.growth>3?'warn':'ok'}">${(r.growth>0?'+':'')+r.growth}%</span>`},{k:'growthGB',label:'+GB/24h',cell:r=>(r.growthGB>0?'+':'')+r.growthGB}];
  panel(g,{id:'sql-tbl',span:'s12',icon:'table',title:'Таблици — детайли',sub:'sortable',types:[],cfg:{},body:'<div class="tbl-host"></div>',after:el=>sortTable(el.querySelector('.tbl-host'),cols,sqlTables,{k:'sizeGB',dir:-1})});
}

let alertFilter='ALL';
function buildAlerts(sec){
  const high=alerts.filter(a=>a.lv==='HIGH').length,err=alerts.filter(a=>a.lv==='ERROR').length;
  sec.appendChild(intro(`Хронологична лента от <b>${alerts.length}</b> аларми, извлечени от ERROR/HIGH събития. <span class="hl">${high}</span> критични (HIGH), <span class="hl">${err}</span> ERROR. Над 60% попадат в инцидентния прозорец 14:00–16:00.`));
  sec.appendChild(kpiGrid([
    kpiCard({lbl:'Аларми общо',val:alerts.length,color:'var(--lv-error)',sub:'24h'}),
    kpiCard({lbl:'HIGH',val:high,color:'var(--lv-high)',sub:'критични'}),
    kpiCard({lbl:'ERROR',val:err,color:'var(--lv-error)',sub:'грешки'}),
    kpiCard({lbl:'Засегнати системи',val:new Set(alerts.map(a=>a.sys)).size,sub:'MQ/ORA/APM/API/SQL'}),
  ],4));
  const g=gridEl();sec.appendChild(g);
  panel(g,{id:'al-tl',span:'s12',icon:'alerts',title:'Лента на алармите',sub:'хронологично',types:[],cfg:{},body:`<div class="tl-filter" id="tlFilter">${['ALL','HIGH','ERROR','WARNING'].map(f=>`<button data-f="${f}" class="${f==='ALL'?'on':''}">${f==='ALL'?'Всички':f}</button>`).join('')}</div><div class="timeline" id="timeline"></div>`,after:el=>{
    const tl=el.querySelector('#timeline');
    function renderTL(){const list=alertFilter==='ALL'?alerts:alerts.filter(a=>a.lv===alertFilter);tl.innerHTML=list.map(a=>`<div class="tl-item"><div class="tl-time">${a.time}</div><div class="tl-dot" style="background:${cvar(lvCol[a.lv])}"></div><div class="tl-body"><div class="tl-h"><span class="lv ${a.lv.toLowerCase()}">${a.lv}</span><span class="tl-sys">${a.sys}</span></div><div class="tl-msg">${a.msg}</div></div></div>`).join('');}
    el.querySelectorAll('#tlFilter button').forEach(b=>b.onclick=()=>{alertFilter=b.dataset.f;el.querySelectorAll('#tlFilter button').forEach(x=>x.classList.remove('on'));b.classList.add('on');renderTL();});
    renderTL();
  }});
}

const BUILDERS={overview:buildOverview,levels:buildLevels,mq:buildMQ,oracle:buildOracle,apm:buildAPM,api:buildAPI,sql:buildSQL,alerts:buildAlerts};

/* =====================================================================
   8. NAV + ACTIVATION
   ===================================================================== */
function buildNav(){
  const nav=document.getElementById('nav');const N=L().nav;
  const groups=[['Общо',['overview','levels']],['Системи',['mq','oracle','apm','api','sql']],['Събития',['alerts']]];
  const counts={overview:fmtShort(totalEvents),levels:fmtShort(lvTotals.WARNING+lvTotals.ERROR+lvTotals.HIGH),mq:fmt(mq.reduce((a,q)=>a+q.dlq,0)),oracle:oraSql.filter(s=>s.avgMs>500).length,apm:apm.filter(a=>a.errPct>1).length,api:fmt(apiEndpoints.reduce((a,e)=>a+e.s5,0)),sql:fmt(sqlTables.length),alerts:alerts.length};
  nav.innerHTML=groups.map(([g,items])=>`<div class="grp">${g}</div>`+items.map(id=>`<a data-sec="${id}" class="${id==='alerts'?'alert':''}">${ic(id)}<span>${N[id]}</span><span class="ct">${counts[id]}</span></a>`).join('')).join('');
  nav.querySelectorAll('a').forEach(a=>a.onclick=()=>{activate(a.dataset.sec);document.getElementById('sidebar').classList.remove('open');document.getElementById('sbScrim').classList.remove('show');});
  // legend
  document.getElementById('legend').innerHTML=LV.map(l=>`<div class="lg"><i style="background:${cvar(lvCol[l])}"></i>${l}</div>`).join('');
}
function buildAllSections(){
  content.innerHTML='';panelSeq=0;for(const k in charts)delete charts[k];
  SECTIONS.forEach(id=>{const sec=document.createElement('section');sec.dataset.sec=id;if(id===active)sec.classList.add('on');BUILDERS[id](sec);content.appendChild(sec);secCharts[id]=Object.keys(charts).filter(cid=>sec.contains(charts[cid].body));});
}
function renderActive(){const ids=Object.keys(charts).filter(cid=>{const b=charts[cid].body;return b&&b.closest('section')?.classList.contains('on');});ids.forEach(renderChart);if(active==='overview')renderOverviewExtras();}
function activate(id){active=id;document.querySelectorAll('section[data-sec]').forEach(s=>s.classList.toggle('on',s.dataset.sec===id));document.querySelectorAll('#nav a').forEach(a=>a.classList.toggle('on',a.dataset.sec===id));document.getElementById('secTitle').textContent=L().nav[id];document.getElementById('secPeriod').textContent=L().period;requestAnimationFrame(()=>setTimeout(renderActive,30));content.scrollIntoView({behavior:'smooth',block:'start'});}

/* =====================================================================
   9. CONTROLS
   ===================================================================== */
document.getElementById('themeBtn').onclick=e=>{e.stopPropagation();document.getElementById('themeMenu').classList.toggle('open');};
document.addEventListener('click',()=>document.getElementById('themeMenu').classList.remove('open'));
document.getElementById('langBtn').onclick=()=>{lang=lang==='bg'?'en':'bg';applyLang();};
document.getElementById('burger').onclick=()=>{document.getElementById('sidebar').classList.toggle('open');document.getElementById('sbScrim').classList.toggle('show');};
document.getElementById('sbScrim').onclick=()=>{document.getElementById('sidebar').classList.remove('open');document.getElementById('sbScrim').classList.remove('show');};
document.getElementById('printBtn').onclick=()=>{SECTIONS.forEach(id=>{const s=document.querySelector(`section[data-sec="${id}"]`);s.classList.add('on');secCharts[id].forEach(renderChart);});renderOverviewExtras();setTimeout(()=>window.print(),400);setTimeout(()=>document.querySelectorAll('section[data-sec]').forEach(s=>s.classList.toggle('on',s.dataset.sec===active)),1200);};
document.getElementById('exportBtn').onclick=()=>{const rows=['hour,'+LV.join(',')];HOURS.forEach((h,i)=>rows.push(h+','+LV.map(l=>lvHourly[l][i]).join(',')));const blob=new Blob([rows.join('\n')],{type:'text/csv'});const url=URL.createObjectURL(blob);const a=document.createElement('a');a.href=url;a.download='log_levels_by_hour.csv';a.click();URL.revokeObjectURL(url);toast(L().exported+' • <b>24</b> '+(lang==='bg'?'реда':'rows'));};
function applyLang(){document.documentElement.lang=lang;document.getElementById('brandsub').textContent=L().brand;document.getElementById('langTxt').textContent=L().lang;document.getElementById('themeTxt').textContent=L().theme;document.getElementById('exportTxt').textContent=L().csv;document.getElementById('printTxt').textContent=L().print;buildNav();buildAllSections();activate(active);}

window.addEventListener('resize',()=>{clearTimeout(window._rz);window._rz=setTimeout(renderActive,180);});

/* =====================================================================
   10. INIT
   ===================================================================== */
buildThemeMenu();buildNav();buildAllSections();
document.getElementById('secPeriod').textContent=L().period;
activate('overview');
</script>
</body>
</html>
