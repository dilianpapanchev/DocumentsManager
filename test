  s+=`</svg>`;host.innerHTML=s;
  host.querySelectorAll('.wedge').forEach((w,i)=>{setTimeout(()=>{w.style.transition=`opacity ${aDur(400)/1000}s ease,transform .25s`;w.style.opacity='1';},i*aDur(70));
