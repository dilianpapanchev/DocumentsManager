  renderRows(DATA);
}

function applyFilter() {
  let filtered;

  if (currentMode === 'datetime') {
    const dateVal = document.getElementById('dt-date').value; // "YYYY-MM-DD"
    const timeVal = document.getElementById('dt-time').value; // "HH:MM" or "HH:MM:SS"

    if (!dateVal || !timeVal) { alert('Моля въведете дата и час.'); return; }

    const target = new Date(`${dateVal}T${timeVal}`);
    if (isNaN(target.getTime())) { alert('Невалидна дата/час.'); return; }

    filtered = DATA.filter(row => {
      if (!isValid(row)) return false;
      const started = parseTs(row.STARTED);
      const stopped = parseTs(row.STOPPED);
      return target >= started && target <= stopped;
    });

