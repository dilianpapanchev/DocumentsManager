function render() {
  const total = filteredIdx.length;
  tc.textContent = total.toString();

  const viewH = wrap.clientHeight;
  const scrollTop = wrap.scrollTop;

  const approxStart = Math.floor(scrollTop / ROW_HEIGHT);
  let start = Math.max(0, approxStart - OVERSCAN);
  let end = Math.min(total, approxStart + Math.ceil(viewH / ROW_HEIGHT) + OVERSCAN);
  if (end - start > MAX_RENDER) end = start + MAX_RENDER;

  topSpacer.style.height = (start * ROW_HEIGHT) + "px";
  botSpacer.style.height = Math.max(0, (total - end) * ROW_HEIGHT) + "px";

  // clear between spacers
  while (tb.rows.length > 2) tb.deleteRow(1);

  const frag = document.createDocumentFragment();
  for (let p = start; p < end; p++) {
    const i = filteredIdx[p];
    const r = DATA[i];

    const tr = document.createElement('tr');
    for (let c = 0; c < HEADERS.length; c++) {
      const td = document.createElement('td');
      td.textContent = (r[c] ?? "");
      tr.appendChild(td);
    }
    frag.appendChild(tr);
  }
  tb.insertBefore(frag, tb.rows[tb.rows.length - 1]);

  vc.textContent = (end - start).toString();
}
