    :'<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01"/></svg>';
  t.innerHTML=`<div class="tst-ic">${ic}</div><div><b>${esc(title)}</b>${sub?`<span>${esc(sub)}</span>`:""}</div>`;
  $("#toasts").appendChild(t);
